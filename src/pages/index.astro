---
import BaseLayout from "../layouts/BaseLayout.astro";
import fundamentals from "../data/fundamentals.json";
import { getCollection } from "astro:content";

const companies = [...(fundamentals.companies || [])].sort((a, b) =>
  String(a.ticker).localeCompare(String(b.ticker))
);

const articles = (
  await getCollection("articles", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const fmtDate = (d) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<BaseLayout title="Owner Scorecard">
  <p class="intro">
    The vital signs of a business — pulled from its own SEC filings, shown with the
    arithmetic, with no rating and no estimate. Pick a company for its Owner’s
    Scorecard, or read why the numbers matter.
  </p>

  <div class="stickyBar">
    <div class="metaRow">
      <div class="count">{companies.length} companies</div>
      <div class="count">{fundamentals.sample ? "sample data" : `as of ${fundamentals.asOf}`}</div>
    </div>
    <input id="q" type="search" placeholder="Search ticker or name…" class="search" autocomplete="off" />
  </div>

  <ul class="list" id="list">
    {companies.map((c) => (
      <li data-search={`${c.ticker} ${c.name || ""}`.toLowerCase()}>
        <span class="ticker"><a href={`/c/${c.ticker}`}>{c.ticker}</a></span>
        <span class="name"><a href={`/c/${c.ticker}`}>{c.name}</a></span>
      </li>
    ))}
  </ul>

  {articles.length ? (
    <section class="reading">
      <h2>Reading</h2>
      <ul class="alist">
        {articles.map((a) => (
          <li>
            <a href={`/articles/${a.id}`}>{a.data.title}</a>
            <span class="adate">{fmtDate(a.data.date)}</span>
          </li>
        ))}
      </ul>
      <p class="more"><a href="/articles">All articles →</a></p>
    </section>
  ) : null}

  <style>
    .intro {
      font-family: var(--serif); font-style: italic;
      font-size: clamp(18px, 2.6vw, 21px); line-height: 1.45;
      color: #3a3e46; margin: 2px 0 24px; max-width: 64ch;
    }

    .stickyBar { position: sticky; top: 0; z-index: 20; background: var(--paper); padding: 12px 0; border-bottom: 1px solid var(--rule); }
    .metaRow { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 8px; }
    .count { font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
    .search { width: 100%; padding: 11px 12px; border: 1px solid var(--rule-strong); font-family: var(--sans); font-size: 15px; background: #fff; }
    .search::placeholder { color: var(--faint); }

    .list { list-style: none; padding-left: 0; margin: 16px 0 0; }
    .list li { padding: 12px 2px; display: flex; gap: 14px; align-items: baseline; border-bottom: 1px solid var(--rule); }
    .ticker { font-weight: 700; width: 76px; flex: 0 0 auto; font-variant-numeric: tabular-nums; }
    .ticker a { color: var(--accent); }
    .name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
    .name a { color: var(--ink); }

    .reading { margin-top: 36px; }
    .reading h2 { border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
    .alist { list-style: none; padding-left: 0; margin: 12px 0 0; }
    .alist li { display: flex; justify-content: space-between; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--rule); align-items: baseline; }
    .alist a { font-family: var(--serif); font-size: 17px; }
    .adate { color: var(--muted); font-size: 12px; flex: 0 0 auto; font-variant-numeric: tabular-nums; }
    .more { margin: 12px 0 0; font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; }
  </style>

  <script is:inline>
    const q = document.getElementById("q");
    const items = Array.from(document.querySelectorAll('li[data-search]'));
    function refresh() {
      const term = (q.value || "").trim().toLowerCase();
      for (const li of items) li.style.display = !term || li.dataset.search.includes(term) ? "" : "none";
    }
    q?.addEventListener("input", refresh);
  </script>
</BaseLayout>
