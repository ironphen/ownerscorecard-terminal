---
import BaseLayout from "../layouts/BaseLayout.astro";
import reports from "../data/reports.json";

const latestByTicker = new Map();

// Keep only the most recent report per ticker
for (const r of reports || []) {
  if (!r?.ticker) continue;
  const t = String(r.ticker).toUpperCase();
  const existing = latestByTicker.get(t);
  if (!existing || String(r.date || "") > String(existing.date || "")) {
    latestByTicker.set(t, { ...r, ticker: t });
  }
}

// Sort by last updated (newest first)
const companies = Array.from(latestByTicker.values()).sort((a, b) => {
  const bd = String(b.date || "");
  const ad = String(a.date || "");
  if (bd !== ad) return bd.localeCompare(ad);
  return String(a.ticker || "").localeCompare(String(b.ticker || ""));
});

// Site-wide last updated stamp
const lastUpdated = (reports || []).reduce((max, r) => {
  const d = String(r?.date || "");
  return d > max ? d : max;
}, "0000-00-00");
---

<BaseLayout title="Owner Scorecard">
  <div class="stickyBar">
    <div class="metaRow">
      <div class="updated">Updated: {lastUpdated}</div>
      <div class="count">{companies.length} issues</div>
    </div>

    <input
      id="q"
      type="search"
      placeholder="Search ticker or name..."
      class="search"
      autocomplete="off"
    />
  </div>

  <ul class="list" id="list">
    {companies.map((c) => (
      <li data-search={`${c.ticker} ${c.name || ""}`.toLowerCase()}>
        <div class="left">
          <span class="ticker">
            <a href={`/c/${c.ticker}`}>{c.ticker}</a>
          </span>
          <span class="name">{c.name}</span>
        </div>
        <span class="date">{c.date}</span>
      </li>
    ))}
  </ul>

  <style>
    .stickyBar {
      position: sticky;
      top: 0;
      z-index: 20;
      background: #fff;
      padding: 10px 0 10px;
      border-bottom: 1px solid #eee;
    }

    .metaRow {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 8px;
    }

    .updated {
      font-size: 12px;
      color: #555;
    }

    .count {
      font-size: 12px;
      color: #555;
    }

    .search {
      width: 100%;
      padding: 10px;
      border: 1px solid #111;
      font-family: inherit;
    }

    .list {
      list-style: none;
      padding-left: 0;
      margin: 14px 0 0;
    }

    li {
      padding: 10px 0;
      display: flex;
      gap: 12px;
      justify-content: space-between;
      border-bottom: 1px solid #f0f0f0;
    }

    .left {
      display: flex;
      gap: 10px;
      min-width: 0;
    }

    .ticker {
      font-weight: 700;
      width: 64px;
      flex: 0 0 auto;
    }

    .name {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }

    .date {
      color: #666;
      font-size: 14px;
      flex: 0 0 auto;
      margin-left: 12px;
    }

    a { color: inherit; }
  </style>

  <script is:inline>
    const q = document.getElementById("q");
    const items = Array.from(document.querySelectorAll('li[data-search]'));

    function refresh() {
      const term = (q.value || "").trim().toLowerCase();
      for (const li of items) {
        li.style.display = !term || li.dataset.search.includes(term) ? "" : "none";
      }
    }

    q?.addEventListener("input", refresh);
  </script>
</BaseLayout>
