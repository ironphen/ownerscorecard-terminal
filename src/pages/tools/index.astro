---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Tools are the "ability to check" half of the publication: each one applies a
// mechanism to a real company, from primary-source filings. Add entries here as
// tools ship. (The interest-coverage checker was folded into the Owner's
// Scorecard once every company carried coverage as a line.)
const tools = [
  {
    href: "/compare",
    title: "Weigh one business against another",
    blurb:
      "Munger's first question is “compared to what?” Put two to four businesses side by side on the record an owner reads — quality, compounding, survival, stewardship, candour — and on what each one's price would have to assume. No score, no ranking; the judgment stays yours.",
  },
];
---

<BaseLayout title="Tools, Owner Scorecard">
  <header class="hero">
    <h1>Tools</h1>
    <p class="lede">
      Instruments, not opinions, each applies a single idea to a real company,
      using figures pulled straight from SEC filings, and shows its work so you can
      check it yourself.
    </p>
  </header>

  {tools.length ? (
    <ul class="list">
      {tools.map((t) => (
        <li>
          <a class="title" href={t.href}>{t.title}</a>
          <p class="blurb">{t.blurb}</p>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">The first standalone instrument is in development. In the meantime, every
    company’s <a href="/">Owner’s Scorecard</a> already runs the core checks.</p>
  )}

  <style>
    .hero h1 { margin: 0 0 6px; }
    .lede { color: var(--ink-dim); margin: 0 0 8px; max-width: 60ch; }
    .list { list-style: none; padding-left: 0; margin: 14px 0 0; }
    li { padding: 14px 0; border-bottom: 1px solid var(--rule); }
    .title { font-family: var(--serif); font-weight: 600; font-size: 19px; }
    .blurb { margin: 6px 0 0; color: var(--ink-dim); }
    .empty { color: var(--muted); margin-top: 16px; }
  </style>
</BaseLayout>
