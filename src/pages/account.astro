---
// The account page — a ledger, not a profile. Three facts: who you are, the companies you
// watch, and the wire arrangement. Server-rendered per user (the one personal page on the
// site), never cached, and it gates nothing — every scorecard stays free with or without it.
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getUser } from "../lib/gate/server.mjs";

const { supabase, user } = await getUser(Astro);
if (!user) {
  return Astro.redirect("/auth/login?next=/account", 303);
}

Astro.response.headers.set("Cache-Control", "private, no-store");

const [{ data: follows }, { data: wirePref }] = await Promise.all([
  supabase.from("follows").select("ticker, created_at").order("ticker"),
  supabase.from("wire_subscriptions").select("enabled, frequency").maybeSingle(),
]);
const list = follows ?? [];
const wireOn = wirePref?.enabled === true;
const wireFreq = wirePref?.frequency === "daily" ? "daily" : "weekly";
---

<BaseLayout title="Your account, Owner Scorecard">
  <section class="acct">
    <div class="head">
      <h1>Your account</h1>
      <button class="signout" id="signout" type="button">Sign out</button>
    </div>
    <p class="who">{user.email}</p>

    <h2 class="secTitle">Companies you follow</h2>
    {list.length ? (
      <ul class="follows">
        {list.map((f) => (
          <li>
            <a class="tkr" href={`/c/${f.ticker}`}>{f.ticker}</a>
            <button class="unfollow" data-ticker={f.ticker} type="button" title="Stop following">remove</button>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">None yet. Open any company and press <em>Follow</em> — its filings then reach you on the wire below.</p>
    )}

    <h2 class="secTitle">The wire, by email</h2>
    <p class="wireNote">
      New filings from the companies you follow — what they disclosed, not what the market did.
      No other mail, ever.
    </p>
    <div class="wireRow">
      <label class="switch">
        <input type="checkbox" id="wireOn" checked={wireOn} />
        <span>Send me the wire</span>
      </label>
      <select id="wireFreq" aria-label="Frequency" disabled={!wireOn}>
        <option value="weekly" selected={wireFreq === "weekly"}>weekly digest</option>
        <option value="daily" selected={wireFreq === "daily"}>each weekday</option>
      </select>
    </div>
    <p class="err" id="err" hidden></p>
  </section>

  <style>
    .acct { max-width: 560px; margin: 32px auto 0; }
    .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
    h1 { margin: 0; }
    .signout { font-family: var(--sans); font-size: 12.5px; letter-spacing: 0.04em; color: var(--muted); background: none; border: 1px solid var(--rule-strong); border-radius: 6px; padding: 5px 12px; cursor: pointer; }
    .signout:hover { color: var(--ink); border-color: var(--ink); }
    .who { color: var(--ink-dim); font-size: 14.5px; margin: 8px 0 28px; }

    .secTitle { border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; margin: 26px 0 10px; }
    .follows { list-style: none; padding: 0; margin: 0; }
    .follows li { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--rule); }
    .tkr { font-family: var(--sans); font-weight: 700; font-variant-numeric: tabular-nums; }
    .unfollow { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.03em; color: var(--muted); background: none; border: 0; cursor: pointer; }
    .unfollow:hover { color: var(--bad); }
    .empty { color: var(--ink-dim); font-size: 14.5px; }

    .wireNote { color: var(--ink-dim); font-size: 14px; line-height: 1.5; margin: 0 0 12px; max-width: 60ch; }
    .wireRow { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .switch { display: inline-flex; align-items: center; gap: 8px; font-family: var(--sans); font-size: 14.5px; cursor: pointer; }
    select { font-family: var(--sans); font-size: 13.5px; padding: 6px 8px; border: 1px solid var(--rule-strong); border-radius: 6px; background: var(--surface); color: var(--ink); }
    select[disabled] { opacity: 0.5; }
    .err { color: var(--bad); font-size: 13.5px; margin: 10px 0 0; }
  </style>

  <script is:inline>
    (function () {
      var err = document.getElementById("err");
      function post(url, body) {
        return fetch(url, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) })
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
          .then(function (res) { if (!res.ok) throw new Error(res.j && res.j.error || "try again"); return res.j; });
      }
      function fail(ex) { err.textContent = ex.message; err.hidden = false; }

      document.getElementById("signout").addEventListener("click", function () {
        post("/api/auth/logout", {}).then(function () { location.href = "/"; }).catch(fail);
      });

      document.querySelectorAll(".unfollow").forEach(function (b) {
        b.addEventListener("click", function () {
          post("/api/follow", { ticker: b.dataset.ticker }).then(function () {
            try { localStorage.removeItem("osc-follow-" + b.dataset.ticker); } catch (e) {}
            b.closest("li").remove();
          }).catch(fail);
        });
      });

      var on = document.getElementById("wireOn");
      var freq = document.getElementById("wireFreq");
      function save() {
        err.hidden = true;
        freq.disabled = !on.checked;
        post("/api/wire-pref", { enabled: on.checked, frequency: freq.value }).catch(fail);
      }
      on.addEventListener("change", save);
      freq.addEventListener("change", save);
    })();
  </script>
</BaseLayout>
