---
import BaseLayout from "../../layouts/BaseLayout.astro";
import jp from "../../data/fundamentals.jp.json";
import TenYear from "../../components/TenYear.astro";
import NormalizedEarnings from "../../components/NormalizedEarnings.astro";
import OwnerEarningsBridge from "../../components/OwnerEarningsBridge.astro";
import Scorecard from "../../components/Scorecard.astro";
import Capital from "../../components/Capital.astro";
import Inversion from "../../components/Inversion.astro";
import Valuation from "../../components/Valuation.astro";
import ActHeader from "../../components/ActHeader.astro";

// The Japanese pool, a separate route and a separate dataset from the US catalog. These
// pages are quantitative by design: the figures are read straight from each company's
// EDINET annual securities report, but the Japanese-language narrative (the business
// description, the risk factors, what changed) is not parsed, so the page says so plainly
// rather than guess. Everything quantitative, the record, normalized earnings, the
// scorecard, capital allocation, the inversion checks and the reverse-DCF, is the same
// machinery the US pages use, run in yen, and lights up now that the deeper EDINET capex
// history gives the Japanese names a full owner-earnings record.
export function getStaticPaths() {
  return (jp.companies || []).map((c) => ({ params: { ticker: String(c.ticker) } }));
}

const ticker = String(Astro.params.ticker || "");
const fund = (jp.companies || []).find((c) => String(c.ticker) === ticker) || null;
const name = fund?.name || "";

const SECTOR_LABEL = {
  assetLight: "Asset-light compounder",
  consumer: "Consumer & brand",
  capital: "Capital-intensive",
  retail: "Trading & distribution",
  general: "Diversified",
};
const sectorLabel = fund ? SECTOR_LABEL[fund.sector] || "Diversified" : null;
---

<BaseLayout title={`${ticker} ${name}, Owner Scorecard (Japan)`}>
  <p class="back"><a href="/japan">← Japan catalog</a></p>

  {fund ? (
    <>
      <header class="hero" id="top">
        <h1>{ticker} · {name}</h1>
        <div class="ident">
          <span class="ichip">{fund.industry}</span>
          <span class="model">{sectorLabel}</span>
          <span class="jp">Japan · ¥</span>
          {fund.accountingStandard ? <span class="std">{fund.accountingStandard}</span> : null}
        </div>
        <div class="meta">Latest filing: FY{fund.fy} annual securities report (有価証券報告書) · EDINET</div>
      </header>

      <section class="band note">
        <p>
          This is a <b>quantitative</b> scorecard. The numbers below are read directly from
          {name}&rsquo;s EDINET filing, in yen. The Japanese-language narrative, what the
          business does, its risks, what changed this year, is not machine-read here, so we
          do not paraphrase it. For the words, go to the filing itself; for the numbers, read on.
          <a href={fund.sourceUrl} target="_blank" rel="noopener"> Find it on EDINET (code {ticker}) →</a>
        </p>
      </section>

      <section class="actGroup">
        <ActHeader n="I" title="The record" lede="What the business has done across the cycle, read straight from the EDINET filing: the multi-year record and, where the history allows, what it earns at mid-cycle." />
        <div id="sec-record" class="sec"><TenYear company={fund} /></div>
        <div id="sec-power" class="sec"><NormalizedEarnings company={fund} /></div>
        <div id="sec-bridge" class="sec"><OwnerEarningsBridge company={fund} /></div>
      </section>

      <section class="actGroup">
        <ActHeader n="II" title="Quality &amp; stewardship" lede="Is it a good business, will it survive, and is it run for the owners? The same checks the US pages run, in yen." />
        <div id="sec-scorecard" class="sec"><Scorecard company={fund} /></div>
        <div id="sec-capital" class="sec"><Capital company={fund} /></div>
        <div id="sec-inversion" class="sec"><Inversion company={fund} /></div>
      </section>

      <section class="actGroup">
        <ActHeader n="III" title="The price" lede="What you would be paying, and what a price would have to assume to make sense, set against the record above." />
        <div id="sec-price" class="sec"><Valuation company={fund} /></div>
      </section>

      <p class="foot">
        Figures from EDINET, the Financial Services Agency&rsquo;s disclosure system, the
        primary source, free, the same kind of filing the US pages draw from EDGAR. A separate
        pool: these names never pass through the US industry classifier. Present, never pronounce.
      </p>
    </>
  ) : (
    <p>Nothing here for {ticker} yet.</p>
  )}

  <style>
    .back { margin: 0 0 10px; }
    .hero h1 { margin: 0; }
    .ident { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; margin: 8px 0 0; }
    .ichip { font-family: var(--sans); font-size: 11.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink); border: 1px solid var(--rule-strong); padding: 2px 8px; }
    .model { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.03em; color: var(--muted); }
    .jp { font-family: var(--sans); font-size: 10.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); padding: 1px 7px; border-radius: 2px; }
    .std { font-family: var(--sans); font-size: 10px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--rule); padding: 1px 6px; }
    .meta { color: var(--ink-dim); font-size: 13px; margin-top: 8px; }

    .note { margin: 18px 0 0; background: var(--accent-tint); border-left: 2px solid var(--accent); padding: 12px 16px; }
    .note p { font-size: 14px; line-height: 1.6; color: var(--ink-soft); margin: 0; max-width: 76ch; }
    .note b { color: var(--ink); }
    .note a { color: var(--accent); white-space: nowrap; }

    .sec { scroll-margin-top: 16px; }
    .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 20px 0 0; line-height: 1.5; max-width: 76ch; border-top: 1px solid var(--rule); padding-top: 12px; }
  </style>
</BaseLayout>
