---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fundamentals from "../../data/fundamentals.json";
import Scorecard from "../../components/Scorecard.astro";
import Portrait from "../../components/Portrait.astro";
import TenYear from "../../components/TenYear.astro";
import Peers from "../../components/Peers.astro";
import BusinessRead from "../../components/BusinessRead.astro";
import Segments from "../../components/Segments.astro";
import OwnersRead from "../../components/OwnersRead.astro";
import Capital from "../../components/Capital.astro";
import Comp from "../../components/Comp.astro";
import Graham from "../../components/Graham.astro";
import Valuation from "../../components/Valuation.astro";
import Language from "../../components/Language.astro";
import language from "../../data/language.json";
import { classify } from "../../lib/archetype.mjs";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  const tickers = new Set([
    ...(fundamentals.companies || []).map((c) => String(c.ticker || "").toUpperCase()),
    ...articles.flatMap((a) => a.data.tickers.map((t) => t.toUpperCase())),
  ]);
  tickers.delete("");
  return Array.from(tickers).map((ticker) => ({ params: { ticker } }));
}

const ticker = String(Astro.params.ticker || "").toUpperCase();

const fund =
  (fundamentals.companies || []).find((c) => String(c.ticker || "").toUpperCase() === ticker) || null;

const related = (
  await getCollection("articles", ({ data }) =>
    (import.meta.env.PROD ? !data.draft : true) &&
    data.tickers.some((t) => t.toUpperCase() === ticker)
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const name = fund?.name || "";
const cls = fund ? classify(fund) : null;
const bizLine = language?.companies?.[ticker]?.business || null;

const fmtDate = (d) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<BaseLayout title={`${ticker}, Owner Scorecard`}>
  <p class="back"><a href="/">← All companies</a></p>

  <header class="hero" id="top">
    <h1>{ticker}{name ? `, ${name}` : ""}</h1>
    {cls ? (
      <div class="ident">
        <span class="ichip">{cls.industry.label}</span>
        <span class="model">{cls.sector.adj}</span>
        {cls.overlays.map((o) => <span class="ov">{o.label}</span>)}
      </div>
    ) : null}
    {bizLine ? <p class="lede">{bizLine}</p> : null}
    {fund ? <div class="meta">Latest filing: FY{fund.fy} {fund.form}</div> : null}
  </header>

  {fund ? (
    <div class="cbar">
      <a class="cbar-id" href="#top">{ticker}<span class="cbar-nm">{name ? ` · ${name}` : ""}</span></a>
      <nav class="secnav" aria-label="Sections">
        <a href="#sec-snapshot">Snapshot</a>
        <a href="#sec-business">Business</a>
        <a href="#sec-mix">Mix</a>
        <a href="#sec-record">Record</a>
        <a href="#sec-scorecard">Scorecard</a>
        <a href="#sec-capital">Capital</a>
        <a href="#sec-pay">Pay</a>
        <a href="#sec-graham">Graham</a>
        <a href="#sec-price">Price</a>
        <a href="#sec-changes">Changes</a>
        <a href="#sec-peers">Peers</a>
        <a href="#sec-writing">Writing</a>
      </nav>
    </div>
  ) : null}

  {fund ? <div id="sec-snapshot" class="sec"><Portrait company={fund} /></div> : null}
  {fund ? <div id="sec-business" class="sec"><BusinessRead company={fund} /></div> : null}
  {fund ? <div id="sec-mix" class="sec"><Segments company={fund} /></div> : null}
  {fund ? <div id="sec-record" class="sec"><TenYear company={fund} /></div> : null}
  {fund ? <div id="sec-scorecard" class="sec"><Scorecard company={fund} sample={fundamentals.sample} /></div> : null}
  {fund ? <div id="sec-capital" class="sec"><Capital company={fund} /></div> : null}
  {fund ? <div id="sec-pay" class="sec"><Comp company={fund} /></div> : null}
  {fund ? <div id="sec-graham" class="sec"><Graham company={fund} /></div> : null}
  {fund ? <div id="sec-price" class="sec"><Valuation company={fund} /></div> : null}
  {fund ? (
    <div id="sec-changes" class="sec">
      <OwnersRead company={fund} />
      <Language company={fund} />
    </div>
  ) : null}
  {fund ? <div id="sec-peers" class="sec"><Peers company={fund} /></div> : null}

  {related.length ? (
    <div id="sec-writing" class="sec">
      <h2>Writing</h2>
      <ul class="history">
        {related.map((a) => (
          <li>
            <span class="hDate">{fmtDate(a.data.date)}</span>
            <span class="hLinks"><a href={`/articles/${a.id}`}>{a.data.title}</a></span>
          </li>
        ))}
      </ul>
    </div>
  ) : null}

  {!fund && !related.length ? <p>Nothing here for {ticker} yet.</p> : null}

  <style>
    .back { margin: 0 0 10px; }
    .hero h1 { margin: 0; }
    .ident { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; margin: 8px 0 0; }
    .ichip { font-family: var(--sans); font-size: 11.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink); border: 1px solid var(--rule-strong); padding: 2px 8px; }
    .model { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.03em; color: var(--muted); }
    .ident .ov { font-family: var(--sans); font-size: 10px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--warn); border: 1px solid var(--warn); padding: 1px 6px; }
    .lede { font-family: var(--serif); font-size: clamp(16px, 2.4vw, 19px); line-height: 1.5; color: #2c2f36; margin: 12px 0 0; max-width: 70ch; }
    .meta { color: #555; font-size: 13px; margin-top: 8px; }

    /* Sticky company bar, ticker always in view, plus section jump-nav. */
    .cbar {
      position: sticky; top: 0; z-index: 40; background: var(--paper);
      display: flex; align-items: center; gap: 12px;
      border-bottom: 1px solid var(--rule-strong); padding: 8px 0; margin: 12px 0 0;
    }
    .cbar-id { font-family: var(--sans); font-weight: 800; font-size: 14px; color: var(--ink); flex: 0 0 auto; }
    .cbar-id:hover { color: var(--accent); text-decoration: none; }
    .cbar-nm { font-weight: 500; color: var(--muted); font-size: 12.5px; }
    .secnav { display: flex; gap: 2px; overflow-x: auto; flex: 1 1 auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
    .secnav::-webkit-scrollbar { display: none; }
    .secnav a { flex: 0 0 auto; font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); padding: 4px 9px; white-space: nowrap; border-bottom: 2px solid transparent; }
    .secnav a:hover { color: var(--ink); text-decoration: none; }
    .secnav a.active { color: var(--ink); border-bottom-color: var(--accent); }
    .sec { scroll-margin-top: 52px; }

    h2 { border-bottom: 1px solid #ddd; padding-bottom: 4px; margin-top: 24px; }
    .history { list-style: none; padding-left: 0; margin: 0; }
    .history li { padding: 10px 0; display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid #f0f0f0; }
    .hDate { color: #666; flex: 0 0 auto; }
    .hLinks { flex: 1 1 auto; text-align: right; }
    @media (max-width: 560px) { .cbar-nm { display: none; } }
  </style>

  <script is:inline>
    (function () {
      const bar = document.querySelector(".cbar");
      if (!bar) return;
      const nav = bar.querySelector(".secnav");
      // Drop nav links whose section rendered nothing (e.g. a company with no proxy or filing data).
      nav.querySelectorAll("a").forEach((a) => {
        const el = document.getElementById(a.getAttribute("href").slice(1));
        if (!el || el.children.length === 0) a.remove();
      });
      const links = Array.from(nav.querySelectorAll("a"));
      const byId = {}; links.forEach((a) => (byId[a.getAttribute("href").slice(1)] = a));
      const targets = links.map((a) => document.getElementById(a.getAttribute("href").slice(1))).filter(Boolean);
      if (!("IntersectionObserver" in window) || !targets.length) return;
      let active = null;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const a = byId[e.target.id];
          if (!a || a === active) return;
          if (active) active.classList.remove("active");
          a.classList.add("active"); active = a;
          const l = a.offsetLeft, r = l + a.offsetWidth;
          if (l < nav.scrollLeft) nav.scrollLeft = l - 12;
          else if (r > nav.scrollLeft + nav.clientWidth) nav.scrollLeft = r - nav.clientWidth + 12;
        });
      }, { rootMargin: "-15% 0px -75% 0px", threshold: 0 });
      targets.forEach((t) => obs.observe(t));
    })();
  </script>
</BaseLayout>
