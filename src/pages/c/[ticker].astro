---
import BaseLayout from "../../layouts/BaseLayout.astro";
import reports from "../../data/reports.json";
---

import reports from "../../data/reports.json";

export async function getStaticPaths() {
  const tickers = Array.from(new Set(reports.map(r => r.ticker.toUpperCase())));
  return tickers.map(ticker => ({ params: { ticker } }));
}

const { ticker } = Astro.params;

const all = reports
  .filter(r => r.ticker.toUpperCase() === ticker)
  .sort((a, b) => b.date.localeCompare(a.date));

const latest = all[0];
---

<BaseLayout title={`${ticker} — Owner Scorecard`}>
  <p><a href="/">← Directory</a></p>
  <!-- keep the rest of your existing company page content -->
</BaseLayout>
