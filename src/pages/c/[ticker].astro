---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fundamentals from "../../data/fundamentals.json";
import Scorecard from "../../components/Scorecard.astro";
import Portrait from "../../components/Portrait.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  const tickers = new Set([
    ...(fundamentals.companies || []).map((c) => String(c.ticker || "").toUpperCase()),
    ...articles.flatMap((a) => a.data.tickers.map((t) => t.toUpperCase())),
  ]);
  tickers.delete("");
  return Array.from(tickers).map((ticker) => ({ params: { ticker } }));
}

const ticker = String(Astro.params.ticker || "").toUpperCase();

const fund =
  (fundamentals.companies || []).find((c) => String(c.ticker || "").toUpperCase() === ticker) || null;

const related = (
  await getCollection("articles", ({ data }) =>
    (import.meta.env.PROD ? !data.draft : true) &&
    data.tickers.some((t) => t.toUpperCase() === ticker)
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const name = fund?.name || "";

const fmtDate = (d) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<BaseLayout title={`${ticker} — Owner Scorecard`}>
  <p class="back"><a href="/">← All companies</a></p>

  <header class="hero">
    <h1>{ticker}{name ? ` — ${name}` : ""}</h1>
    {fund ? <div class="meta">Latest filing: FY{fund.fy} {fund.form}</div> : null}
  </header>

  {fund ? <Portrait company={fund} /> : null}

  {fund ? <Scorecard company={fund} sample={fundamentals.sample} /> : null}

  {related.length ? (
    <>
      <h2>Writing</h2>
      <ul class="history">
        {related.map((a) => (
          <li>
            <span class="hDate">{fmtDate(a.data.date)}</span>
            <span class="hLinks"><a href={`/articles/${a.id}`}>{a.data.title}</a></span>
          </li>
        ))}
      </ul>
    </>
  ) : null}

  {!fund && !related.length ? <p>Nothing here for {ticker} yet.</p> : null}

  <style>
    .back { margin: 0 0 10px; }
    .hero h1 { margin: 0; }
    .meta { color: #555; font-size: 14px; margin-top: 4px; }
    h2 { border-bottom: 1px solid #ddd; padding-bottom: 4px; margin-top: 24px; }
    .history { list-style: none; padding-left: 0; margin: 0; }
    .history li { padding: 10px 0; display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid #f0f0f0; }
    .hDate { color: #666; flex: 0 0 auto; }
    .hLinks { flex: 1 1 auto; text-align: right; }
  </style>
</BaseLayout>
