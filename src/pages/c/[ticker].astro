---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fundamentals from "../../data/fundamentals.json";
import Scorecard from "../../components/Scorecard.astro";
import Portrait from "../../components/Portrait.astro";
import TenYear from "../../components/TenYear.astro";
import CurrentPosition from "../../components/CurrentPosition.astro";
import Peers from "../../components/Peers.astro";
import BusinessRead from "../../components/BusinessRead.astro";
import Segments from "../../components/Segments.astro";
import OwnersRead from "../../components/OwnersRead.astro";
import Capital from "../../components/Capital.astro";
import Inversion from "../../components/Inversion.astro";
import ActHeader from "../../components/ActHeader.astro";
import Comp from "../../components/Comp.astro";
import Valuation from "../../components/Valuation.astro";
import CompareLink from "../../components/CompareLink.astro";
import OwnerEarningsBridge from "../../components/OwnerEarningsBridge.astro";
import DebtMaturity from "../../components/DebtMaturity.astro";
import LeaseObligations from "../../components/LeaseObligations.astro";
import Acquisitions from "../../components/Acquisitions.astro";
import language from "../../data/language.json";
import segmentsData from "../../data/segments.json";
import { classify } from "../../lib/archetype.mjs";
import { computeLenses, LENS_BY_KEY } from "../../lib/lenses.mjs";
import { businessPhrase, weakLede, pickNote } from "../../lib/business.mjs";
import { compositionSentence } from "../../lib/segments.mjs";
import { selectPeers } from "../../lib/peers.mjs";
import notes from "../../data/notes.json";
import adrFundamentals from "../../data/fundamentals.adr.json";
import { getCollection } from "astro:content";

// ADRs (foreign 20-F filers) carry US-style tickers and the same record shape, so they get the same
// /c/[ticker] page as a US company; only the data source and currency differ. The two pools are
// merged for path generation (inline below, since getStaticPaths runs isolated from the frontmatter
// body) and for the lookup.
export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  const companies = [...(fundamentals.companies || []), ...(adrFundamentals.companies || [])];
  const tickers = new Set([
    ...companies.map((c) => String(c.ticker || "").toUpperCase()),
    ...articles.flatMap((a) => a.data.tickers.map((t) => t.toUpperCase())),
  ]);
  tickers.delete("");
  return Array.from(tickers).map((ticker) => ({ params: { ticker } }));
}

const allCompanies = [...(fundamentals.companies || []), ...(adrFundamentals.companies || [])];

const ticker = String(Astro.params.ticker || "").toUpperCase();

const fund =
  allCompanies.find((c) => String(c.ticker || "").toUpperCase() === ticker) || null;

// Peers, found once and shared: both the peer table and the scorecard's peer context read the same set,
// and the universe scan runs a single time per page rather than once per component.
const peerResult = fund ? selectPeers(fund, fundamentals.companies || []) : { peers: [], basis: "model" };

const related = (
  await getCollection("articles", ({ data }) =>
    (import.meta.env.PROD ? !data.draft : true) &&
    data.tickers.some((t) => t.toUpperCase() === ticker)
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const name = fund?.name || "";
const cls = fund ? classify(fund) : null;
const isFin = !!cls && ["financial", "reit"].includes(cls.sector.key);
// Lede priority, so the hero always opens with the most concrete accurate thing: a reviewed,
// model-drafted note (the names a human has written up, governed by docs/qualitative-doctrine.md)
// first; else the filing's own description when it actually describes the business; else the
// company's own revenue mix (so a giant that opens on a mission statement — Amazon, Apple — still
// says what it does, from its reportable segments); else the computed one-line industry
// characterization. BusinessRead recomputes the same chain to show the complement, never a repeat.
const note = fund ? pickNote(notes, ticker) : null;
const rawBiz = language?.companies?.[ticker]?.business || null;
const seg = fund ? segmentsData?.companies?.[ticker] : null;
const bizLine = fund
  ? (note?.whatItIs || (rawBiz && !weakLede(rawBiz) ? rawBiz : (compositionSentence(seg) || businessPhrase(fund))))
  : rawBiz;
// The company's own "in brief": up to two more verbatim sentences naming what it sells, kept
// distinct from the lede by the detector (businessBrief). Sits under the lede so the whole opening
// reads in the company's own voice. Empty, and so absent, until the filings re-fetch populates it.
const brief = fund ? (language?.companies?.[ticker]?.brief || []).filter((s) => s && s !== bizLine) : [];

const fmtDate = (d) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });

// The archetype-trail: which of the discovery archetypes this company fits, so discovery and evaluation
// are one loop. Same memoized computation the Archetypes pages run, so the trail can never disagree with them.
const lensTrail = fund ? (computeLenses(allCompanies, language.companies).byTicker[ticker] || []) : [];
---

<BaseLayout title={`${ticker}, Owner Scorecard`}>
  <p class="back"><a href="/">← All companies</a></p>

  <header class="hero" id="top">
    <h1>{ticker}{name ? `, ${name}` : ""}</h1>
    {cls ? (
      <div class="ident">
        <span class="ichip">{cls.industry.label}</span>
        <span class="model">{cls.sector.adj}</span>
        {cls.overlays.map((o) => <span class="ov">{o.label}</span>)}
      </div>
    ) : null}
    {bizLine ? <p class="lede">{bizLine}</p> : null}
    {brief.length ? <div class="leadMore">{brief.map((s) => <p>{s}</p>)}</div> : null}
    {fund ? <div class="meta">Latest filing: FY{fund.fy} {fund.form}</div> : null}
    {lensTrail.length ? (
      <div class="lensTrail">
        <span class="ltLabel">Fits <a href="/archetypes">archetypes</a></span>
        {lensTrail.map((k) => (
          <a class={LENS_BY_KEY[k].positive ? "ltChip" : "ltChip ltCaution"} href={`/archetypes/${k}`}>{LENS_BY_KEY[k].title}</a>
        ))}
      </div>
    ) : null}
  </header>

  {fund ? (
    <div class="cbar">
      <a class="cbar-id" href="#top">{ticker}<span class="cbar-nm">{name ? ` · ${name}` : ""}</span></a>
      <nav class="secnav" aria-label="Sections">
        <a href="#act-what">The business</a>
        <a href="#act-record">The record</a>
        <a href="#act-quality">Quality</a>
        <a href="#act-price">Price</a>
      </nav>
    </div>
  ) : null}

  {fund ? (
    <section id="act-what" class="actGroup">
      <ActHeader n="I" title="The business" lede="What it sells, where the money comes from, the kind of company it is." />
      <div id="sec-snapshot" class="sec"><Portrait company={fund} /></div>
      <div id="sec-business" class="sec"><BusinessRead company={fund} /></div>
      <div id="sec-mix" class="sec"><Segments company={fund} /></div>
    </section>
  ) : null}

  {fund ? (
    <section id="act-record" class="actGroup">
      <ActHeader n="II" title="The record" lede="Ten years of arithmetic, read across the cycle." />
      <div id="sec-record" class="sec"><TenYear company={fund} /></div>
      {!isFin ? <div id="sec-bridge" class="sec"><OwnerEarningsBridge company={fund} /></div> : null}
    </section>
  ) : null}

  {fund ? (
    <section id="act-quality" class="actGroup">
      <ActHeader n="III" title="Quality &amp; stewardship" lede="Returns, the balance sheet, capital allocation, and pay." />
      <div id="sec-scorecard" class="sec"><Scorecard company={fund} sample={fundamentals.sample} peers={peerResult.peers} /></div>
      <div id="sec-current" class="sec"><CurrentPosition company={fund} /></div>
      <div id="sec-debt" class="sec"><DebtMaturity company={fund} /></div>
      <div id="sec-leases" class="sec"><LeaseObligations company={fund} /></div>
      {!isFin ? <div id="sec-capital" class="sec"><Capital company={fund} /></div> : null}
      <div id="sec-acq" class="sec"><Acquisitions company={fund} /></div>
      <div id="sec-pay" class="sec"><Comp company={fund} /></div>
      {!isFin ? <div id="sec-inversion" class="sec"><Inversion company={fund} /></div> : null}
      <div id="sec-changes" class="sec"><OwnersRead company={fund} /></div>
      <div id="sec-peers" class="sec"><Peers company={fund} peers={peerResult.peers} basis={peerResult.basis} subsector={peerResult.subsector} /></div>
    </section>
  ) : null}

  {fund ? (
    <section id="act-price" class="actGroup">
      <ActHeader n="IV" title="The price" lede="What a price has to assume." />
      <div id="sec-price" class="sec"><Valuation company={fund} /><CompareLink company={fund} /></div>
    </section>
  ) : null}

  {fund && related.length ? (
    <section id="sec-writing" class="sec">
      <h2>Writing</h2>
      <ul class="history">
        {related.map((a) => (
          <li>
            <span class="hDate">{fmtDate(a.data.date)}</span>
            <span class="hLinks"><a href={`/articles/${a.id}`}>{a.data.title}</a></span>
          </li>
        ))}
      </ul>
    </section>
  ) : null}

  {!fund && !related.length ? <p>Nothing here for {ticker} yet.</p> : null}

  <style>
    .back { margin: 0 0 10px; }
    .hero h1 { margin: 0; }
    .ident { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; margin: 8px 0 0; }
    .ichip { font-family: var(--sans); font-size: 11.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink); border: 1px solid var(--rule-strong); padding: 2px 8px; }
    .model { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.03em; color: var(--muted); }
    .ident .ov { font-family: var(--sans); font-size: 10px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--warn); border: 1px solid var(--warn); padding: 1px 6px; }
    .lede { font-family: var(--serif); font-size: clamp(16px, 2.4vw, 19px); line-height: 1.5; color: var(--ink-soft); margin: 12px 0 0; max-width: 70ch; }
    /* The "in brief" continuation: the company's own follow-on sentences, set quieter than the lede
       so the one-line characterization still leads. */
    .leadMore { margin: 8px 0 0; max-width: 72ch; }
    .leadMore p { font-family: var(--serif); font-size: 14.5px; line-height: 1.55; color: var(--muted); margin: 6px 0 0; }
    .meta { color: var(--ink-dim); font-size: 13px; margin-top: 8px; }
    .lensTrail { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
    .ltLabel { font-family: var(--sans); font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
    .ltLabel a { color: var(--accent); }
    .ltChip { font-family: var(--sans); font-size: 11.5px; color: var(--ink-soft); border: 1px solid var(--rule-strong); padding: 2px 8px; text-decoration: none; }
    .ltChip:hover { border-color: var(--accent); color: var(--accent); }
    .ltCaution { color: var(--warn, #b4690e); border-color: var(--warn, #b4690e); }
    .ltCaution:hover { color: var(--warn, #b4690e); filter: brightness(1.12); }


    /* Sticky company bar, ticker always in view, plus section jump-nav. */
    .cbar {
      position: sticky; top: 0; z-index: 40; background: var(--paper);
      display: flex; align-items: center; gap: 12px;
      border-bottom: 1px solid var(--rule-strong); padding: 8px 0; margin: 12px 0 0;
    }
    .cbar-id { font-family: var(--sans); font-weight: 800; font-size: 14px; color: var(--ink); flex: 0 0 auto; }
    .cbar-id:hover { color: var(--accent); text-decoration: none; }
    .cbar-nm { font-weight: 500; color: var(--muted); font-size: 12.5px; }
    .secnav { display: flex; gap: 2px; overflow-x: auto; flex: 1 1 auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
    .secnav::-webkit-scrollbar { display: none; }
    .secnav a { flex: 0 0 auto; font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); padding: 4px 9px; white-space: nowrap; border-bottom: 2px solid transparent; }
    .secnav a:hover { color: var(--ink); text-decoration: none; }
    .secnav a.active { color: var(--ink); border-bottom-color: var(--accent); }
    .sec { scroll-margin-top: 52px; }
    .actGroup { scroll-margin-top: 46px; }
    /* The first act follows the sticky bar directly, so it needs no big top gap; later acts
       keep the divider the component draws. */
    .actGroup:first-of-type :global(.actHead) { margin-top: 14px; }

    h2 { border-bottom: 1px solid var(--rule); padding-bottom: 4px; margin-top: 24px; }
    .history { list-style: none; padding-left: 0; margin: 0; }
    .history li { padding: 10px 0; display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--rule); }
    .hDate { color: var(--muted); flex: 0 0 auto; }
    .hLinks { flex: 1 1 auto; text-align: right; }
    @media (max-width: 560px) { .cbar-nm { display: none; } }
  </style>

  <script is:inline>
    (function () {
      const bar = document.querySelector(".cbar");
      if (!bar) return;
      const nav = bar.querySelector(".secnav");
      // Drop nav links whose section rendered nothing (e.g. a company with no proxy or filing data).
      nav.querySelectorAll("a").forEach((a) => {
        const el = document.getElementById(a.getAttribute("href").slice(1));
        if (!el || el.children.length === 0) a.remove();
      });
      const links = Array.from(nav.querySelectorAll("a"));
      const byId = {}; links.forEach((a) => (byId[a.getAttribute("href").slice(1)] = a));
      const targets = links.map((a) => document.getElementById(a.getAttribute("href").slice(1))).filter(Boolean);
      if (!("IntersectionObserver" in window) || !targets.length) return;
      let active = null;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const a = byId[e.target.id];
          if (!a || a === active) return;
          if (active) active.classList.remove("active");
          a.classList.add("active"); active = a;
          const l = a.offsetLeft, r = l + a.offsetWidth;
          if (l < nav.scrollLeft) nav.scrollLeft = l - 12;
          else if (r > nav.scrollLeft + nav.clientWidth) nav.scrollLeft = r - nav.clientWidth + 12;
        });
      }, { rootMargin: "-15% 0px -75% 0px", threshold: 0 });
      targets.forEach((t) => obs.observe(t));
    })();
  </script>
</BaseLayout>
