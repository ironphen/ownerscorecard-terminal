---
// The business in brief: a high-level, qualitative read of what the company is and
// what moves its needle, assembled entirely from figures the pipeline already
// computes. No model writes a word here, every line is arithmetic that also appears
// elsewhere on the page, and the company's own account of the business is one click
// away in the 10-K. This is the lens Graham and Buffett would bring before any ratio.
import language from "../data/language.json";
import segmentsData from "../data/segments.json";
import { classify } from "../lib/archetype.mjs";
import { roicValue, ownerEarningsMargin, cashPosition, coverage, cashConversionCycle } from "../lib/fundamentals.mjs";
import { capitalHistory } from "../lib/capital.mjs";

const { company } = Astro.props;
const cls = classify(company);
const cur = company.ttm?.lines || company.lines || {};
const L = language?.companies?.[company.ticker] || null;
const sourceUrl = L?.sourceUrl || null;
const bizLine = L?.business || null; // the company's own one-sentence account, verbatim from Item 1

const pc = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(dp)}%`);
const median = (xs) => { const s = [...xs].sort((a, b) => a - b); return s.length ? s[Math.floor((s.length - 1) / 2)] : null; };

// What moves the needle, one lever per business model. Written once and reused, so
// it teaches the lens rather than describing this one company; honest because it is
// tied to the economic shape the classifier already read from the filings.
const LEVER = {
  assetLight: "Engagement and pricing power, not factories. What decides it: whether the gross margin holds as the business scales, how much of the profit is paid out to employees as stock, and whether revenue keeps compounding.",
  consumer: "Volume against price, and shelf position. What decides it: whether it can raise prices without losing the customer, and whether the brand still commands its margin.",
  capital: "How hard the assets work, and what the inputs cost. What decides it: utilization, how much of the capex merely keeps the assets running, and what a downturn does to a heavy fixed-cost base.",
  retail: "Sales per store and how fast inventory moves. What decides it: same-store sales, inventory turns, and whether thin margins survive a price war.",
  financial: "Net interest margin, loan losses, and book value. A lender is read on the quality of its balance sheet, not on an earnings multiple.",
  reit: "Occupancy, rents, and the cost of debt. Read on funds from operations and net asset value, because GAAP depreciation distorts the earnings.",
  general: "Where the revenue actually comes from, and whether the margin is earned or bought. The segment detail in the 10-K is where this one is settled.",
};
const lever = LEVER[cls.sector.key] || LEVER.general;

// Segment reality check: when the profit engine is not the biggest seller, say so,
// so an archetype label (Amazon read as "retail") does not mislead about the needle.
const cleanSeg = (s) => String(s || "").replace(/\s+Segments?$/i, "").replace(/ And /g, " and ").trim();
let leverExtra = "";
const seg = segmentsData?.companies?.[company.ticker];
if (seg?.bySegment?.hasOperatingIncome) {
  const items = seg.bySegment.items;
  const oiSum = items.filter((i) => (i.operatingIncome ?? 0) > 0).reduce((a, b) => a + b.operatingIncome, 0);
  const topRev = [...items].sort((a, b) => b.revenue - a.revenue)[0];
  const topOI = [...items].sort((a, b) => (b.operatingIncome ?? 0) - (a.operatingIncome ?? 0))[0];
  if (oiSum > 0 && topRev && topOI && topOI.label !== topRev.label)
    leverExtra = ` In practice most of the profit now comes from ${cleanSeg(topOI.label)}, even though ${cleanSeg(topRev.label)} is the bigger seller, so that is the part to watch (see the mix below).`;
}

// What it is, qualitatively: lead with what the company actually sells, drawn from
// the product or reportable-segment mix, then the economic shape from the classifier.
// This connects the segment data into a description rather than just a label.
const ucfirst = (s) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
const mix = seg?.byProduct || seg?.bySegment || null;
const mixKind = seg?.byProduct ? "line" : "segment";
let composition = "";
if (mix && seg.revenueTotal) {
  const items = [...mix.items].sort((a, b) => b.revenue - a.revenue);
  const sh = (it) => Math.round((100 * it.revenue) / seg.revenueTotal);
  const fmtItem = (it) => `${cleanSeg(it.label)} (${sh(it)}%)`;
  const joinList = (arr) =>
    arr.length === 1 ? fmtItem(arr[0])
      : arr.length === 2 ? `${fmtItem(arr[0])} and ${fmtItem(arr[1])}`
        : `${arr.slice(0, -1).map(fmtItem).join(", ")} and ${fmtItem(arr[arr.length - 1])}`;
  composition = items.length <= 3
    ? `Revenue is ${joinList(items)}.`
    : `Revenue is led by ${fmtItem(items[0])} and ${fmtItem(items[1])}, with ${items.length - 2} more ${mixKind}s behind.`;
}
const whatItIs = composition ? `${composition} ${ucfirst(cls.sector.reason)}.` : `${ucfirst(cls.sector.reason)}.`;

// Is it a good business? Read return on capital across the whole record, but treat
// the ratio with the skepticism modern accounting demands: buybacks and expensed
// R&D and brands shrink invested capital and inflate ROIC, so flag that, lean on the
// harder-to-game cash measure (owner earnings), and hand the verdict to the filing.
const H = (company.history || []).filter((h) => h?.lines?.revenue != null);
const roicSeries = H.map((h) => roicValue(h.lines)).filter((v) => v != null);
const roicMed = median(roicSeries);
const roicAbove = roicSeries.filter((v) => v >= 0.15).length;

// Is the ROIC figure trustworthy, or mechanically inflated by a small capital base?
const annual = company.lines || {};
const invested = annual.totalDebt != null && annual.stockholdersEquity != null
  ? annual.totalDebt + annual.stockholdersEquity - (annual.cashAndEquivalents || 0) : null;
const investedIntensity = invested != null && annual.revenue ? invested / annual.revenue : null;
const roicInflated = cls.sector.key === "assetLight"
  || (investedIntensity != null && investedIntensity < 0.3)
  || (roicMed != null && roicMed > 0.3);

// Corroborants we now have the data for: owner-earnings durability, and a negative
// cash-conversion cycle (others fund the business), which no return ratio reveals.
const oeSeries = H.map((h) => ownerEarningsMargin(h.lines)).filter((v) => v != null);
const oeMed = median(oeSeries);
const oeStable = oeSeries.length >= 3 && oeSeries.filter((v) => v > 0).length >= oeSeries.length - 1;
const ccc = cashConversionCycle(company);
const negativeCCC = ccc && /Negative/.test(ccc.label);
const cyclical = (cls.overlays || []).some((o) => o.key === "cyclical");

let moat = null;
if (roicSeries.length >= 3 && roicMed != null) {
  const n = roicSeries.length;
  const band = roicMed >= 0.2 ? "high" : roicMed >= 0.13 ? "mid" : roicMed >= 0.07 ? "low" : "poor";
  const figs = `median ${pc(roicMed)}, above 15% in ${roicAbove} of ${n} years`;

  let s1;
  if (band === "high") s1 = `Return on capital has run high across the record (${figs})`;
  else if (band === "mid") s1 = `Return on capital has run in the teens (${figs})`;
  else if (band === "low") s1 = `Return on capital has sat near the cost of capital (median ${pc(roicMed)})`;
  else s1 = `Return on capital has rarely cleared the cost of capital (${figs})`;
  if (roicInflated && (band === "high" || band === "mid"))
    s1 += ", though buybacks and expensed R&D and brands shrink the capital base, so the figure overstates the underlying economics";
  s1 += ".";

  let s2 = "";
  if (oeMed != null && oeMed >= 0.03)
    s2 = `${roicInflated ? "The steadier read is owner earnings" : "Owner earnings agree"}: roughly ${pc(oeMed)} of revenue reaches owners as cash${oeStable ? ", consistently" : ", though it swings"}` +
      `${negativeCCC ? ", and customers and suppliers fund the business through negative working capital" : ""}.`;
  else if (oeMed != null) s2 = "Owner earnings, the cash-based check, have been thin too.";
  else if (negativeCCC) s2 = "Customers and suppliers fund the business through negative working capital, a structural edge the ratio does not show.";

  let s3;
  if (band === "high") s3 = "High, durable returns can mark a moat, but whether this one is real pricing power or an accounting artifact is the judgment the 10-K is for.";
  else if (band === "mid") s3 = "Returns like these are solid but short of clear franchise economics; whether they hold is what the 10-K settles, not the multiple.";
  else if (cyclical) s3 = "The cycle and the balance sheet decide this one, so weigh the worst year against the median, and read the 10-K.";
  else s3 = "This is price-taker territory, where the balance sheet and the cycle matter more than any multiple; the 10-K is where you look.";

  moat = { text: [s1, s2, s3].filter(Boolean).join(" ") };
}

// What owners actually keep: owner earnings as a share of revenue, this period.
const oem = ownerEarningsMargin(cur);
let owners = null;
if (oem != null)
  owners = oem < 0
    ? { value: pc(oem, 1), text: "owner earnings. The business spends more on the capex it needs to stand still than its operations bring in, so for now it consumes cash. The price tool shows what the future must deliver to justify the shares." }
    : { value: pc(oem, 1), text: "of revenue reaches owners as free cash, after the capex the business needs just to stand still. This is the figure to judge it on, not accounting profit." };

// What management does with the cash, characterised over the whole span.
const cap = capitalHistory(company);

// Can it be killed? Net cash or net debt, with interest coverage as the qualifier.
const cash = cashPosition(company);
const cov = coverage(company);
let covPhrase = "";
if (cov && cov.ratio != null && cov.ratio >= 1) covPhrase = ` Operating profit covers the interest about ${cov.ratio.toFixed(1)} times over.`;
else if (cov && cov.ratio != null) covPhrase = ` A full year of operating profit does not cover the interest bill (${cov.ratio.toFixed(1)}×), the first thing to weigh here.`;
else if (cov && cov.noBurden) covPhrase = " There is little or no interest burden to carry.";
else if (cov) covPhrase = " A year of operating profit does not cover the interest bill, the first thing to weigh here.";

const overlays = cls.overlays || [];
---

<section class="brief">
  <div class="head">
    <h2>The business in brief</h2>
    {sourceUrl ? <a class="src" href={sourceUrl} target="_blank" rel="noopener">read the 10-K →</a> : null}
  </div>
  <p class="intro">
    What this business is and what moves its needle, read straight from the numbers in its
    filings. No verdict and no score, the company's own account of the business is one click
    away in the 10-K.
  </p>

  <dl class="reads">
    <div class="r">
      <dt>What it is</dt>
      <dd>
        {bizLine ? <span class="said">“{bizLine}”</span> : null}
        <span class="tag">{cls.sector.label}</span> {whatItIs}
      </dd>
    </div>
    {overlays.length ? (
      <div class="r">
        <dt>Situation</dt>
        <dd>{overlays.map((o) => <span class="ov"><b>{o.label}.</b> {o.reason}. </span>)}</dd>
      </div>
    ) : null}
    <div class="r">
      <dt>What moves the needle</dt>
      <dd>{lever}{leverExtra}</dd>
    </div>
    {moat ? (
      <div class="r">
        <dt>Is it a good business?</dt>
        <dd>{moat.text}</dd>
      </div>
    ) : null}
    {owners ? (
      <div class="r">
        <dt>What owners keep</dt>
        <dd><span class="fig">{owners.value}</span> {owners.text}</dd>
      </div>
    ) : null}
    {cap ? (
      <div class="r">
        <dt>What is done with the cash</dt>
        <dd>Over {cap.span}, {cap.character}.</dd>
      </div>
    ) : null}
    {cash ? (
      <div class="r">
        <dt>Can it be killed?</dt>
        <dd><span class="fig">{cash.value}</span> {cash.label}.{covPhrase}</dd>
      </div>
    ) : null}
  </dl>

  <p class="foot">
    Every line here is arithmetic from the company's own filings, not a model's opinion, and
    each figure appears in full below. For the business in management's own words, read the 10-K.
  </p>
</section>

<style>
  .brief { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 70ch; }

  .reads { margin: 14px 0 0; }
  .r { display: grid; grid-template-columns: 190px 1fr; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--rule); }
  .r dt { font-family: var(--sans); font-weight: 700; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .r dd { margin: 0; font-size: 14.5px; line-height: 1.55; color: #2c2f36; max-width: 72ch; }
  .said { display: block; font-family: var(--serif); font-style: italic; font-size: 14.5px; line-height: 1.5; color: #3a3e46; margin: 0 0 7px; }
  .ov b { color: var(--ink); }
  .tag { font-size: 11px; letter-spacing: 0.02em; color: var(--ink); border: 1px solid var(--rule-strong); padding: 1px 6px; margin-right: 6px; white-space: nowrap; }
  .fig { font-weight: 700; font-variant-numeric: tabular-nums; color: var(--ink); margin-right: 4px; }
  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 14px; padding-top: 10px; max-width: 72ch; }

  @media (max-width: 560px) {
    .r { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
