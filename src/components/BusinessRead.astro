---
// The business in brief: the qualitative thesis. What the company sells (from its
// own segment mix), the situation, what moves its needle, and whether the numbers
// say it is any good, with the verdict handed to the filing on purpose. For most
// names every claim is arithmetic, shown in full below. For
// the names carrying a reviewed note (docs/qualitative-doctrine.md), the two
// descriptive reads are drafted from the company's own filings and reviewed by hand;
// "is it a good business" stays computed, and the footer says which is which. The
// company's own description and the industry sit in the page header above this.
import language from "../data/language.json";
import segmentsData from "../data/segments.json";
import { pickPrimaryBreakdown, compositionSentence } from "../lib/segments.mjs";
import { classify } from "../lib/archetype.mjs";
import { roicValue, ownerEarningsMargin, cashConversionCycle, debtReliable } from "../lib/fundamentals.mjs";
import { financialQuality } from "../lib/financials.mjs";
import { reitQuality } from "../lib/reits.mjs";
import { insurerQuality } from "../lib/insurers.mjs";
import { feeQuality } from "../lib/feeFinancials.mjs";
import { managedCareQuality } from "../lib/managedCare.mjs";
import { financialKind, financialSubtype } from "../lib/archetype.mjs";
import { businessLever, businessPhrase, weakLede, pickNote } from "../lib/business.mjs";
import notes from "../data/notes.json";

const { company } = Astro.props;
const cls = classify(company);
const L = language?.companies?.[company.ticker] || null;
const sourceUrl = L?.sourceUrl || null;

const fk = financialKind(company);

const pc = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(dp)}%`);
const median = (xs) => { const s = [...xs].sort((a, b) => a - b); return s.length ? s[Math.floor((s.length - 1) / 2)] : null; };

// A reviewed, model-drafted note (docs/qualitative-doctrine.md) for the names a human
// has written up: it supplies the two descriptive reads in place of the computed
// template. Absent or unreviewed, everything below falls back to the template, so the
// 800-plus names without a note are unchanged. The note carries prose only — every
// figure on the page stays arithmetic in the sections below.
const note = pickNote(notes, company.ticker);

// What moves the needle: the reviewed note when present, else one lever per business,
// finer than the model where the industry warrants it (lib/business.mjs). Teaches the
// lens, never a verdict on this one.
const lever = note?.needle || businessLever(company);

// Segment reality check: when the profit engine is not the biggest seller, say so,
// so an archetype label (Amazon read as "retail") does not mislead about the needle.
const cleanSeg = (s) => String(s || "").replace(/&amp;/gi, "&").replace(/\s+Segments?$/i, "").replace(/ And /g, " and ").trim();
let leverExtra = "";
const seg = segmentsData?.companies?.[company.ticker];
// Only when the segment breakdown actually informs (and so renders below), or the "see
// the mix below" pointer would dangle at a section we suppressed.
const segPick = pickPrimaryBreakdown(seg, ["segment"]);
if (segPick?.raw?.hasOperatingIncome) {
  const items = segPick.raw.items;
  const oiSum = items.filter((i) => (i.operatingIncome ?? 0) > 0).reduce((a, b) => a + b.operatingIncome, 0);
  const topRev = [...items].sort((a, b) => b.revenue - a.revenue)[0];
  const topOI = [...items].sort((a, b) => (b.operatingIncome ?? 0) - (a.operatingIncome ?? 0))[0];
  if (oiSum > 0 && topRev && topOI && topOI.label !== topRev.label)
    leverExtra = ` In practice most of the profit now comes from ${cleanSeg(topOI.label)}, even though ${cleanSeg(topRev.label)} is the bigger seller, so that is the part to watch (see the mix below).`;
}

// Make the industry lens company-specific by pointing to the filing's own top flagged
// driver, reusing the same ownerFlags the section below sets against the numbers. A
// pointer, not a repeat: the quote and the weld stay in "what the filing emphasizes".
const DRIVER_LENSES = new Set(["Customer concentration", "Pricing power & competition", "Supplier & input dependence", "Concentrated dependence", "Cyclicality & demand"]);
const oflags = L?.ownerFlags || [];
const topFlag = oflags.find((f) => DRIVER_LENSES.has(f.lens)) || oflags[0] || null;
const flagPointer = topFlag
  ? ` On its own account, the filing leans hardest on ${topFlag.lens.toLowerCase()}, set against the numbers in what the filing emphasizes, below.`
  : "";

// What it is: the segment mix when it actually informs (same gate as the section below,
// from lib/segments.mjs, so the two never disagree). Geography answers where, not what,
// so the brief asks only for segments or product lines. The computed phrase lives in
// lib/business.mjs and is shown only when the hero is carrying the filing's own words.
const composition = compositionSentence(seg) || "";
// The hero (page header) opens with, in order: the filing's verbatim description, else this
// segment composition, else the computed industry phrase. Show here whatever the hero is NOT
// showing, so the two read as a pair instead of repeating — the mix beside the filing's own
// words, or the industry lens beside the mix.
// When a reviewed note is present, the hero opens with its "what it is" prose, so the
// brief shows only the complement — the revenue mix when it actually informs — and never
// repeats the prose. Without a note, the original chain: the segment mix or the computed
// phrase, whichever the hero is not already showing.
const goodVerbatim = !weakLede(L?.business);
const whatItIs = note
  ? (composition || null)
  : goodVerbatim
  ? (composition || businessPhrase(company))
  : (composition ? businessPhrase(company) : null);

// Is it a good business? Read return on capital across the whole record, but treat
// the ratio with the skepticism modern accounting demands: buybacks and expensed
// R&D and brands shrink invested capital and inflate ROIC, so flag that, lean on the
// harder-to-game cash measure (owner earnings), and hand the verdict to the filing.
const H = (company.history || []).filter((h) => h?.lines?.revenue != null);
const roicSeries = H.map((h) => roicValue(h.lines)).filter((v) => v != null);
const roicMed = median(roicSeries);
const roicAbove = roicSeries.filter((v) => v >= 0.15).length;

const annual = company.lines || {};
const invested = annual.totalDebt != null && annual.stockholdersEquity != null
  ? annual.totalDebt + annual.stockholdersEquity - (annual.cashAndEquivalents || 0) : null;
const investedIntensity = invested != null && annual.revenue ? invested / annual.revenue : null;
const roicInflated = cls.sector.key === "assetLight"
  || (investedIntensity != null && investedIntensity < 0.3)
  || (roicMed != null && roicMed > 0.3);

const oeSeries = H.map((h) => ownerEarningsMargin(h.lines, company)).filter((v) => v != null);
const oeMed = median(oeSeries);
const oeStable = oeSeries.length >= 3 && oeSeries.filter((v) => v > 0).length >= oeSeries.length - 1;
const ccc = cashConversionCycle(company);
const negativeCCC = ccc && /Negative/.test(ccc.label);
const cyclical = (cls.overlays || []).some((o) => o.key === "cyclical");

// Banks read on ROE, insurers on the combined ratio and float, REITs on FFO, asset
// managers and exchanges on fee margins, health plans on the medical loss ratio, none
// on ROIC; route each financial kind to its own lens (fk resolved above).
const isFin = !!fk;
let moat = fk === "reit" ? reitQuality(company)
  : fk === "insurer" ? insurerQuality(company, financialSubtype(company))
  : fk === "managedCare" ? managedCareQuality(company)
  : fk === "fee" ? feeQuality(company, financialSubtype(company))
  : fk === "bank" ? financialQuality(company, financialSubtype(company))
  : null;
const debtOk = debtReliable(company.lines || {}) && debtReliable(company.ttm?.lines || {});
if (!isFin && debtOk && roicSeries.length >= 3 && roicMed != null) {
  const n = roicSeries.length;
  const band = roicMed >= 0.2 ? "high" : roicMed >= 0.13 ? "mid" : roicMed >= 0.07 ? "low" : "poor";
  const figs = `median ${pc(roicMed)}, above 15% in ${roicAbove} of ${n} years`;

  let s1;
  if (band === "high") s1 = `Return on capital has run high across the record (${figs})`;
  else if (band === "mid") s1 = `Return on capital has run in the teens (${figs})`;
  else if (band === "low") s1 = `Return on capital has sat near the cost of capital (median ${pc(roicMed)})`;
  else s1 = `Return on capital has rarely cleared the cost of capital (${figs})`;
  if (roicInflated && (band === "high" || band === "mid"))
    s1 += ", though buybacks and expensed R&D and brands shrink the capital base, so the figure overstates the underlying economics";
  s1 += ".";

  let s2 = "";
  if (oeMed != null && oeMed >= 0.03)
    s2 = `${roicInflated ? "The steadier read is owner earnings" : "Owner earnings agree"}: roughly ${pc(oeMed)} of revenue reaches owners as cash${oeStable ? ", consistently" : ", though it swings"}` +
      `${negativeCCC ? ", and customers and suppliers fund the business through negative working capital" : ""}.`;
  else if (oeMed != null) s2 = "Owner earnings, the cash-based check, have been thin too.";
  else if (negativeCCC) s2 = "Customers and suppliers fund the business through negative working capital, a structural edge the ratio does not show.";

  let s3;
  if (band === "high") s3 = "High, durable returns can mark a moat, but whether this one is real pricing power or an accounting artifact is the judgment the 10-K is for.";
  else if (band === "mid") s3 = "Returns like these are solid but short of clear franchise economics; whether they hold is what the 10-K settles, not the multiple.";
  else if (cyclical) s3 = "The cycle and the balance sheet decide this one, so weigh the worst year against the median, and read the 10-K.";
  else s3 = "This is price-taker territory, where the balance sheet and the cycle matter more than any multiple; the 10-K is where you look.";

  moat = { text: [s1, s2, s3].filter(Boolean).join(" ") };
}

const overlays = cls.overlays || [];
---

<section class="brief">
  <div class="head">
    <h3 class="secTitle">The business in brief</h3>
    {sourceUrl ? <a class="src" href={sourceUrl} target="_blank" rel="noopener">read the 10-K →</a> : null}
  </div>
  <p class="intro">
    What this business is and what moves its needle, drawn from its own SEC filings. The lens
    to bring to the numbers below, not the answer.
  </p>

  <dl class="reads">
    {whatItIs ? (
      <div class="r">
        <dt>What it is</dt>
        <dd>{whatItIs}</dd>
      </div>
    ) : null}
    {overlays.length ? (
      <div class="r">
        <dt>Situation</dt>
        <dd>{overlays.map((o) => <span class="ov"><b>{o.label}.</b> {o.reason}. </span>)}</dd>
      </div>
    ) : null}
    <div class="r">
      <dt>What moves the needle</dt>
      <dd>{lever}{note ? "" : leverExtra}{note ? "" : flagPointer}</dd>
    </div>
    {moat ? (
      <div class="r">
        <dt>Is it a good business?</dt>
        <dd>{moat.text}</dd>
      </div>
    ) : null}
  </dl>

  <p class="foot">
    {note
      ? "The lens and characterization here were drafted from the company's own filings and reviewed by hand; every number is arithmetic on those filings, shown in full in the sections below. The judgment is yours."
      : "Every line here is arithmetic on the company's filings, shown in full in the sections below; the judgment is yours."}
  </p>
</section>

<style>
  .brief { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 70ch; }

  .reads { margin: 14px 0 0; }
  .r { display: grid; grid-template-columns: 190px 1fr; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--rule); }
  .r dt { font-family: var(--sans); font-weight: 700; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .r dd { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--ink-soft); max-width: 72ch; }
  .ov b { color: var(--ink); }
  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 14px; padding-top: 10px; max-width: 72ch; }

  @media (max-width: 560px) {
    .r { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
