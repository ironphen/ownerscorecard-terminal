---
import fundamentals from "../data/fundamentals.json";
import { buildScorecard, TONE_COLOR, roicValue, ownerEarningsMargin, operatingMargin, earningsQuality, earningsQualityReconciliation } from "../lib/fundamentals.mjs";
import { selectPeers, peerMedian } from "../lib/peers.mjs";
import { buildFinancialScorecard, returnOnEquity, returnOnTangibleEquity, efficiencyRatio } from "../lib/financials.mjs";
import { buildReitScorecard, ffoPayout, debtToAssets, ebitdaCoverage } from "../lib/reits.mjs";
import { buildInsurerScorecard, combinedRatio } from "../lib/insurers.mjs";
import { buildFeeScorecard } from "../lib/feeFinancials.mjs";
import { buildManagedCareScorecard, medicalLossRatio } from "../lib/managedCare.mjs";
import { moatReport } from "../lib/durability.mjs";
import { grahamTests } from "../lib/graham.mjs";
import { financialKind, financialSubtype } from "../lib/archetype.mjs";
import language from "../data/language.json";
import MoatUnderAI from "./MoatUnderAI.astro";
import Term from "./Term.astro";

const { company, sample = false, peers: peersProp } = Astro.props;
// Graham's defensive tests live inside the scorecard, so "is it safe" reads in one place
// instead of split across a separate section. Run for the US pool and the ADRs, but not the
// Japanese pool or the financials (the tests are industrial-shaped — a current-ratio and
// working-capital frame the banks/insurers/REITs don't fit). The one dollar-denominated test,
// the $2B size floor, shows the figure but withholds a verdict for a non-dollar filer rather
// than fake an exchange rate (see graham.mjs); the rest are ratios that read in any currency.
const GTONE = { pass: "good", near: "warn", fail: "bad", na: "none" };
const GLABEL = { pass: "Pass", near: "Near", fail: "Miss", na: "—" };
// Each financial kind is read on different statements, so each gets its own scorecard
// and skips the ROIC-based durability block, which applies to none of them: a lender on
// return on equity and credit cost, an insurer on the combined ratio and float, a REIT
// on FFO, an asset manager or exchange on fee margins, a health plan on its medical loss
// ratio.
const fk = financialKind(company);
const isFin = !!fk;
const { sections } =
  fk === "reit" ? buildReitScorecard(company)
  : fk === "insurer" ? buildInsurerScorecard(company, financialSubtype(company))
  : fk === "managedCare" ? buildManagedCareScorecard(company)
  : fk === "fee" ? buildFeeScorecard(company, financialSubtype(company))
  : fk === "bank" ? buildFinancialScorecard(company, financialSubtype(company))
  : buildScorecard(company);
// The filing's own pricing words, threaded into the moat report so the margin/pricing-power line
// reads the number and the company's language together. Withheld for financials (where "pricing
// power" and "input costs" are the wrong lens) — and moatReport runs for non-financials only anyway.
const pricingLang = isFin ? null : (language?.companies?.[company.ticker]?.buffettRead?.pricing || null);
const report = isFin ? null : moatReport(company, { pricing: pricingLang });
const graham = company.market !== "JP" && !isFin ? grahamTests(company) : null;

// Peer context on the two quality reads that are otherwise judged against an absolute band: a number
// means something only beside its peers — 18% ROIC is wonderful for a grocer and ordinary for software.
// The same economic-engine peers the table below uses, each read through its own cycle, so the median is
// the line this company's figure is set against. Factual context, never a verdict; shown only when the
// industry has enough peers carrying the metric (peerMedian withholds otherwise). Every archetype is read
// on its own measures — the operator on ROIC and owner earnings, a bank on ROE/ROTCE/efficiency, a REIT on
// payout, leverage and coverage against its property subsector.
const peerCtx = (() => {
  const peers = peersProp || selectPeers(company, fundamentals.companies || []).peers;
  const ctx = {};
  // Add peer context to a check by its title: the median of the metric across the same-engine peers,
  // each read through its own cycle. Withheld (no line) when too few peers carry it. Most metrics are
  // percentages; an optional formatter handles the few that aren't (interest coverage, a multiple).
  const pctFmt = (m) => `${(m * 100).toFixed(0)}%`;
  const add = (title, fn, fmt = pctFmt) => { const m = peerMedian(peers, fn); if (m != null) ctx[title] = `Industry peers: median ${fmt(m)}`; };
  if (!isFin) {
    add("Return on invested capital", (L) => roicValue(L));
    add("Owner-earnings margin", (L, c) => ownerEarningsMargin(L, c));
  } else if (fk === "reit") {
    // A REIT's peers are now its property subsector (net-lease beside net-lease), so the payout,
    // leverage and coverage read against a like property model — not a grab-bag of "real estate".
    // FFO-per-share stays off the peer line (it's a per-share figure, not a comparable ratio).
    add("Dividend / FFO (payout)", (L) => ffoPayout(L));
    add("Debt / assets", (L) => debtToAssets(L));
    add("Interest coverage (EBITDA)", (L) => ebitdaCoverage(L), (m) => `${m.toFixed(1)}×`);
  } else if (fk === "bank") {
    add("Return on equity", (L) => returnOnEquity(L));
    add("Return on tangible equity", (L) => returnOnTangibleEquity(L));
    add("Efficiency ratio", (L) => efficiencyRatio(L));
  } else if (fk === "insurer") {
    add("Return on equity", (L) => returnOnEquity(L));
    add("Combined ratio", (L) => combinedRatio(L));
  } else if (fk === "managedCare") {
    add("Return on equity", (L) => returnOnEquity(L));
    add("Operating margin", (L) => operatingMargin(L));
    add("Medical loss ratio", (L) => medicalLossRatio(L));
  } else if (fk === "fee") {
    add("Operating margin", (L) => operatingMargin(L));
    add("Return on equity", (L) => returnOnEquity(L));
  }
  return ctx;
})();

// The earnings-quality tie: the filing's language about the numbers, brought to the cash-backing
// check. Integrity admissions (a material weakness, a restatement) undermine the numbers themselves;
// heavy "look past GAAP" steering is read against whether cash actually backs the GAAP profit. The
// ratio stays the spine; the words say whether to trust it. Non-financial scorecard only, where the
// "Are earnings backed by cash?" check lives; financials' admissions still surface in the owner read.
const eqTie = (() => {
  if (isFin) return null;
  const lc = language?.companies?.[company.ticker] || null;
  const integ = lc?.buffettRead?.integrity || null;
  const adjusted = lc?.mdna?.candor?.adjusted ?? null;
  if (!integ && adjusted == null) return null;
  const q = earningsQuality(company);
  return earningsQualityReconciliation(q?.tone || "none", {
    adjusted,
    materialWeakness: !!integ?.materialWeakness,
    restatement: !!integ?.restatement,
  });
})();

// Enrich each check with the context it earns: the peer median where the metric is peer-comparable,
// and — on the cash-backing check — the filing's own language about the reliability of the numbers.
const enrich = (sec) => ({
  ...sec,
  checks: sec.checks.map((c) => {
    let cc = peerCtx[c.title] ? { ...c, peer: peerCtx[c.title] } : c;
    if (eqTie && c.title === "Are earnings backed by cash?") cc = { ...cc, lang: eqTie.text, langTone: eqTie.tone };
    return cc;
  }),
});
---

<section class="scorecard">
  <div class="head">
    <h3 class="secTitle">Owner’s Scorecard</h3>
    <div class="src">
      FY{company.fy} {company.form}
      {company.sourceUrl ? (
        <> · <a href={company.sourceUrl} target="_blank" rel="noopener">source on {company.market === "JP" ? "EDINET" : "SEC EDGAR"} →</a></>
      ) : null}
    </div>
  </div>

  {sample ? (
    <div class="sample">
      <strong>Sample data.</strong> Illustrative placeholders until the EDGAR pipeline runs.
      The “source” link is already real.
    </div>
  ) : null}

  {sections.map(enrich).map((sec) => (
    <div class="section">
      <h3 class="secHead">{sec.heading}</h3>
      <ul class="checks">
        {sec.checks.map((c) => (
          <li>
            <div class="row">
              <span class="title">{c.concept ? <Term id={c.concept}>{c.title}</Term> : c.href ? <a href={c.href}>{c.title}</a> : c.title}</span>
              <span class="value" style={`color:${TONE_COLOR[c.tone]}`}>{c.value}</span>
            </div>
            <div class="label" style={`color:${TONE_COLOR[c.tone]}`}>{c.label}</div>
            {c.formula ? <div class="formula">{c.formula}</div> : null}
            {c.peer ? <div class="peer">{c.peer}</div> : null}
            {c.lang ? <p class="langTie" style={`border-color:${TONE_COLOR[c.langTone]}`}><span class="langMark" style={`color:${TONE_COLOR[c.langTone]}`}>In the filing’s words</span> {c.lang}</p> : null}
            <details class="why"><summary>What this means</summary><p class="note">{c.note}</p></details>
          </li>
        ))}
      </ul>
    </div>
  ))}

  {graham ? (
    <div class="section">
      <h3 class="secHead">Graham’s defensive tests{graham.testable ? ` · ${graham.passes} of ${graham.testable} met` : ""}</h3>
      <p class="durNote">Graham’s numerical criteria for the defensive investor (<em>The Intelligent Investor</em>, ch. 14), run on the filings. A floor of safety, not a buy signal; many fine modern businesses fail his strictest liquidity rules by design.</p>
      <ul class="report">
        {graham.tests.map((t) => (
          <li>
            <div class="factRow">
              <span class="factLabel">{t.name}</span>
              <span class="gbadge" style={`color:${TONE_COLOR[GTONE[t.status]]}; border-color:${TONE_COLOR[GTONE[t.status]]}`}>{GLABEL[t.status]}</span>
            </div>
            <div class="gcrit">{t.criterion} · <b>{t.value}</b></div>
            <details class="why"><summary>What this means</summary><p class="factNote">{t.note}</p></details>
          </li>
        ))}
      </ul>
    </div>
  ) : null}

  {report ? (
    <div class="section">
      <h3 class="secHead">Durability &amp; moat, {report.years[0]}–{report.years[report.years.length - 1]}</h3>
      <p class="durNote">A moat is a high return that doesn’t fade, reinvested at high returns. Here is what the record says, judgments, not another chart of the numbers.</p>
      <ul class="report">
        {report.facts.map((ft) => (
          <li>
            <div class="factRow">
              <span class="factLabel">{ft.label}</span>
              <span class="factValue" style={`color:${TONE_COLOR[ft.tone]}`}>{ft.value}</span>
            </div>
            {ft.lang ? <p class="langTie" style={`border-color:${TONE_COLOR[ft.langTone]}`}><span class="langMark" style={`color:${TONE_COLOR[ft.langTone]}`}>In the filing’s words</span> {ft.lang}</p> : null}
            <details class="why"><summary>What this means</summary><p class="factNote">{ft.note}</p></details>
          </li>
        ))}
      </ul>
    </div>
  ) : null}

  {company.market !== "JP" ? <MoatUnderAI company={company} /> : null}

  <p class="foot">
    Solvent is not the same as cheap; growing is not the same as good. These are vital
    signs, not a verdict, the judgment is yours, and the filing is one click away.
  </p>
</section>

<style>
  .scorecard { border: 1px solid var(--rule-strong); padding: 20px 22px; margin: 20px 0; background: var(--surface); }
  .head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .head h2 { margin: 0; }
  .src { font-size: 12px; color: var(--muted); }
  .src a { color: var(--accent); }

  .sample { background: var(--warn-bg); border: 1px solid var(--warn-border); padding: 6px 10px; font-size: 12px; color: var(--warn-ink); margin-top: 12px; }

  .section { margin-top: 18px; }
  .secHead {
    font-family: var(--sans); font-weight: 600;
    margin: 0; font-size: 11.5px; letter-spacing: 0.09em; text-transform: uppercase;
    color: var(--ink); border-bottom: 1px solid var(--rule-strong); padding-bottom: 5px;
  }

  .checks { list-style: none; padding: 0; margin: 0; }
  .checks li { padding: 13px 0; border-bottom: 1px solid var(--rule); }

  .row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .title { font-weight: 600; font-size: 16px; }
  .title a { color: inherit; }
  .value { font-size: 23px; font-weight: 700; font-variant-numeric: tabular-nums; flex: 0 0 auto; letter-spacing: -0.01em; }

  .label { font-weight: 600; font-size: 13px; margin-top: 2px; }
  .formula { font-size: 12.5px; color: var(--muted); font-variant-numeric: tabular-nums; margin-top: 4px; }
  /* Peer context: where this figure sits against its industry, the line that gives the number meaning.
     Set in the accent so the eye catches the comparison, but stated as fact — never a verdict. */
  .peer { font-size: 12px; color: var(--accent); font-variant-numeric: tabular-nums; margin-top: 4px; letter-spacing: 0.01em; }
  .note { font-size: 13.5px; color: var(--ink-dim); margin: 6px 0 0; line-height: 1.5; }

  /* The explanatory paragraph under each row is collapsed by default for a clean, scannable
     scorecard; the figure and its one-word read stay visible, the teaching is one click away. */
  .why { margin-top: 6px; }
  .why > summary { list-style: none; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; font-family: var(--sans); font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); user-select: none; }
  .why > summary::-webkit-details-marker { display: none; }
  .why > summary::before { content: "▸"; font-size: 9px; line-height: 1; transition: transform 0.15s ease; }
  .why[open] > summary::before { transform: rotate(90deg); }
  .why > summary:hover { color: var(--accent); }
  .why[open] > summary { margin-bottom: 3px; }
  .why > .note, .why > .factNote { margin-top: 0; }

  .durNote { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 6px; }
  .report { list-style: none; padding: 0; margin: 0; }
  .report li { padding: 11px 0; border-bottom: 1px solid var(--rule); }
  .factRow { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .factLabel { font-weight: 600; font-size: 15px; }
  .factValue { font-weight: 700; font-size: 17px; font-variant-numeric: tabular-nums; flex: 0 0 auto; text-align: right; }
  .factNote { font-size: 13px; color: var(--ink-dim); margin: 4px 0 0; line-height: 1.5; }

  /* The pricing-power tie: the filing's own words brought to the margin number, set off with a
     tone-colored rule so it reads as a second voice corroborating, explaining or contesting the
     record — not another data line. The marker names the source; the clause does the reasoning. */
  .langTie { font-family: var(--serif); font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; margin: 7px 0 0; padding: 1px 0 1px 12px; border-left: 2px solid var(--rule-strong); max-width: 74ch; }
  .langMark { font-family: var(--sans); font-style: normal; font-weight: 700; font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; margin-right: 6px; }

  .gbadge { font-family: var(--sans); font-size: 10.5px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; border: 1px solid; border-radius: 2px; padding: 1px 7px; flex: 0 0 auto; }
  .gcrit { font-size: 13px; color: var(--muted); margin-top: 3px; font-variant-numeric: tabular-nums; }
  .gcrit b { color: var(--ink); font-weight: 700; }

  .foot { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 16px; padding-top: 11px; }

  /* On a phone a long descriptive value (a margin trajectory like "28% (FY2016) → 32%
     (FY2025)") can't sit beside its label without pushing the page wide, so the row wraps and
     the value drops to its own line, left-aligned, rather than overflowing. */
  @media (max-width: 480px) {
    .row, .factRow { flex-wrap: wrap; }
    .value, .factValue { text-align: left; }
  }
</style>
