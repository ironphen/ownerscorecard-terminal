---
// The ADRs pool: foreign companies listed in the US, the same "start with the A's" A-Z directory as
// the home tab, by company name, each opening to its full record (in its home currency). Self-
// contained — its own scoped search and rail (adr- prefixed) so it never collides with the US
// directory in the same page. Reads fundamentals.adr.json; renders nothing until that is populated.
import adr from "../data/fundamentals.adr.json";

const sortKey = (s) => s.replace(/^the\s+/i, "").replace(/^[^a-z0-9]+/i, "").trim().toLowerCase();
const rows = [...(adr.companies || [])]
  .map((c) => ({ ticker: String(c.ticker || ""), name: c.name || c.ticker, country: c.country || null, key: sortKey(c.name || c.ticker) }))
  .filter((r) => r.ticker)
  .sort((a, b) => a.key.localeCompare(b.key) || a.ticker.localeCompare(b.ticker));

const LETTERS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
const letterOf = (k) => { const ch = (k[0] || "#").toUpperCase(); return /[A-Z]/.test(ch) ? ch : "#"; };
const groups = new Map();
for (const r of rows) { const k = letterOf(r.key); if (!groups.has(k)) groups.set(k, []); groups.get(k).push(r); }
const order = [...LETTERS.filter((l) => groups.has(l)), ...(groups.has("#") ? ["#"] : [])];
---

{rows.length ? (
  <section class="adrcat">
    <div class="bandHead">
      <h2>ADRs</h2>
      <a class="all" href="/concepts">What the terms mean →</a>
    </div>
    <p class="method">
      Foreign companies listed on a US exchange — they file a Form 20-F with the SEC, so we read them
      the same way, from their own filings, in their home currency. The same A-to-Z, each a door to its
      full record. We don't rank them.
    </p>

    <div class="toolbar">
      <input id="adr-q" type="search" placeholder="Search ticker or name…" class="search" autocomplete="off" aria-label="Search ADRs by ticker or name" />
      <span id="adr-count" class="count">{rows.length} companies</span>
    </div>

    <nav class="azbar" aria-label="Jump to letter">
      {LETTERS.map((l) => (groups.has(l) ? <a href={`#A-${l}`}>{l}</a> : <span class="off">{l}</span>))}
    </nav>

    <div id="adr-index">
      {order.map((l) => (
        <section class="let" id={l === "#" ? "A-num" : `A-${l}`}>
          <h3 class="letH" aria-hidden="true">{l}</h3>
          <ul class="ents">
            {groups.get(l).map((r) => (
              <li class="ent" data-s={`${r.name} ${r.ticker} ${r.country || ""}`.toLowerCase()}>
                <a class="entLink" href={`/c/${r.ticker}`}>
                  <span class="n">{r.name}</span>
                  <span class="t">{r.ticker}</span>
                </a>
                {r.country ? <span class="ctry">{r.country}</span> : null}
              </li>
            ))}
          </ul>
        </section>
      ))}
      <p class="empty" id="adr-empty" hidden>No company matches that.</p>
    </div>
  </section>
) : (
  <p class="soon">The ADR pool is being assembled. Check back shortly.</p>
)}

<style>
  .bandHead { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .bandHead h2 { margin: 0; }
  .all { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; flex: 0 0 auto; }
  .method { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 70ch; line-height: 1.6; }
  .toolbar { position: sticky; top: 0; z-index: 20; background: var(--paper); display: flex; align-items: center; gap: 12px; margin: 14px 0 0; padding: 8px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule-strong); }
  .search { flex: 1 1 220px; min-width: 140px; padding: 9px 12px; border: 1px solid var(--rule-strong); border-radius: 3px; font-family: var(--sans); font-size: 14px; background: var(--surface); color: var(--ink); }
  .search::placeholder { color: var(--faint); }
  .count { font-size: 11.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; font-variant-numeric: tabular-nums; }
  .azbar { display: flex; flex-wrap: wrap; gap: 1px 2px; margin: 12px 0 0; position: sticky; top: 49px; z-index: 19; background: var(--paper); padding: 6px 0; border-bottom: 1px solid var(--rule); }
  .azbar a, .azbar span { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; padding: 3px 7px; border-radius: 3px; min-width: 22px; text-align: center; }
  .azbar a { color: var(--accent); }
  .azbar a:hover { background: var(--accent-tint); text-decoration: none; }
  .azbar .off { color: var(--faint); }
  .let { margin: 0; scroll-margin-top: 92px; }
  .letH { font-family: var(--sans); font-weight: 800; font-size: 13px; letter-spacing: 0.08em; color: var(--muted); margin: 22px 0 0; padding-bottom: 5px; border-bottom: 1px solid var(--rule-strong); }
  .ents { list-style: none; padding: 0; margin: 6px 0 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 0 24px; }
  .ent { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; padding: 8px 2px; border-bottom: 1px solid var(--rule); }
  .entLink { display: flex; align-items: baseline; gap: 9px; min-width: 0; flex: 1 1 auto; }
  .entLink:hover { text-decoration: none; }
  .entLink:hover .n { color: var(--accent); }
  .entLink:hover .t { color: var(--accent); }
  .n { font-size: 14px; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .t { font-family: var(--sans); font-weight: 700; font-variant-numeric: tabular-nums; font-size: 11px; letter-spacing: 0.03em; color: var(--muted); flex: 0 0 auto; }
  .ctry { font-size: 10.5px; letter-spacing: 0.02em; color: var(--tag-ink); background: var(--tag-bg); border-radius: 3px; padding: 2px 7px; white-space: nowrap; flex: 0 0 auto; }
  .empty { font-family: var(--serif); font-style: italic; color: var(--muted); padding: 26px 2px; }
  .soon { font-family: var(--serif); font-style: italic; color: var(--muted); margin: 18px 0; }
  @media (max-width: 640px) { .ctry { display: none; } }
</style>

<script is:inline>
  (function () {
    const q = document.getElementById("adr-q");
    if (!q) return;
    const countEl = document.getElementById("adr-count");
    const emptyEl = document.getElementById("adr-empty");
    const azbar = document.querySelector(".adrcat .azbar");
    const sections = Array.from(document.querySelectorAll(".adrcat .let"));
    const total = document.querySelectorAll(".adrcat .ent").length;
    function apply() {
      const term = (q.value || "").trim().toLowerCase();
      let shown = 0; const live = new Set();
      sections.forEach((s) => {
        let any = false;
        s.querySelectorAll(".ent").forEach((e) => { const m = !term || e.dataset.s.indexOf(term) >= 0; e.hidden = !m; if (m) { any = true; shown++; } });
        s.hidden = !any; if (any) live.add(s.id);
      });
      if (emptyEl) emptyEl.hidden = shown !== 0;
      if (countEl) countEl.textContent = shown + (shown === 1 ? " company" : " companies");
      if (azbar) azbar.querySelectorAll("a").forEach((a) => { const on = live.has((a.getAttribute("href") || "").slice(1)); a.style.opacity = on ? "" : "0.3"; a.style.pointerEvents = on ? "" : "none"; });
    }
    q.addEventListener("input", apply);
  })();
</script>
