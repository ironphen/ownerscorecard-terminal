---
// An inline defined term. Wrap a word the reader is meant to learn:
//   <Term id="owner-earnings">owner earnings</Term>
// It renders with a quiet dotted underline, shows the one-line definition on hover
// (native title, so it works without JavaScript), and links to the full entry on the
// Concepts page. If the id is unknown it falls back to plain text, never a broken link.
import { conceptById } from "../data/concepts.mjs";

const { id } = Astro.props;
const c = conceptById[id];
if (!c && import.meta.env.DEV) console.warn(`[Term] unknown concept id: "${id}"`);
---

{c ? (
  <a class="term" href={`/concepts#${id}`} title={c.short}><slot /></a>
) : (
  <slot />
)}

<style>
  .term {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dotted var(--faint);
    cursor: help;
  }
  .term:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
    text-decoration: none;
  }
</style>
