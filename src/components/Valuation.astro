---
// "What the price implies", a reader-supplied-price reverse-DCF. We pull no price
// feed and store nothing: you bring the quote (off any broker), we do the math in
// your browser. That sidesteps every market-data licence and keeps the page honest
//, the only number we'd ever "redistribute" is the one you typed in. Never a price
// target: it shows the owner-earnings growth a price implies, set against the record.
import { classify, financialKind, financialSubtype } from "../lib/archetype.mjs";
import { moatReport } from "../lib/durability.mjs";
import { fmtMoney, currencySymbol, liquidAssets, maintenanceCapex, ownerEarningsAbs } from "../lib/fundamentals.mjs";
import { tangibleEquity } from "../lib/financials.mjs";
import { ffoPerShare } from "../lib/reits.mjs";
import { earningsPower } from "../lib/normalize.mjs";
import { trendGrowth } from "../lib/valuationInputs.mjs";
import rates from "../data/rates.json";
import DeliveredGrowth from "./DeliveredGrowth.astro";
import Sparkline from "./Sparkline.astro";

// The series behind a delivered-growth anchor: the same window the CAGR above is read over
// (the last `maxSpan` years, with the latest figure as the final point), so the rate, the
// sparkline and the "N-yr record" label all agree. null when the record is too short.
const sparkWin = (vals, maxSpan, latest) => {
  const xs = (vals || []).filter((v) => v != null);
  if (xs.length < 3) return null;
  const span = Math.min(maxSpan, xs.length - 1);
  const win = xs.slice(xs.length - 1 - span);
  if (latest != null) win[win.length - 1] = latest;
  return win;
};

const { company } = Astro.props;
// Currency-aware: the reader brings the price (in the listing currency), and the tool does
// the math in their browser. The symbol travels into each interactive box via data-sym.
const ccy = company.currency || "USD";
const sym = currencySymbol(ccy);
const $ = (v) => fmtMoney(v, ccy);
const { sector, overlays } = classify(company);
// A lender, an insurer and a REIT are not read on an owner-earnings DCF; each routes to
// its own balance-sheet or FFO lens. Asset managers, exchanges, brokers and health plans
// are capital-light cash generators, so they keep the owner-earnings reverse-DCF, the
// right lens for a business whose value is the cash it throws off, not its book.
const fk = financialKind(company);
const isInsurer = fk === "insurer";
const offModel = fk === "bank" || fk === "insurer" || fk === "reit";
// An ADR (a foreign 20-F/40-F filer) reports its financials in its home currency and on its
// ordinary-share count, undivided by the ADR ratio. The reader-supplied price is the only input
// the tool can't currency-convert (we carry no FX rate or ADR ratio, by the no-market-data rule),
// so a US ADR quote in dollars would not reconcile with home-currency owner earnings and an
// ordinary-share count — the multiple would be off by the exchange rate times the ADR ratio. We
// warn loudly and tell the reader the basis to enter on, rather than silently invert the read.
const isADR = company.market === "ADR";
const cyclical = overlays.some((o) => o.key === "cyclical");
const median = (xs) => { if (!xs.length) return null; const s = [...xs].sort((a, b) => a - b); const m = Math.floor(s.length / 2); return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
// A fiscal year as a two-digit tick (’25), and the inclusive span of a delivered-growth window —
// the last `n` points its CAGR and sparkline are read over — labelled ’20→’25, so every record
// anchor names the years it covers rather than leaving a bare count's start year to guess.
const yy = (fy) => (fy == null ? "" : `’${String(fy).slice(-2)}`);
const winRangeYrs = (pairs, n = 6) => { const w = (pairs || []).slice(-n); return w.length >= 2 ? `${yy(w[0].fy)}→${yy(w[w.length - 1].fy)}` : null; };
// Delivered growth (trendGrowth) and the reverse-DCF math (pv/solve/justified multiples) live in
// shared libs — lib/valuationInputs.mjs and lib/reverseDcf.mjs — so this page and the head-to-head
// compare view read a business through identical arithmetic. trendGrowth is imported above.

const L = company.ttm?.lines || company.lines || {};
// Share count turns the price into a market cap. We fall back from the TTM block to the latest
// annual, but some filers (Up-C structures, multiple share classes — Planet Fitness, Shopify)
// tag their shares where the pull misses them, leaving it null. Rather than withhold the whole
// tool over that one field, we run the owner-earnings mode anyway and let the reader bring the
// share count, the same way they bring the price.
const shares = L.sharesDiluted ?? company.lines?.sharesDiluted ?? null;
const haveShares = shares != null && shares > 0;
const cfo = L.cashFromOps, capex = L.capex;
const ownerEarnings = cfo != null && capex != null ? cfo - Math.abs(capex) : null;
const netDebt = (L.totalDebt || 0) - (liquidAssets(L) || 0);
// `runnable` is decided below, once the normalized and steady-state bases are known: the latest
// year can be negative on total capex (a build-out) while a through-cycle or maintenance-capex
// base is solidly positive, and that should still run the owner-earnings tool, not the loss read.

// Graham's price-gate inputs: 3-year average earnings (his method, to avoid paying
// for a peak) and current book value, both per share.
const niH = (company.history || []).filter((h) => h?.lines?.netIncome != null).slice(-3).map((h) => h.lines.netIncome);
const eps3 = niH.length >= 2 && shares ? niH.reduce((a, b) => a + b, 0) / niH.length / shares : null;
const bvps = L.stockholdersEquity != null && shares ? L.stockholdersEquity / shares : null;

// An honest base, on demand: a 3-year average of owner earnings (Graham's normalization,
// to avoid anchoring on one noisy year) and the latest stock comp (so it can be treated as
// the expense Munger insisted it is). Both are toggles in the tool.
const oeHist = (company.history || []).map((h) => (h.lines.cashFromOps != null && h.lines.capex != null ? h.lines.cashFromOps - Math.abs(h.lines.capex) : null));
const oe3vals = [...oeHist].reverse().filter((v) => v != null).slice(0, 3);
const oe3 = oe3vals.length >= 2 ? oe3vals.reduce((a, b) => a + b, 0) / oe3vals.length : ownerEarnings;
// The normalized base, Graham's through-cycle figure: the average owner-earnings margin of the
// record applied to today's revenue. Falls back to a 3-year average where the record is too short.
const ep = earningsPower(company);
const oeNormalized = ep?.normOE ?? oe3;
// Graham's through-cycle (peak-vs-trough) read, surfaced here at the point of valuation rather than in
// a separate "earnings power" section: where the latest year's owner-earnings margin sits against its
// own through-cycle median, so a price typed on a peak year is flagged as one. Only when the
// normalization is stable (a positive, meaningful through-cycle figure).
const cycleRead = ep && ep.normOE != null && ep.cyclePos && !ep.normUnstable && !ep.structuralBreak ? ep.cyclePos : null;
const sbcLatest = L.stockBasedComp ?? company.lines?.stockBasedComp ?? 0;
// Steady-state owner earnings: Buffett's definition subtracts maintenance capex, not total
// capex. For a business in a build-out (the AI capex wave most of all) total capex understates
// the cash it would throw off at rest, so we offer a base that swaps capex for depreciation,
// the standard maintenance-capex proxy. Offered only when it differs enough to matter.
const dep = L.depreciation;
// Maintenance capex (Buffett's owner earnings base) instead of total: the same per-company estimate
// the owner-earnings bridge uses, so the steady-state lens here and the bridge never disagree. It
// carves growth capex out only for a business spending above depreciation while it grows.
const maintCx = maintenanceCapex(company);
const ownerEarningsMaint = cfo != null && maintCx != null ? cfo - maintCx : null;
const oeHistMaint = (company.history || []).map((h) => (h.lines.cashFromOps != null && h.lines.depreciation != null ? h.lines.cashFromOps - h.lines.depreciation : null));
const oem3vals = [...oeHistMaint].reverse().filter((v) => v != null).slice(0, 3);
const oe3Maint = oem3vals.length >= 2 ? oem3vals.reduce((a, b) => a + b, 0) / oem3vals.length : ownerEarningsMaint;
// Show the steady-state toggle only where it actually differs — a real builder whose growth capex
// the maintenance estimate carves out; when maintenance ≈ total capex it would just be a dial for
// its own sake.
const offerMaint = ownerEarningsMaint != null && ownerEarnings != null && maintCx != null && capex != null && maintCx < Math.abs(capex) * 0.9;
// The owner-earnings growth the business actually delivered, as a number, to anchor a
// reference value against (never a target): what the record would be worth on its own record.
const oeSeries = oeHist.filter((v) => v != null);
const gDeliv = trendGrowth(oeSeries.slice(-8));
const oeWin = sparkWin(oeSeries, 7, null);

// A positive base to anchor the reverse-DCF can come from the latest year, the through-cycle
// normalization, or — for a business mid-build-out whose total capex buries the cash it throws
// off at rest — the steady-state (maintenance-capex) figure. When the latest year is negative on
// total capex but a normalized or steady-state base is positive (Air Products, a cyclical at a
// trough), we still run the owner-earnings tool and open it on that base with the toggle
// pre-checked, so the normalize controls are right there — rather than dropping to the loss read.
const maintBasePos = offerMaint && (((ownerEarningsMaint ?? -1) > 0) || ((oe3Maint ?? -1) > 0));
const normBasePos = (oeNormalized ?? -1) > 0;
const defaultMaint = !(ownerEarnings > 0) && maintBasePos;
const defaultNorm = !(ownerEarnings > 0) && !defaultMaint && normBasePos;
const runnable = (ownerEarnings != null && ownerEarnings > 0) || defaultMaint || defaultNorm;

// Book-value valuation: a bank or an insurer is worth a multiple of tangible book set
// by the return it earns on that book. Same math for both; only the wording differs,
// since an insurer's cycle is underwriting, not credit. Normalize over the record.
const isBank = fk === "bank" || fk === "insurer";
const isMReit = financialSubtype(company) === "mortgage-reit";
const finKind = isInsurer ? "insurer" : isMReit ? "mortgage REIT" : "bank";
const bankRisk = isInsurer
  ? "an underwriting cycle, a reserve shortfall or a bad year on the float"
  : isMReit
  ? "a rate shock, a spread that compresses or a credit cycle"
  : "a credit cycle, a rate shock or a bad acquisition";
const tEq = tangibleEquity(L);
const tbvps = tEq != null && shares ? tEq / shares : null;
const bvpsB = L.stockholdersEquity != null && shares ? L.stockholdersEquity / shares : null;
const epsB = L.netIncome != null && shares ? L.netIncome / shares : null;
const rotceH = (company.history || [])
  .map((h) => { const t = tangibleEquity(h.lines); return h.lines.netIncome != null && t && t > 0 ? h.lines.netIncome / t : null; })
  .filter((v) => v != null);
const rotceMed = rotceH.length >= 3 ? median(rotceH) : null;
const bankRunnable = isBank && tbvps != null && tbvps > 0 && rotceMed != null;
// Delivered tangible-book-per-share growth, the record anchor for the bank/insurer growth dial.
const tbvpsPairs = (company.history || [])
  .map((h) => { const t = tangibleEquity(h.lines); const s = h.lines.sharesDiluted; return { fy: h.fy, v: t != null && s ? t / s : null }; })
  .filter((p) => p.v != null);
const tbvpsH = tbvpsPairs.map((p) => p.v);
const tbvGrowthRaw = trendGrowth(tbvpsH.slice(-6));
const tbvWin = sparkWin(tbvpsH, 5, tbvps);
const tbvRange = winRangeYrs(tbvpsPairs);

// REIT valuation: a property trust is priced on a multiple of funds from operations,
// its cash earnings once property depreciation is added back.
const isReit = fk === "reit";
const ffops = ffoPerShare(L);
const dpsReit = L.dividendsPaid != null && shares ? Math.abs(L.dividendsPaid) / shares : null;
const ffopsPairs = (company.history || []).map((h) => ({ fy: h.fy, v: ffoPerShare(h.lines) })).filter((p) => p.v != null);
const ffopsH = ffopsPairs.map((p) => p.v);
const ffoGrowthRaw = trendGrowth(ffopsH.slice(-6));
const ffoWin = sparkWin(ffopsH, 5, ffops);
const ffoRange = winRangeYrs(ffopsPairs);
const reitGrowthPct = ffoGrowthRaw == null ? 3 : Math.max(0, Math.min(8, Math.round(ffoGrowthRaw * 100)));
const reitRunnable = isReit && ffops != null && ffops > 0 && shares != null && shares > 0;

// Negative-owner-earnings mode: a reverse-DCF can't grow a negative base, so we flip
// the question to the future profitability the price demands. Inputs: revenue and its
// recent growth, the only honest base when there are no earnings yet.
const rev = L.revenue;
const revPairs = (company.history || []).map((h) => ({ fy: h.fy, v: h.lines.revenue })).filter((p) => p.v != null);
const revH = revPairs.map((p) => p.v);
const gRevRaw = trendGrowth(revH.slice(-6));
const revWin = sparkWin(revH, 5, company.ttm?.lines?.revenue);
const revRange = winRangeYrs(revPairs);
const negMode = !runnable && !offModel && rev != null && rev > 0 && shares != null && shares > 0;
const gRevPct = gRevRaw == null ? 15 : Math.max(0, Math.min(45, Math.round((gRevRaw * 100) / 5) * 5));
const oeMarginNow = ownerEarnings != null && rev ? ownerEarnings / rev : null;
// Negative owner earnings come in two very different kinds: a genuine loss, and a
// profitable business whose capital spending currently outruns its operating cash (a
// build-out, common to utilities, railroads, telecoms). The tool must not call the second
// a "loss"; net income sets which framing is honest.
const niNow = L.netIncome ?? company.lines?.netIncome ?? null;
const profitableNeg = niNow != null && niNow > 0;

const report = moatReport(company);
const oeGrowth = report?.facts.find((f) => f.label === "Owner earnings growth")?.value ?? null;
// Delivered owner-earnings growth over a recent 5-year window, beside the full record: a
// full-record CAGR can smooth over a recent acceleration or fade, so the shorter read sits next
// to it. Same maintenance-based owner-earnings series (ownerEarningsAbs) and the same
// 2-year-averaged-endpoint method the durability card's figure uses, read over each window, so the
// two compare cleanly. Only shown when the record runs past five years, else it just repeats it.
const oeAbsHist = (company.history || [])
  .filter((h) => h?.lines?.revenue != null)
  .map((h) => ({ fy: h.fy, v: ownerEarningsAbs(h.lines, company) }))
  .filter((p) => p.v != null);
const deliveredOe = (pts) => {
  if (pts.length < 4) return null;
  const early = (pts[0].v + pts[1].v) / 2;
  const late = (pts[pts.length - 1].v + pts[pts.length - 2].v) / 2;
  const yrs = pts[pts.length - 1].fy - pts[0].fy;
  return early > 0 && late > 0 && yrs > 0 ? Math.pow(late / early, 1 / yrs) - 1 : null;
};
const recYrs = report?.years?.length ?? oeAbsHist.length;
const gDeliv5 = oeAbsHist.length > 5 ? deliveredOe(oeAbsHist.slice(-5)) : null;
const gFmt = (v) => (v == null ? "—" : `${v >= 0 ? "+" : "−"}${Math.abs(v * 100).toFixed(0)}%/yr`);
// A turnaround the CAGRs can't read: when owner earnings cross from losses to profit there's no
// full-record (or 5-year) CAGR to take — you can't annualize a move from negative to positive. But
// a business whose owner earnings have turned positive and are climbing (Unity: a loss through 2022,
// then $179M → $463M) has delivered something worth showing, not a blank. So when no CAGR exists we
// read the growth over the most recent unbroken run of positive years and label it from where it
// began, so the turn reads as a turn. It is not fed into the reference value: a rate off a low,
// just-positive base isn't one it's honest to extrapolate ten years out, which the 30% cap there enforces.
const recentOe = (oeGrowth == null) ? (() => {
  let i = oeAbsHist.length - 1;
  while (i >= 0 && oeAbsHist[i].v > 0) i--;
  const run = oeAbsHist.slice(i + 1);
  if (run.length < 2) return null;
  const yrs = run[run.length - 1].fy - run[0].fy;
  return yrs > 0 ? { g: Math.pow(run[run.length - 1].v / run[0].v, 1 / yrs) - 1, fromFy: run[0].fy } : null;
})() : null;
// The actual fiscal-year endpoints behind each delivered-growth window, shown in place of a bare
// "5 yr" / "10 yr" so the reader sees exactly which years the CAGR was read over (e.g. ’16→’25),
// rather than a trailing count whose start year is left to guess. Each range is the inclusive span
// of the same window its CAGR is computed over: the recent five-point window, and the full record.
const range5 = gDeliv5 != null && oeAbsHist.length >= 5
  ? `${yy(oeAbsHist[oeAbsHist.length - 5].fy)}→${yy(oeAbsHist[oeAbsHist.length - 1].fy)}`
  : null;
const recRange = oeGrowth != null && oeAbsHist.length >= 2
  ? `${yy(oeAbsHist[0].fy)}→${yy(oeAbsHist[oeAbsHist.length - 1].fy)}`
  : null;
// Label and value for the delivered-growth row: the full record where a CAGR exists, else the
// recent positive run for a turnaround, else withheld.
const dLabel = oeGrowth != null
  ? (recRange ? `Owner-earnings growth · ${recRange}`
     : gDeliv5 != null ? `Owner-earnings growth · ${recYrs} yr`
     : "Owner-earnings growth, delivered")
  : recentOe != null ? `Owner-earnings growth · since FY${recentOe.fromFy}`
  : "Owner-earnings growth, delivered";
const dValue = oeGrowth != null ? `${oeGrowth.replace("/yr", "")}/yr`
  : recentOe != null ? gFmt(recentOe.g)
  : "—";
const name = company.name || company.ticker;
const pctS = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${Math.abs(v * 100).toFixed(dp)}%`);
// The risk-free anchor for Graham's bond test: the 10-year Treasury, fetched on the daily refresh
// (public-domain government data), prefilled as an editable default. Dated, so it never reads as live.
const bondDefault = rates?.tenYear != null ? rates.tenYear : null;
const bondAsOf = rates?.asOf ? new Date(rates.asOf).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric", timeZone: "UTC" }) : null;
---

<section class="val">
  <div class="head">
    <h3 class="secTitle">What the price implies</h3>
    <span class="tag">{bankRunnable ? "price / tangible book" : reitRunnable ? "price / FFO" : "reverse-DCF"}</span>
  </div>

  {isADR ? (
    <p class="adrWarn">
      <b>Enter the home-market price, not the US ADR quote.</b> {name} reports in <b>{ccy}</b>,
      and every figure here — owner earnings, book value, the share count — is on that
      {ccy === "USD" ? " ordinary-share" : ` ${ccy}, ordinary-share`} basis. Enter the price on the
      same basis: the local-exchange quote per ordinary share{ccy === "USD" ? "" : ` in ${ccy}`}.
      A US ADR price in dollars bundles the ADR-to-ordinary ratio{ccy === "USD" ? "" : " and the exchange rate"},
      so it will not reconcile with these figures and would throw the multiple off.
    </p>
  ) : null}

  {offModel ? (
    reitRunnable ? (
      <div id="valBoxReit" data-ffops={ffops} data-dps={dpsReit ?? ""} data-name={name} data-sym={sym}>
        <p class="intro">A REIT is priced on a multiple of its <b>funds from operations</b> (FFO), the cash it earns once the depreciation on its buildings is added back. Type today&rsquo;s price; we show the multiple you would pay and the income and growth it implies. Nothing is stored.</p>
        <div class="priceRow">
          <label for="pxr">Today&rsquo;s price</label>
          <span class="dollar">{sym}</span>
          <input id="pxr" type="number" inputmode="decimal" step="0.01" min="0" placeholder="e.g. 55.00" />
        </div>
        <p class="lede" id="ledeR">Enter a price above to run it.</p>
        <div class="compare">
          <div class="cmp"><span class="cl">Price / FFO</span><span class="cv hot" id="pffo">—</span></div>
          <div class="cmp"><span class="cl">Justified by growth</span><span class="cv" id="justpffo">—</span></div>
          <div class="cmp"><span class="cl">Dividend yield</span><span class="cv" id="dyR">—</span></div>
        </div>
        <div class="compare ref">
          <div class="cmp"><span class="cl">Reference value / share</span><span class="cv hot" id="refVR">—</span></div>
          <div class="cmp"><span class="cl">…less a 30% margin of safety</span><span class="cv" id="refMosR">—</span></div>
        </div>
        <div class="dials">
          <span class="dialsLbl">The assumptions, turn the dials</span>
          <label>Discount rate <output id="rOutR">8%</output><input id="rR" type="range" min="5" max="12" step="0.5" value="8" /></label>
          <label>FFO / share growth <output id="gOutR">{reitGrowthPct}%</output><input id="gR" type="range" min="0" max="8" step="0.5" value={reitGrowthPct} /></label>
          <DeliveredGrowth cagr={ffoGrowthRaw} series={ffoWin} label="FFO / share, delivered" range={ffoRange} />
        </div>
        <p class="dialsNote">The justified multiple is 1 ÷ (discount rate − growth), a perpetuity on FFO. At an 8% discount and 3% growth, a REIT is worth about 20× FFO. Raise the discount rate and the multiple falls: the same interest-rate gravity that pulls on every yield asset.</p>
        <p class="foot">FFO about ${ffops.toFixed(2)} per share on {(shares / 1e6).toFixed(0)}M shares. The reference value applies the multiple the dials justify to FFO per share — a yardstick, not a price target. FFO here adds back depreciation and removes property-sale gains, the NAREIT method; it does not net out maintenance capex (AFFO), occupancy or lease terms, which the 10-K does.</p>
      </div>
    ) : bankRunnable ? (
      <div id="valBoxBank" data-tbvps={tbvps} data-bvps={bvpsB} data-rotce={rotceMed} data-eps={epsB ?? ""} data-name={name} data-cycle={isInsurer ? "underwriting cycle" : "credit cycle"} data-sym={sym}>
        <p class="intro">{isInsurer ? "An" : "A"} {finKind} is worth a multiple of its <b>tangible book value</b>, and the multiple it deserves is set by the return it earns on that book. Type today&rsquo;s price; we show what you would be paying against what {name}&rsquo;s record justifies. Nothing is stored; the number stays in your browser.</p>
        <div class="priceRow">
          <label for="pxb">Today&rsquo;s price</label>
          <span class="dollar">{sym}</span>
          <input id="pxb" type="number" inputmode="decimal" step="0.01" min="0" placeholder="e.g. 250.00" />
        </div>
        <p class="lede" id="ledeB">Enter a price above to run it.</p>
        <div class="compare">
          <div class="cmp"><span class="cl">Price / tangible book</span><span class="cv hot" id="ptbv">—</span></div>
          <div class="cmp"><span class="cl">Justified by the return</span><span class="cv" id="justptbv">—</span></div>
          <div class="cmp"><span class="cl">Normalized return on tangible equity</span><span class="cv">{pctS(rotceMed)}</span></div>
        </div>
        <div class="compare ref">
          <div class="cmp"><span class="cl">Reference value / share</span><span class="cv hot" id="refVB">—</span></div>
          <div class="cmp"><span class="cl">…less a 30% margin of safety</span><span class="cv" id="refMosB">—</span></div>
        </div>
        <div class="compare gate">
          <div class="cmp"><span class="cl">Price / book</span><span class="cv" id="pbBank">—</span></div>
          <div class="cmp"><span class="cl">Earnings yield</span><span class="cv" id="eyBank">—</span></div>
          <div class="cmp"><span class="cl">P/E</span><span class="cv" id="peBank">—</span></div>
        </div>
        <div class="dials">
          <span class="dialsLbl">The assumptions, turn the dials</span>
          <label>Cost of equity <output id="coeOut">10%</output><input id="coeB" type="range" min="8" max="14" step="0.5" value="10" /></label>
          <label>Long-term growth <output id="gOutB">3%</output><input id="gB" type="range" min="0" max="6" step="0.5" value="3" /></label>
          <DeliveredGrowth cagr={tbvGrowthRaw} series={tbvWin} label="Tangible book / share, delivered" range={tbvRange} />
          <p class="dialsNote">The justified multiple is (return on tangible equity − growth) ÷ (cost of equity − growth). {isInsurer ? "An" : "A"} {finKind} earning exactly its cost of equity is worth about one times tangible book; every point of durable excess return above that is worth paying up for. Raise the cost of equity and the justified multiple falls: that is interest-rate gravity on {isInsurer ? "an" : "a"} {finKind}.</p>
        </div>
        <p class="foot">Tangible book {$(tEq)} on {(shares / 1e6).toFixed(0)}M shares, a {pctS(rotceMed)} normalized return on it. The reference value applies the multiple that return justifies to tangible book — a yardstick to weigh the price against, never a target. It assumes the {finKind} keeps earning that return; {bankRisk} changes it, which is what the record and the 10-K are for.</p>
      </div>
    ) : (
      <p class="note">A {sector.label.toLowerCase()} isn't read on an owner-earnings DCF, its economics live on the balance sheet (book value, the return earned on it, and the cash the assets throw off). We don't force this lens where it doesn't belong.</p>
    )
  ) : !runnable ? (
    negMode ? (
      <div id="valBoxNeg" data-rev={rev} data-shares={shares} data-netdebt={netDebt} data-name={name} data-oem={oeMarginNow ?? ""} data-profitable={profitableNeg ? "1" : "0"} data-sym={sym}>
        {profitableNeg ? (
          <p class="intro">{name} is <b>profitable</b>, but owner earnings are <b>negative</b> this year because capital spending currently outruns operating cash, a build-out, so the owner-earnings reverse-DCF has no positive base to grow. We read the price from both ends instead: type a price to see the steady-state profitability it <b>demands</b>, then set the mature margin you would actually <b>believe</b> for a reference value to weigh it against. Nothing is stored.</p>
        ) : (
          <p class="intro">Owner earnings are <b>negative</b> today, so the usual reverse-DCF has nothing to grow. That is exactly when a price makes its boldest promise, so we read it from both ends: type a price to see the future profitability it <b>demands</b>, then set the mature margin you would actually <b>believe</b> to get a reference value to weigh that price against. Nothing is stored.</p>
        )}
        <div class="priceRow">
          <label for="pxn">Today&rsquo;s price</label>
          <span class="dollar">{sym}</span>
          <input id="pxn" type="number" inputmode="decimal" step="0.01" min="0" placeholder="e.g. 30.00" />
        </div>
        <p class="lede" id="ledeN">Enter a price to run it.</p>
        <div class="compare">
          <div class="cmp"><span class="cl">Owner earnings it must reach</span><span class="cv hot" id="reqOE">—</span></div>
          <div class="cmp"><span class="cl">Margin the price demands</span><span class="cv hot" id="reqM">—</span></div>
          <div class="cmp"><span class="cl">Owner-earnings margin today</span><span class="cv neg">{pctS(oeMarginNow)}</span></div>
        </div>
        <div class="compare ref">
          <div class="cmp"><span class="cl">On the margin you would believe</span><span class="cv" id="refMN">—</span></div>
          <div class="cmp"><span class="cl">Reference value / share</span><span class="cv hot" id="refVN">—</span></div>
          <div class="cmp"><span class="cl">…less a 30% margin of safety</span><span class="cv" id="refMosN">—</span></div>
        </div>
        <div class="dials">
          <span class="dialsLbl">The assumptions, turn the dials</span>
          <label>Discount rate <output id="rOutN">9%</output><input id="rN" type="range" min="4" max="15" step="0.5" value="9" /></label>
          <label>Years to get there <output id="nOutN">10</output><input id="nN" type="range" min="5" max="15" step="1" value="10" /></label>
          <label>Revenue growth <output id="grOutN">{gRevPct}%</output><input id="grN" type="range" min="0" max="45" step="5" value={gRevPct} /></label>
          <DeliveredGrowth cagr={gRevRaw} series={revWin} label="Revenue, delivered" range={revRange} />
          <label>Mature owner-earnings margin <output id="mmOutN">15%</output><input id="mmN" type="range" min="3" max="40" step="1" value="15" /></label>
        </div>
        <p class="foot">Two reads of one future. From your price: the owner earnings the company must reach, valued at a mature multiple and discounted back at your rate, expressed as the margin it implies on revenue grown at your rate. From your belief: the mature margin you would credit, turned into a reference value per share and netted against {netDebt >= 0 ? `net debt ${$(netDebt)}` : `net cash ${$(-netDebt)}`} — a yardstick, never a target. When the margin the price demands runs above the one you would believe, you are paying for a future taken on faith. For a deep cyclical at a trough, normalized through-cycle earnings are the better lens; this mode is for the genuinely unprofitable, and for the profitable business whose capital spending currently outruns its cash.</p>
      </div>
    ) : (
      <p class="note">A reverse-DCF needs positive owner earnings, or at least revenue, to anchor to, there's no clean base here. Judge this one on assets or normalized earnings, not a growth model.</p>
    )
  ) : (
    <div id="valBox" data-oe={ownerEarnings} data-oe3={oeNormalized ?? ""} data-oemaint={ownerEarningsMaint ?? ""} data-oemaint3={oe3Maint ?? ""} data-sbc={sbcLatest ?? ""} data-gdeliv={(gDeliv5 ?? gDeliv) ?? ""} data-netdebt={netDebt} data-shares={shares} data-haveshares={haveShares ? "1" : "0"} data-name={name} data-eps3={eps3 ?? ""} data-bvps={bvps ?? ""} data-rev={rev ?? ""} data-grev={gRevRaw ?? ""} data-ni={niNow ?? ""} data-sym={sym} data-bonddefault={bondDefault ?? ""}>
      <p class="intro">
        A price is the one input we don't pull, <b>you bring it</b>. Type today's close (read it off any
        broker or quote site) and see the owner-earnings growth you'd have to believe to justify it, set
        beside what {name} has actually delivered. Nothing is stored; the number stays in your browser.
      </p>

      {(defaultMaint || defaultNorm) ? (
        <p class="basenote">
          {name}&rsquo;s latest year shows <b>negative owner earnings</b>{defaultMaint
            ? " — the mark of a build-out, where total capital spending outruns the cash the business throws off today"
            : ", a cyclical trough"}. So the tool opens on the {defaultMaint ? "steady-state base — maintenance capex in place of the build-out spend" : "through-cycle base"}, the cash it would earn at rest, so the normalize controls actually work; clear the toggle below to read the latest year exactly as reported.
        </p>
      ) : null}

      <div class="priceRow">
        <label for="px">Today&rsquo;s price</label>
        <span class="dollar">{sym}</span>
        <input id="px" type="number" inputmode="decimal" step="0.01" min="0" placeholder="e.g. 220.50" />
      </div>

      {!haveShares ? (
        <div class="priceRow shRow">
          <label for="shInput">Shares outstanding</label>
          <input id="shInput" type="number" inputmode="decimal" step="0.1" min="0" placeholder="e.g. 87.5" />
          <span class="unit">million</span>
          <span class="shWhy">— the filing tags {name}&rsquo;s share count where we can&rsquo;t read it, so bring it too (any quote page lists it); the rest is from the record.</span>
        </div>
      ) : null}

      {cycleRead ? (
        <p class="cyclenote">
          Through the cycle, {name} earns about <b>{$(ep.normOE)}</b> on its {pctS(ep.normOeMargin, 1)} median
          owner-earnings margin. This year&rsquo;s {pctS(ep.latestOeMargin, 1)} margin runs <b>{cycleRead === "at" ? "in line with" : cycleRead}</b> that{cycleRead === "above" ? " — so the reported figure may flatter a peak you'd be paying on" : cycleRead === "below" ? " — so the reported figure may understate a lean year" : ""}. <b>Normalize</b>, below, values the price on that through-cycle figure rather than the latest year.
        </p>
      ) : null}

      <div class="bases" role="group" aria-label="Make the owner-earnings base honest">
        <span class="basesLbl">Base</span>
        <label class="tog"><input type="checkbox" id="oeNorm" checked={defaultNorm} /> Normalize · through-cycle{oeNormalized != null ? <> (<b>{$(oeNormalized)}</b>)</> : null}</label>
        <label class="tog"><input type="checkbox" id="oeSbc" /> Net of stock comp{sbcLatest > 0 ? <> (−<b>{$(sbcLatest)}</b>)</> : null}</label>
        {offerMaint ? <label class="tog"><input type="checkbox" id="oeMaint" checked={defaultMaint} /> Steady-state · maintenance capex{ownerEarningsMaint != null ? <> (<b>{$(ownerEarningsMaint)}</b>)</> : null}</label> : null}
      </div>
      <p class="baseUsed" id="baseUsed" aria-live="polite">—</p>

      <p class="lede" id="lede">Enter a price above to run it.</p>

      <div class="compare">
        <div class="cmp"><span class="cl">Implied by the price</span><span class="cv hot" id="impG">—</span></div>
        {gDeliv5 != null ? <div class="cmp"><span class="cl">Owner-earnings growth · {range5 ?? "5 yr"}</span><span class="cv">{gFmt(gDeliv5)}</span></div> : null}
        <div class="cmp"><span class="cl">{dLabel}</span><span class="cv">{dValue}</span>{oeWin ? <Sparkline series={oeWin} klass="cmpSpark" /> : null}</div>
        <div class="cmp"><span class="cl">Multiple paid</span><span class="cv" id="multPaid">—</span></div>
        <div class="cmp"><span class="cl">Owner-earnings yield</span><span class="cv" id="oeY">—</span></div>
      </div>

      <div class="ops" id="ops" hidden>
        <p class="opsMc" id="opsMc"></p>
        <p class="impOps" id="impOps" hidden></p>
        <div class="marginRow" id="marginRow" hidden>
          <label>If the owner-earnings margin matured to <output id="mmOut">25%</output><input id="mmDial" type="range" min="3" max="50" step="1" value="25" aria-label="Mature owner-earnings margin" /></label>
        </div>
        <p class="reqRev" id="reqRev" hidden></p>
      </div>

      <div class="compare ref" id="refRow" hidden>
        <div class="cmp"><span class="cl">On the growth it delivered</span><span class="cv" id="refG">—</span></div>
        <div class="cmp"><span class="cl">Justified multiple</span><span class="cv" id="justMult">—</span></div>
        <div class="cmp"><span class="cl">Reference value / share</span><span class="cv hot" id="refV">—</span></div>
        <div class="cmp"><span class="cl">…less a 30% margin of safety</span><span class="cv" id="refMos">—</span></div>
      </div>

      {eps3 != null && bvps != null ? (
        <>
          <div class="compare gate">
            <div class="cmp"><span class="cl">P/E (3-yr earnings)</span><span class="cv" id="pe">—</span></div>
            <div class="cmp"><span class="cl">P/B</span><span class="cv" id="pb">—</span></div>
            <div class="cmp"><span class="cl">Graham’s price gate</span><span class="cv" id="ggate">—</span></div>
          </div>
          <p class="gatenote">Graham capped the multiple at 15×; Buffett and Munger let that rule go, a wonderful business can deserve 50× if the thesis holds. Read it as the bargain-hunter's floor, not a ceiling on good sense.</p>
        </>
      ) : null}

      <div class="bondBox">
        <div class="bondHead">
          <span class="bondTitle">Against a high-grade bond — Graham’s yardstick</span>
          <span class="bondField"><span class="bondLbl">bond yield</span><input id="bondY" type="number" inputmode="decimal" step="0.1" min="0" placeholder="e.g. 4.5" aria-label="High-grade bond yield, percent" /><span class="bondPct">%</span></span>
        </div>
        {bondAsOf ? <p class="bondAsOf">Prefilled with the 10-year Treasury ({bondDefault}%, as of {bondAsOf}) — the public-domain risk-free rate. Edit it for today’s exact figure, or a AAA corporate yield.</p> : null}
        <p class="bondLede" id="bondLede">Graham measured a stock against the bond you could own instead — the heart of his margin of safety. Enter a price above to weigh the owner-earnings yield against this bond.</p>
        <div class="compare bondCmp" id="bondCmp" hidden>
          <div class="cmp"><span class="cl">Owner-earnings yield</span><span class="cv hot" id="eyB">—</span></div>
          <div class="cmp"><span class="cl">High-grade bond yield</span><span class="cv" id="bondYOut">—</span></div>
          <div class="cmp"><span class="cl">Margin over the bond</span><span class="cv" id="spreadB">—</span></div>
        </div>
      </div>

      <div class="dials">
        <span class="dialsLbl">The assumptions, turn the dials</span>
        <label>Discount rate <output id="rOut">9%</output><input id="r" type="range" min="4" max="15" step="0.5" value="9" /></label>
        <label>Years of high growth <output id="nOut">10</output><input id="n" type="range" min="5" max="15" step="1" value="10" /></label>
        <label>Terminal growth <output id="gOut">2.5%</output><input id="g" type="range" min="0" max="4" step="0.25" value="2.5" /></label>
        <p class="dialsNote">The discount rate is your interest rate, what a dollar years from now is worth today, anchored to the long-term Treasury yield ({bondDefault != null ? <>about {bondDefault}% as of {bondAsOf}</> : "~4–5% today"}, plus whatever premium you want for risk). Drag it toward the risk-free rate and watch how much growth the price suddenly “needs”: interest rates are gravity on valuations.</p>
      </div>

      <div class="sens" id="sens" hidden>
        <span class="sensLbl">What the record justifies — the owner-earnings multiple, across the dials</span>
        <div class="sensWrap"><table class="sensTbl" id="sensTbl" aria-label="Justified owner-earnings multiple by discount rate and years of high growth"></table></div>
        <p class="sensNote" id="sensNote"></p>
      </div>

      <p class="foot">
        {offerMaint ? "Free cash flow" : "Owner earnings"} {$(ownerEarnings)} {haveShares ? `on ${(shares / 1e6).toFixed(0)}M diluted shares` : "on the share count you enter above"}; net {netDebt >= 0 ? `debt ${$(netDebt)}` : `cash ${$(-netDebt)}`}.
        The base is the latest year by default; <b>Normalize</b> values it on the through-cycle median owner-earnings margin (Graham's method, to avoid paying on a peak year), and <b>Net of stock comp</b> treats option pay as the expense it is.{offerMaint ? (<> Capex ({$(Math.abs(capex))}) runs well above depreciation ({$(dep)}), so this is a build-out; <b>Steady-state</b> swaps total capex for maintenance (≈ depreciation), lifting the base to about {$(ownerEarningsMaint)}, the cash it would throw off if it stopped expanding.</>) : null}
        The reference value extrapolates the owner-earnings growth the record actually delivered, netted against debt — a yardstick, never a price target. The tool says what you'd have to <em>believe</em>, not what the company is <em>worth</em>.
      </p>
    </div>
  )}
</section>

<style>
  .val { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .tag { font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; }

  .note { font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--ink-dim); margin: 12px 0 0; line-height: 1.5; max-width: 66ch; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--muted); margin: 12px 0 0; line-height: 1.55; max-width: 68ch; }
  .basenote { font-family: var(--serif); font-size: 13.5px; line-height: 1.55; color: var(--ink-soft); background: var(--accent-tint); border-left: 2px solid var(--accent); padding: 9px 13px; margin: 12px 0 0; max-width: 72ch; }
  /* Graham's through-cycle read, folded in from the former earnings-power section: where this year
     sits against its own median margin, set quietly above the Normalize toggle it explains. */
  .cyclenote { font-family: var(--serif); font-size: 13.5px; line-height: 1.55; color: var(--ink-soft); margin: 14px 0 0; max-width: 74ch; }
  .cyclenote b { font-style: normal; color: var(--ink); font-weight: 600; }
  /* ADR price-basis warning: a foreign filer's figures are in its home currency on the ordinary-
     share count, so the reader must not enter a US ADR quote. Flagged, not hidden. */
  .adrWarn { font-size: 13.5px; line-height: 1.55; color: var(--ink-soft); background: var(--warn-tint, var(--accent-tint)); border-left: 3px solid var(--warn); padding: 10px 13px; margin: 14px 0 0; max-width: 74ch; }
  .adrWarn b { color: var(--ink); }
  .basenote b { color: var(--ink); }
  .intro b { font-style: normal; color: var(--ink); }

  .priceRow { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin: 16px 0 0; }
  .priceRow label { font-size: 13px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .priceRow .dollar { font-size: 20px; font-weight: 700; color: var(--ink); }
  .priceRow input { width: 140px; padding: 8px 10px; border: 1px solid var(--rule-strong); font-family: var(--sans); font-size: 18px; font-variant-numeric: tabular-nums; background: var(--surface); }
  .shRow { margin-top: 10px; }
  .shRow input { width: 110px; }
  .shRow .unit { font-size: 13px; color: var(--muted); }
  .shWhy { flex-basis: 100%; font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); line-height: 1.5; margin-top: 3px; max-width: 70ch; }

  .lede { font-family: var(--serif); font-size: clamp(16px, 2.3vw, 18.5px); line-height: 1.5; margin: 14px 0 0; max-width: 66ch; min-height: 1.5em; }
  .lede b { font-weight: 600; }
  .hot { color: var(--accent); font-variant-numeric: tabular-nums; }
  .cv.neg { color: var(--bad); }
  .lede .bad { color: var(--bad); }

  .bases { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 16px; margin: 12px 0 0; }
  .basesLbl { font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: var(--muted); font-weight: 700; }
  .tog { display: inline-flex; align-items: center; gap: 6px; font-size: 12.5px; color: var(--ink-dim); cursor: pointer; user-select: none; }
  .tog input { accent-color: var(--accent); cursor: pointer; }
  .tog b { font-weight: 600; color: var(--ink); font-variant-numeric: tabular-nums; }
  /* The owner-earnings figure actually feeding the model, named and updated as the toggles change —
     so "Normalize" is never a black box: you see the through-cycle number it switched the base to. */
  .baseUsed { font-family: var(--sans); font-size: 13.5px; color: var(--ink-dim); margin: 10px 0 0; line-height: 1.5; }
  .baseUsed b { color: var(--ink); font-weight: 700; font-variant-numeric: tabular-nums; }
  .compare { display: flex; flex-wrap: wrap; gap: 10px 28px; margin: 16px 0 0; padding: 12px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .compare[hidden] { display: none; } /* the flex rule above otherwise defeats the hidden attribute, leaving an empty reference row of dashes */
  .compare.ref { border-top: 0; margin-top: 0; padding-top: 0; }
  .cmp { display: flex; flex-direction: column; }
  .cl { font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .cv { font-size: 20px; font-weight: 700; font-variant-numeric: tabular-nums; margin-top: 2px; }
  .cmpSpark { margin-top: 6px; opacity: 0.9; }

  .dials { margin: 16px 0 0; }
  .dialsLbl { font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .dials label { display: flex; align-items: center; gap: 10px; margin: 9px 0 0; font-size: 13.5px; color: var(--ink-dim); }
  .dials output { font-weight: 700; font-variant-numeric: tabular-nums; min-width: 44px; color: var(--ink); }
  .dials input[type="range"] { flex: 1 1 auto; max-width: 320px; accent-color: var(--accent); }
  .dialsNote { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 10px 0 0; line-height: 1.5; max-width: 70ch; }

  /* The operating picture behind a price: implied market cap and the multiples it is, the owner
     earnings it must reach, and — at a margin you set — the revenue that demands. */
  .ops { background: var(--surface-2); border-left: 2px solid var(--accent); padding: 12px 15px; margin: 14px 0 0; max-width: 80ch; }
  .ops[hidden] { display: none; }
  .opsMc, .impOps, .reqRev { font-family: var(--serif); font-size: 14px; line-height: 1.55; color: var(--ink-soft); margin: 0; }
  .impOps, .reqRev, .marginRow { margin-top: 9px; }
  .opsMc[hidden], .impOps[hidden], .reqRev[hidden], .marginRow[hidden] { display: none; }
  .ops b { font-weight: 600; color: var(--ink); }
  .ops b.hot { color: var(--accent); }
  .marginRow label { display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--ink-dim); font-family: var(--sans); flex-wrap: wrap; }
  .marginRow output { font-weight: 700; font-variant-numeric: tabular-nums; min-width: 40px; color: var(--ink); }
  .marginRow input[type="range"] { flex: 1 1 200px; max-width: 280px; accent-color: var(--accent); }

  /* The sensitivity grid: justified owner-earnings multiple across discount rate × horizon. */
  .sens { margin: 18px 0 0; }
  .sens[hidden] { display: none; }
  .sensLbl { font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .sensWrap { overflow-x: auto; margin: 10px 0 0; }
  .sensTbl { border-collapse: collapse; font-variant-numeric: tabular-nums; font-size: 13px; }
  .sensTbl th, .sensTbl td { border: 1px solid var(--rule); padding: 5px 13px; text-align: right; white-space: nowrap; }
  .sensTbl thead th { color: var(--muted); font-weight: 600; font-size: 11px; letter-spacing: 0.03em; }
  .sensTbl tbody th { color: var(--muted); font-weight: 600; }
  .sensTbl td { color: var(--ink-dim); }
  .sensTbl td.now { background: var(--accent-tint); color: var(--accent); font-weight: 700; }
  .sensNote { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 9px 0 0; line-height: 1.5; max-width: 72ch; }

  .gatenote { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 8px 0 0; line-height: 1.5; max-width: 70ch; }

  /* Graham's bond yardstick: the owner-earnings yield against the bond the reader could hold instead. */
  .bondBox { margin: 18px 0 0; padding: 13px 0 0; border-top: 1px solid var(--rule); }
  .bondHead { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .bondTitle { font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .bondField { display: inline-flex; align-items: baseline; gap: 6px; }
  .bondLbl { font-size: 11.5px; color: var(--muted); letter-spacing: 0.02em; }
  .bondField input { width: 66px; padding: 5px 8px; border: 1px solid var(--rule-strong); font-family: var(--sans); font-size: 14px; font-variant-numeric: tabular-nums; background: var(--surface); }
  .bondPct { font-size: 16px; font-weight: 700; color: var(--ink); }
  .bondAsOf { font-size: 11.5px; color: var(--muted); margin: 8px 0 0; line-height: 1.5; max-width: 78ch; }
  .bondLede { font-family: var(--serif); font-size: 13.5px; line-height: 1.55; color: var(--ink-soft); margin: 8px 0 0; max-width: 78ch; }
  .bondCmp { margin-top: 12px; }

  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 14px 0 0; line-height: 1.5; max-width: 70ch; }

  /* On a phone the price input wraps under its label rather than overflowing, and each dial's
     slider takes the full width below its label instead of being squeezed beside a long one. */
  @media (max-width: 520px) {
    .dials label { flex-wrap: wrap; }
    .dials input[type="range"] { flex-basis: 100%; max-width: none; }
  }
</style>

<script>
  import { pv, solve } from "../lib/reverseDcf.mjs";
  (function () {
    const box = document.getElementById("valBox");
    if (!box) return;
    const OE = parseFloat(box.dataset.oe), SH_DATA = parseFloat(box.dataset.shares), NAME = box.dataset.name || "this company";
    const SYM = box.dataset.sym || "$";
    const OE3 = parseFloat(box.dataset.oe3), SBC = parseFloat(box.dataset.sbc) || 0, GDELIV = parseFloat(box.dataset.gdeliv), NETDEBT = parseFloat(box.dataset.netdebt) || 0;
    const OEM = parseFloat(box.dataset.oemaint), OEM3 = parseFloat(box.dataset.oemaint3);
    const px = document.getElementById("px");
    // When the filing's share count is missing (Up-C / multi-class filers), the reader supplies it
    // in millions; otherwise SH comes straight from the record. Market cap can't be formed without it.
    const shInput = document.getElementById("shInput");
    const curSH = () => { if (SH_DATA > 0) return SH_DATA; const v = shInput ? parseFloat(shInput.value) : NaN; return v > 0 ? v * 1e6 : NaN; };
    const r = document.getElementById("r"), n = document.getElementById("n"), g = document.getElementById("g");
    const rOut = document.getElementById("rOut"), nOut = document.getElementById("nOut"), gOut = document.getElementById("gOut");
    const lede = document.getElementById("lede"), impG = document.getElementById("impG"), oeY = document.getElementById("oeY");
    const pe = document.getElementById("pe"), pb = document.getElementById("pb"), ggate = document.getElementById("ggate");
    // Graham's bond yardstick: the reader's high-grade bond yield, the owner-earnings yield set against it.
    const bondY = document.getElementById("bondY"), bondLede = document.getElementById("bondLede"), bondCmp = document.getElementById("bondCmp");
    const eyB = document.getElementById("eyB"), bondYOut = document.getElementById("bondYOut"), spreadB = document.getElementById("spreadB");
    const oeNorm = document.getElementById("oeNorm"), oeSbc = document.getElementById("oeSbc"), oeMaint = document.getElementById("oeMaint");
    const refRow = document.getElementById("refRow"), refG = document.getElementById("refG"), refV = document.getElementById("refV"), refMos = document.getElementById("refMos");
    const EPS3 = parseFloat(box.dataset.eps3), BVPS = parseFloat(box.dataset.bvps);
    const REV = parseFloat(box.dataset.rev), GREV = parseFloat(box.dataset.grev), NI = parseFloat(box.dataset.ni);
    const multPaid = document.getElementById("multPaid"), justMult = document.getElementById("justMult");
    const sens = document.getElementById("sens"), sensTbl = document.getElementById("sensTbl"), sensNote = document.getElementById("sensNote");
    const baseUsed = document.getElementById("baseUsed");
    const ops = document.getElementById("ops"), opsMc = document.getElementById("opsMc"), impOps = document.getElementById("impOps");
    const marginRow = document.getElementById("marginRow"), mmDial = document.getElementById("mmDial"), mmOut = document.getElementById("mmOut"), reqRev = document.getElementById("reqRev");

    const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
    const pcs = (v) => (v < 0 ? "−" : "") + Math.abs(v * 100).toFixed(1) + "%";
    const usd = (v) => { const a = Math.abs(v); const s = a >= 1e12 ? SYM + (a / 1e12).toFixed(2) + "T" : a >= 1e9 ? SYM + (a / 1e9).toFixed(1) + "B" : a >= 1e6 ? SYM + Math.round(a / 1e6) + "M" : SYM + Math.round(a); return v < 0 ? "(" + s + ")" : s; };

    // The sensitivity grid: the owner-earnings multiple the delivered growth justifies across a span of
    // discount rates (down) and high-growth horizons (across), so the reader sees the whole surface at
    // once — interest-rate gravity down a column, the price of a longer runway across a row — not just
    // the one cell their dials happen to land on.
    const R_ROWS = [0.06, 0.08, 0.1, 0.12], N_COLS = [5, 10, 15];
    const nearest = (arr, x) => arr.reduce((a, b) => (Math.abs(b - x) < Math.abs(a - x) ? b : a));
    function renderSens(gT, rrCur, NCur) {
      if (!sens || !sensTbl || isNaN(GDELIV)) { if (sens) sens.hidden = true; return; }
      const rN = nearest(R_ROWS, rrCur), nN = nearest(N_COLS, NCur);
      let html = "<thead><tr><th>disc · yrs</th>" + N_COLS.map((n) => "<th>" + n + "y</th>").join("") + "</tr></thead><tbody>";
      for (const rr of R_ROWS) {
        html += "<tr><th>" + (rr * 100).toFixed(0) + "%</th>";
        for (const n of N_COLS) {
          const m = rr > gT ? pv(GDELIV, rr, n, gT) : null;
          html += "<td" + (rr === rN && n === nN ? ' class="now"' : "") + ">" + (m != null ? m.toFixed(1) + "×" : "—") + "</td>";
        }
        html += "</tr>";
      }
      sensTbl.innerHTML = html + "</tbody>";
      sens.hidden = false;
      if (sensNote) sensNote.textContent = "Each cell is the owner-earnings multiple a " + pcs(GDELIV) + "/yr record justifies at that discount rate and horizon (then " + (gT * 100).toFixed(1) + "% forever). Your dials sit on the highlighted cell; set the price's multiple against it.";
    }

    // The base the whole tool runs on, made honest by the toggles: a 3-year average instead of
    // one noisy year; the steady-state base that subtracts maintenance capex (≈ depreciation)
    // instead of total capex, for a business mid-build-out; and/or net of the stock comp that
    // is a real cost to owners.
    function effOE() {
      const maint = oeMaint && oeMaint.checked && !isNaN(OEM);
      const norm = oeNorm && oeNorm.checked;
      let base = maint ? ((norm && OEM3 > 0) ? OEM3 : OEM) : ((norm && OE3 > 0) ? OE3 : OE);
      if (oeSbc && oeSbc.checked && SBC > 0) base -= SBC;
      return base;
    }

    function dials() {
      const rr = parseFloat(r.value) / 100, N = parseInt(n.value, 10), gT = parseFloat(g.value) / 100;
      rOut.textContent = r.value + "%"; nOut.textContent = N; gOut.textContent = parseFloat(g.value) + "%";
      return { rr, N, gT };
    }
    function setURL(v) { try { const u = new URL(location.href); v ? u.searchParams.set("px", v) : u.searchParams.delete("px"); history.replaceState(null, "", u); } catch (e) {} }

    // Graham's central test, made live: the owner-earnings yield (the equity yield a price buys) set
    // against the high-grade bond yield the reader supplies — the bond you could hold instead. The
    // margin between them is the margin of safety Graham measured in yield terms; and the discount
    // rate reads as that bond plus the premium you demand, Buffett's "interest rates are gravity."
    function bondView() {
      if (!bondY || !bondCmp || !bondLede) return;
      const BOND = parseFloat(bondY.value) / 100;
      const price = parseFloat(px.value), SH = curSH(), base = effOE();
      const haveEY = price > 0 && base > 0 && SH > 0;
      const EY = haveEY ? base / (price * SH) : null;
      if (!(BOND > 0) || !haveEY) {
        bondCmp.hidden = true;
        bondLede.textContent = !(BOND > 0)
          ? "Graham measured a stock against the bond you could own instead — the heart of his margin of safety. Enter today’s high-grade bond yield (the 10-year Treasury, or a AAA corporate) to weigh the owner-earnings yield against it. Nothing is stored."
          : "Enter a price above to set the owner-earnings yield, then this weighs it against the bond.";
        return;
      }
      const rr = parseFloat(r.value) / 100;
      bondCmp.hidden = false;
      eyB.textContent = pcs(EY);
      bondYOut.textContent = (BOND * 100).toFixed(2) + "%";
      const spread = EY - BOND;
      spreadB.textContent = (spread >= 0 ? "+" : "−") + Math.abs(spread * 100).toFixed(1) + " pts";
      spreadB.style.color = spread >= 0 ? "var(--good)" : "var(--bad)";
      const ratio = EY / BOND;
      let s;
      if (EY >= 2 * BOND) s = `The owner-earnings yield is about ${ratio.toFixed(1)}× the bond — comfortably above it, the wide cushion Graham looked for: you are paid far more to own the business than to hold the bond.`;
      else if (EY >= BOND) s = `The owner-earnings yield sits above the bond, but short of the roughly 2× cushion Graham’s defensive rule asked for. The margin over the bond is your pay for the equity’s risk; weigh whether it is enough.`;
      else s = `The owner-earnings yield is below the bond — today, the riskless bond pays more. The equity has to grow into that gap to earn its risk, which is exactly the growth the reverse-DCF above asks you to believe.`;
      const prem = rr - BOND;
      if (prem > 0.001) s += ` Your ${(rr * 100).toFixed(0)}% discount rate is this ${(BOND * 100).toFixed(2)}% bond plus about a ${(prem * 100).toFixed(1)}-point premium for the risk.`;
      bondLede.textContent = s;
    }

    function update() {
      bondView();
      const { rr, N, gT } = dials();
      const base = effOE();
      const SH = curSH();

      // Name the figure the model is actually running on, and update it as the toggles change, so
      // "Normalize" / "Steady-state" / "Net of stock comp" are never a black box: you see the number.
      if (baseUsed) {
        const maint = oeMaint && oeMaint.checked && !isNaN(OEM);
        const norm = oeNorm && oeNorm.checked;
        const sbc = oeSbc && oeSbc.checked && SBC > 0;
        const kind = maint ? (norm ? "steady-state owner earnings, 3-year average" : "steady-state owner earnings (maintenance capex)") : (norm ? "through-cycle (normalized) owner earnings" : "latest-year owner earnings");
        baseUsed.innerHTML = "Base in use: <b>" + usd(base) + "</b>" + (SH > 0 && isFinite(base / SH) ? " · <b>" + SYM + (base / SH).toFixed(2) + "</b>/share" : "") + " — " + kind + (sbc ? ", net of " + usd(SBC) + " stock comp" : "") + ".";
      }

      // Reference value: what the business is worth on the growth it actually delivered,
      // valued at your dials. A reference to weigh your price against, never a target; shown
      // only when the delivered growth is in a range it's honest to extrapolate.
      if (refRow) {
        if (!isNaN(GDELIV) && GDELIV >= -0.05 && GDELIV <= 0.30 && base > 0 && SH > 0 && rr > gT) {
          const mult = pv(GDELIV, rr, N, gT);
          const fairPx = (mult * base - NETDEBT) / SH;
          refRow.hidden = false;
          refG.textContent = pcs(GDELIV) + "/yr";
          if (justMult) justMult.textContent = mult.toFixed(1) + "×";
          refV.textContent = fairPx > 0 ? SYM + fairPx.toFixed(2) : "—";
          refMos.textContent = fairPx > 0 ? SYM + (fairPx * 0.7).toFixed(2) : "—";
          renderSens(gT, rr, N);
        } else { refRow.hidden = true; if (sens) sens.hidden = true; }
      }

      const price = parseFloat(px.value);
      if (!(price > 0)) {
        lede.textContent = "Enter a price above to run it."; impG.textContent = "—"; oeY.textContent = "—";
        if (multPaid) multPaid.textContent = "—"; if (ops) ops.hidden = true;
        if (pe) pe.textContent = "—"; if (pb) pb.textContent = "—"; if (ggate) { ggate.textContent = "—"; ggate.style.color = ""; }
        setURL(""); return;
      }
      if (!(SH > 0)) {
        lede.textContent = "Enter the shares outstanding above to run it."; impG.textContent = "—"; oeY.textContent = "—";
        if (multPaid) multPaid.textContent = "—"; if (ops) ops.hidden = true;
        if (pe) pe.textContent = "—"; if (pb) pb.textContent = "—"; if (ggate) { ggate.textContent = "—"; ggate.style.color = ""; }
        return;
      }
      const mc = price * SH, res = solve(mc / base, rr, N, gT);
      oeY.textContent = pcs(base / mc);
      if (multPaid) multPaid.textContent = (mc / base).toFixed(1) + "×";
      if (pe || pb || ggate) {
        const peV = EPS3 > 0 ? price / EPS3 : null, pbV = BVPS > 0 ? price / BVPS : null;
        if (pe) pe.textContent = peV != null ? peV.toFixed(1) + "×" : "n/m";
        if (pb) pb.textContent = pbV != null ? pbV.toFixed(1) + "×" : "n/m";
        if (ggate) {
          if (peV != null && pbV != null) { const ok = peV <= 15 && peV * pbV <= 22.5; ggate.textContent = ok ? "Clears" : "Above his line"; ggate.style.color = ok ? "var(--good)" : "var(--muted)"; }
          else { ggate.textContent = "n/m"; ggate.style.color = ""; }
        }
      }
      if (!res) { impG.textContent = "—"; lede.textContent = "Set the discount rate above the terminal rate."; return; }
      impG.textContent = res.cap ? "100%+/yr" : pcs(res.g) + "/yr";
      const P = SYM + price.toFixed(2);
      if (res.cap) lede.innerHTML = `At <b>${P}</b>, even <b class="hot">100%+/yr</b> growth for a decade can't justify the price on owner earnings alone.`;
      else if (res.g < 0) lede.innerHTML = `At <b>${P}</b>, the market is pricing owner earnings to <b>shrink ${pcs(res.g)}/yr</b> for ${N} years, priced for decline.`;
      else lede.innerHTML = `At <b>${P}</b>, the market is pricing <b>${esc(NAME)}</b> to grow owner earnings about <b class="hot">${pcs(res.g)}</b>/yr for ${N} years, then ${(gT * 100).toFixed(1)}% forever, discounted at ${(rr * 100).toFixed(0)}%.`;
      // The operating picture behind the price.
      if (ops) {
        ops.hidden = false;
        // Implied market cap, and the multiples that price is on each trailing figure an owner watches.
        let mcs = `At <b>${P}</b>, the implied market cap is <b class="hot">${usd(mc)}</b> — <b>${(mc / base).toFixed(1)}×</b> owner earnings`;
        if (NI > 0) mcs += `, <b>${(mc / NI).toFixed(1)}×</b> earnings`;
        if (REV > 0) mcs += `, <b>${(mc / REV).toFixed(1)}×</b> revenue`;
        if (opsMc) opsMc.innerHTML = mcs + ".";

        // Owner earnings the price implies by the terminal year, and what revenue must do to deliver
        // them — read both ways: at the delivered revenue growth, the margin it forces; and at a
        // margin you set, the revenue (and its growth) it forces. The capped/decline cases have no
        // honest end-state to read, so the operating lines fold away and only the multiples remain.
        const solved = !res.cap && res.g != null && isFinite(res.g) && res.g > 0;
        const oeN = solved ? base * Math.pow(1 + res.g, N) : null;
        if (solved && impOps) {
          let s = `To justify it, owner earnings would compound to about <b class="hot">${usd(oeN)}</b> by year ${N} — <b>${(oeN / base).toFixed(1)}×</b> today’s.`;
          if (REV > 0 && !isNaN(GREV) && GREV > -0.5) {
            const revN = REV * Math.pow(1 + GREV, N), margN = oeN / revN, margNow = base / REV;
            s += ` On revenue grown at its delivered ${pcs(GREV)}/yr to ${usd(revN)}, that is an owner-earnings margin near <b class="hot">${pcs(margN)}</b> (about ${pcs(margNow)} today).`;
          }
          impOps.innerHTML = s; impOps.hidden = false;
        } else if (impOps) impOps.hidden = true;

        if (solved && REV > 0 && marginRow && reqRev) {
          const mm = mmDial ? parseFloat(mmDial.value) / 100 : 0.25;
          if (mmOut) mmOut.textContent = (mm * 100).toFixed(0) + "%";
          const revReq = oeN / mm, grReq = Math.pow(revReq / REV, 1 / N) - 1;
          reqRev.innerHTML = `At a <b>${(mm * 100).toFixed(0)}%</b> mature owner-earnings margin, revenue must reach <b class="hot">${usd(revReq)}</b> by year ${N} — a <b class="hot">${pcs(grReq)}/yr</b> climb` + (!isNaN(GREV) && GREV > -0.5 ? ` (it has delivered ${pcs(GREV)}/yr)` : "") + ".";
          marginRow.hidden = false; reqRev.hidden = false;
        } else { if (marginRow) marginRow.hidden = true; if (reqRev) reqRev.hidden = true; }
      }
      setURL(px.value);
    }
    [px, r, n, g, shInput, mmDial].forEach((el) => el && el.addEventListener("input", update));
    [oeNorm, oeSbc, oeMaint].forEach((el) => el && el.addEventListener("change", update));
    // The bond yield carries in the URL (like the price), so a shared link keeps the whole comparison.
    if (bondY) bondY.addEventListener("input", () => {
      try { const u = new URL(location.href); bondY.value ? u.searchParams.set("by", bondY.value) : u.searchParams.delete("by"); history.replaceState(null, "", u); } catch (e) {}
      bondView();
    });
    try {
      const q = new URL(location.href).searchParams.get("px"); if (q) px.value = q;
      // The bond field opens on the build-time Treasury default (set programmatically, so it stays out
      // of the URL until the reader overrides it); an explicit ?by= in the URL wins.
      const qb = new URL(location.href).searchParams.get("by");
      if (bondY) bondY.value = qb || box.dataset.bonddefault || "";
    } catch (e) {}
    update();
  })();
</script>

<script>
  import { gordonMultiple } from "../lib/reverseDcf.mjs";
  (function () {
    const box = document.getElementById("valBoxNeg");
    if (!box) return;
    const REV = parseFloat(box.dataset.rev), SH = parseFloat(box.dataset.shares), NAME = box.dataset.name || "this company";
    const NETDEBT = parseFloat(box.dataset.netdebt) || 0;
    const PROFIT = box.dataset.profitable === "1";
    const FROM = PROFIT ? "from negative free cash flow today" : "from a loss today";
    const SYM = box.dataset.sym || "$";
    const px = document.getElementById("pxn");
    const r = document.getElementById("rN"), n = document.getElementById("nN"), gr = document.getElementById("grN"), mm = document.getElementById("mmN");
    const rOut = document.getElementById("rOutN"), nOut = document.getElementById("nOutN"), grOut = document.getElementById("grOutN"), mmOut = document.getElementById("mmOutN");
    const lede = document.getElementById("ledeN"), reqOE = document.getElementById("reqOE"), reqM = document.getElementById("reqM");
    const refMN = document.getElementById("refMN"), refVN = document.getElementById("refVN"), refMosN = document.getElementById("refMosN");

    const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
    const pcs = (v) => (v < 0 ? "−" : "") + Math.abs(v * 100).toFixed(0) + "%";
    const usd = (v) => { const a = Math.abs(v); const s = a >= 1e12 ? SYM + (a / 1e12).toFixed(2) + "T" : a >= 1e9 ? SYM + (a / 1e9).toFixed(1) + "B" : a >= 1e6 ? SYM + Math.round(a / 1e6) + "M" : SYM + Math.round(a); return v < 0 ? "(" + s + ")" : s; };
    function setURL(v) { try { const u = new URL(location.href); v ? u.searchParams.set("px", v) : u.searchParams.delete("px"); history.replaceState(null, "", u); } catch (e) {} }

    function update() {
      const rr = parseFloat(r.value) / 100, N = parseInt(n.value, 10), g = parseFloat(gr.value) / 100, mgn = parseFloat(mm.value) / 100;
      rOut.textContent = r.value + "%"; nOut.textContent = N; grOut.textContent = gr.value + "%"; mmOut.textContent = mm.value + "%";
      const M = gordonMultiple(rr, 0.025) || 0; // mature owner-earnings multiple at this discount rate (2.5% terminal)
      const revN = REV * Math.pow(1 + g, N);  // revenue grown at your rate

      // From your belief: the mature margin you would credit, turned into owner earnings on
      // that grown revenue, valued at the mature multiple, discounted back, net of debt. A
      // reference value to set the price against — the same yardstick the other modes show.
      refMN.textContent = mm.value + "%";
      if (M > 0 && SH > 0 && revN > 0) {
        const pv = (revN * mgn * M) / Math.pow(1 + rr, N);
        const refPS = (pv - NETDEBT) / SH;
        refVN.textContent = refPS > 0 ? SYM + refPS.toFixed(2) : "—";
        refMosN.textContent = refPS > 0 ? SYM + (refPS * 0.7).toFixed(2) : "—";
      } else { refVN.textContent = "—"; refMosN.textContent = "—"; }

      const price = parseFloat(px.value);
      if (!(price > 0)) { lede.textContent = "Enter a price to run it."; reqOE.textContent = "—"; reqM.textContent = "—"; setURL(""); return; }
      const mc = price * SH;
      const valN = mc * Math.pow(1 + rr, N);  // equity value it must reach in year N to return rr
      const requiredOE = valN / M;
      const reqMargin = requiredOE / revN;
      reqOE.textContent = usd(requiredOE);
      reqM.textContent = reqMargin > 3 ? ">300%" : pcs(reqMargin);
      const P = SYM + price.toFixed(2);
      let verdict;
      if (reqMargin > 1) verdict = `, <b class="bad">impossible</b>: more owner profit than it would have revenue.`;
      else if (reqMargin > 0.45) verdict = `, an <b class="bad">extraordinary</b> margin almost no business on earth sustains, ${FROM}.`;
      else if (reqMargin > 0.3) verdict = `, a <b>top-tier</b> margin (the most profitable software), ${FROM}.`;
      else if (reqMargin > mgn) verdict = `, <b>above the ${mm.value}%</b> you would credit — you are paying for more than you believe.`;
      else verdict = `, at or below the ${mm.value}% you would credit, ${FROM}.`;
      lede.innerHTML = `At <b>${P}</b>, to earn you ${r.value}% a year, ${esc(NAME)} must be worth ${usd(valN)} in ${N} years. At ~${M.toFixed(0)}× owner earnings, that is <b class="hot">${usd(requiredOE)}</b> a year, on revenue grown ${g > 0 ? "at " + gr.value + "%/yr" : "flat"} to ${usd(revN)}: an owner-earnings margin of <b class="hot">${reqMargin > 3 ? ">300%" : pcs(reqMargin)}</b>${verdict}`;
      setURL(px.value);
    }
    [px, r, n, gr, mm].forEach((el) => el.addEventListener("input", update));
    try { const q = new URL(location.href).searchParams.get("px"); if (q) px.value = q; } catch (e) {}
    update();
  })();
</script>

<script>
  import { justifiedBookMultiple } from "../lib/reverseDcf.mjs";
  (function () {
    const box = document.getElementById("valBoxBank");
    if (!box) return;
    const TBVPS = parseFloat(box.dataset.tbvps), BVPS = parseFloat(box.dataset.bvps), ROTCE = parseFloat(box.dataset.rotce);
    const EPS = parseFloat(box.dataset.eps), NAME = box.dataset.name || "this company", CYCLE = box.dataset.cycle || "credit cycle";
    const SYM = box.dataset.sym || "$";
    const px = document.getElementById("pxb");
    const coe = document.getElementById("coeB"), gB = document.getElementById("gB");
    const coeOut = document.getElementById("coeOut"), gOutB = document.getElementById("gOutB");
    const lede = document.getElementById("ledeB"), ptbv = document.getElementById("ptbv"), just = document.getElementById("justptbv");
    const pbB = document.getElementById("pbBank"), eyB = document.getElementById("eyBank"), peB = document.getElementById("peBank");
    const refVB = document.getElementById("refVB"), refMosB = document.getElementById("refMosB");
    const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));

    function setURL(v) { try { const u = new URL(location.href); v ? u.searchParams.set("px", v) : u.searchParams.delete("px"); history.replaceState(null, "", u); } catch (e) {} }

    function update() {
      const c = parseFloat(coe.value) / 100, g = parseFloat(gB.value) / 100;
      coeOut.textContent = coe.value + "%"; gOutB.textContent = gB.value + "%";
      // The justified multiple and the reference value it implies depend only on the dials and
      // the normalized return, not on the price you type, so they stand on their own.
      const justified = justifiedBookMultiple(ROTCE, c, g);
      just.textContent = justified != null ? justified.toFixed(2) + "×" : "—";
      if (justified != null && TBVPS > 0) {
        const fair = justified * TBVPS;
        refVB.textContent = SYM + fair.toFixed(2); refMosB.textContent = SYM + (fair * 0.7).toFixed(2);
      } else { refVB.textContent = "—"; refMosB.textContent = "—"; }
      const price = parseFloat(px.value);
      if (!(price > 0)) { lede.textContent = "Enter a price above to run it."; [ptbv, pbB, eyB, peB].forEach((e) => (e.textContent = "—")); setURL(""); return; }
      const ptb = price / TBVPS;
      ptbv.textContent = ptb.toFixed(2) + "×";
      pbB.textContent = (price / BVPS).toFixed(2) + "×";
      if (EPS > 0) { eyB.textContent = ((EPS / price) * 100).toFixed(1) + "%"; peB.textContent = (price / EPS).toFixed(1) + "×"; }
      else { eyB.textContent = "n/m"; peB.textContent = "n/m"; }
      const P = SYM + price.toFixed(2), R = (ROTCE * 100).toFixed(0);
      if (justified == null) { lede.textContent = "Set the cost of equity above the growth rate."; setURL(px.value); return; }
      const ratio = ptb / justified;
      let verdict;
      if (ratio <= 0.85) verdict = `a <b class="hot">discount</b> to what its ${R}% return on tangible equity would justify (about ${justified.toFixed(2)}×). The market is doubting the return holds; the record is where you check whether that doubt is earned.`;
      else if (ratio <= 1.15) verdict = `roughly <b>in line</b> with what its ${R}% return on tangible equity justifies (about ${justified.toFixed(2)}×).`;
      else verdict = `a <b class="bad">premium</b> to what its ${R}% return justifies (about ${justified.toFixed(2)}×). You are paying for the return to rise, or to outlast the ${CYCLE}.`;
      lede.innerHTML = `At <b>${P}</b>, you pay <b class="hot">${ptb.toFixed(2)}×</b> tangible book for ${esc(NAME)}, ${verdict}`;
      setURL(px.value);
    }
    [px, coe, gB].forEach((el) => el.addEventListener("input", update));
    try { const q = new URL(location.href).searchParams.get("px"); if (q) px.value = q; } catch (e) {}
    update();
  })();
</script>

<script>
  import { gordonMultiple } from "../lib/reverseDcf.mjs";
  (function () {
    const box = document.getElementById("valBoxReit");
    if (!box) return;
    const FFOPS = parseFloat(box.dataset.ffops), DPS = parseFloat(box.dataset.dps), NAME = box.dataset.name || "this REIT";
    const SYM = box.dataset.sym || "$";
    const px = document.getElementById("pxr");
    const r = document.getElementById("rR"), g = document.getElementById("gR");
    const rOut = document.getElementById("rOutR"), gOut = document.getElementById("gOutR");
    const lede = document.getElementById("ledeR"), pffo = document.getElementById("pffo"), just = document.getElementById("justpffo"), dyR = document.getElementById("dyR");
    const refVR = document.getElementById("refVR"), refMosR = document.getElementById("refMosR");
    const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
    function setURL(v) { try { const u = new URL(location.href); v ? u.searchParams.set("px", v) : u.searchParams.delete("px"); history.replaceState(null, "", u); } catch (e) {} }

    function update() {
      const rr = parseFloat(r.value) / 100, gg = parseFloat(g.value) / 100;
      rOut.textContent = r.value + "%"; gOut.textContent = g.value + "%";
      // The justified multiple and the reference value depend only on the dials, not the price.
      const justified = gordonMultiple(rr, gg);
      just.textContent = justified != null ? justified.toFixed(1) + "×" : "—";
      if (justified != null && FFOPS > 0) {
        const fair = justified * FFOPS;
        refVR.textContent = SYM + fair.toFixed(2); refMosR.textContent = SYM + (fair * 0.7).toFixed(2);
      } else { refVR.textContent = "—"; refMosR.textContent = "—"; }
      const price = parseFloat(px.value);
      if (!(price > 0)) { lede.textContent = "Enter a price above to run it."; [pffo, dyR].forEach((e) => (e.textContent = "—")); setURL(""); return; }
      const pf = price / FFOPS;
      pffo.textContent = pf.toFixed(1) + "×";
      const dy = DPS > 0 ? DPS / price : null;
      dyR.textContent = dy != null ? (dy * 100).toFixed(1) + "%" : "—";
      const P = SYM + price.toFixed(2);
      if (justified == null) { lede.textContent = "Set the discount rate above the growth rate."; setURL(px.value); return; }
      const ratio = pf / justified;
      let verdict;
      if (ratio <= 0.85) verdict = `a <b class="hot">discount</b> to the about ${justified.toFixed(1)}× that ${g.value}% FFO growth justifies at an ${r.value}% discount rate.`;
      else if (ratio <= 1.15) verdict = `roughly <b>in line</b> with the about ${justified.toFixed(1)}× that ${g.value}% FFO growth justifies.`;
      else verdict = `a <b class="bad">premium</b> to the about ${justified.toFixed(1)}× that ${g.value}% FFO growth justifies; you are paying for faster growth or a lower rate.`;
      const income = dy != null ? ` The income alone is a ${(dy * 100).toFixed(1)}% yield.` : "";
      lede.innerHTML = `At <b>${P}</b>, you pay <b class="hot">${pf.toFixed(1)}×</b> funds from operations for ${esc(NAME)}, ${verdict}${income}`;
      setURL(px.value);
    }
    [px, r, g].forEach((el) => el.addEventListener("input", update));
    try { const q = new URL(location.href).searchParams.get("px"); if (q) px.value = q; } catch (e) {}
    update();
  })();
</script>
