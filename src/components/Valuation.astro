---
// "What you're implicitly betting" — the reverse-DCF, rendered. Dark until a price
// snapshot exists. Never a price target: it shows the growth the market is pricing
// and sets it beside what the company has actually delivered. The reader judges.
import prices from "../data/prices.json";
import { expectations } from "../lib/valuation.mjs";
import { classify } from "../lib/archetype.mjs";
import { moatReport } from "../lib/durability.mjs";
import { fmtUSD } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const price = prices?.prices?.[company.ticker] ?? null;
const asOf = prices?.asOf ?? null;

const { sector, overlays } = classify(company);
const offModel = sector.key === "financial" || sector.key === "reit";
const cyclical = overlays.some((o) => o.key === "cyclical");
const exp = price != null && !offModel ? expectations(company, price) : null;

const report = moatReport(company);
const oeGrowth = report?.facts.find((f) => f.label === "Owner earnings growth")?.value ?? null;

const pc = (v, dp = 1) => (v == null ? "—" : `${v < 0 ? "−" : ""}${Math.abs(v * 100).toFixed(dp)}%`);
const mult = exp && exp.runnable ? exp.marketCap / exp.ownerEarnings : null;
const name = company.name || company.ticker;
---

{price != null ? (
  <section class="val">
    <div class="head">
      <h2>What the price implies</h2>
      <span class="asof">close ${price.toFixed(2)}{asOf ? ` · ${asOf}` : ""}</span>
    </div>

    {offModel ? (
      <p class="note">A {sector.label.toLowerCase()} isn't read on an owner-earnings DCF — its economics live on the balance sheet (book value, net interest margin, loan losses / FFO). We don't force this lens where it doesn't belong.</p>
    ) : !exp || !exp.runnable ? (
      <p class="note">Owner earnings are negative this year, so a reverse-DCF can't be run — there's no positive stream to discount. For a {cyclical ? "cyclical at this point in the cycle" : "loss-making or turnaround business"}, judge it on normalized (through-cycle) earnings or on assets, not a growth-on-growth model.</p>
    ) : (
      <>
        <p class="lede" data-mult={mult.toFixed(4)}>
          At <b>${price.toFixed(2)}</b>, the market is pricing <b>{name}</b> to grow owner earnings
          {exp.capped ? (
            <> faster than <b class="hot">100%/yr</b> — beyond what this model can justify on owner earnings alone.</>
          ) : exp.floored || (exp.impliedG != null && exp.impliedG < 0) ? (
            <> at <b class="hot" id="ig">{pc(exp.impliedG)}</b>/yr — i.e. it's priced for owner earnings to <b>shrink</b> for a decade.</>
          ) : (
            <> about <b class="hot" id="ig">{pc(exp.impliedG)}</b>/yr for <span id="igN">10</span> years, then 2.5% forever — discounted at <span id="igR">9</span>%.</>
          )}
        </p>

        <div class="compare">
          <div class="cmp"><span class="cl">Implied by today's price</span><span class="cv hot" id="igEcho">{pc(exp.impliedG)}/yr</span></div>
          <div class="cmp"><span class="cl">Actually delivered (record)</span><span class="cv">{oeGrowth ? `${oeGrowth.replace("/yr", "")}/yr` : "—"}</span></div>
          <div class="cmp"><span class="cl">Owner-earnings yield</span><span class="cv">{pc(exp.oeYield)}</span></div>
        </div>

        <div class="dials" id="dials" data-mult={mult.toFixed(4)}>
          <span class="dialsLbl">Turn the dials — what would you have to believe?</span>
          <label>Discount rate <output id="rOut">9%</output><input id="r" type="range" min="6" max="14" step="0.5" value="9" /></label>
          <label>Years of high growth <output id="nOut">10</output><input id="n" type="range" min="5" max="15" step="1" value="10" /></label>
          <label>Terminal growth <output id="gOut">2.5%</output><input id="g" type="range" min="0" max="4" step="0.25" value="2.5" /></label>
        </div>

        <p class="foot">
          This is a lens, not a price target — it says what you'd have to <em>believe</em>, not what the
          company is <em>worth</em>. It runs on one year of owner earnings (noisy by nature) at assumptions
          you can see and change above. Market cap {fmtUSD(exp.marketCap)} ÷ owner earnings {fmtUSD(exp.ownerEarnings)} = {mult.toFixed(0)}×.
        </p>
      </>
    )}
  </section>
) : null}

<style>
  .val { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .asof { font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; flex: 0 0 auto; }

  .note { font-family: var(--serif); font-style: italic; font-size: 14px; color: #3a3e46; margin: 12px 0 0; line-height: 1.5; max-width: 66ch; }
  .lede { font-family: var(--serif); font-size: clamp(16px, 2.3vw, 18.5px); line-height: 1.5; margin: 14px 0 0; max-width: 66ch; }
  .lede b { font-weight: 600; }
  .hot { color: var(--accent); font-variant-numeric: tabular-nums; }

  .compare { display: flex; flex-wrap: wrap; gap: 10px 28px; margin: 16px 0 0; padding: 12px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .cmp { display: flex; flex-direction: column; }
  .cl { font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .cv { font-size: 20px; font-weight: 700; font-variant-numeric: tabular-nums; margin-top: 2px; }

  .dials { margin: 16px 0 0; }
  .dialsLbl { font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .dials label { display: flex; align-items: center; gap: 10px; margin: 9px 0 0; font-size: 13.5px; color: #3a3e46; }
  .dials output { font-weight: 700; font-variant-numeric: tabular-nums; min-width: 44px; color: var(--ink); }
  .dials input[type="range"] { flex: 1 1 auto; max-width: 320px; accent-color: var(--accent); }

  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); margin: 14px 0 0; line-height: 1.5; max-width: 70ch; }
</style>

<script is:inline>
  (function () {
    const dials = document.getElementById("dials");
    if (!dials) return;
    const mult = parseFloat(dials.dataset.mult);
    const r = document.getElementById("r"), n = document.getElementById("n"), g = document.getElementById("g");
    const rOut = document.getElementById("rOut"), nOut = document.getElementById("nOut"), gOut = document.getElementById("gOut");
    const ig = document.getElementById("ig"), igN = document.getElementById("igN"), igR = document.getElementById("igR"), igEcho = document.getElementById("igEcho");

    const pv = (gr, rr, N, gT) => { let p = 0, oe = 1; for (let y = 1; y <= N; y++) { oe *= 1 + gr; p += oe / Math.pow(1 + rr, y); } return p + (oe * (1 + gT)) / (rr - gT) / Math.pow(1 + rr, N); };
    function solve(rr, N, gT) {
      if (rr <= gT) return null;
      const f = (gr) => pv(gr, rr, N, gT) - mult;
      let lo = -0.5, hi = 1.0;
      if (f(lo) > 0) return lo; if (f(hi) < 0) return hi;
      for (let i = 0; i < 60; i++) { const m = (lo + hi) / 2; if (f(m) > 0) hi = m; else lo = m; }
      return (lo + hi) / 2;
    }
    const fmtPc = (v) => (v == null ? "—" : (v < 0 ? "−" : "") + Math.abs(v * 100).toFixed(1) + "%");

    function update() {
      const rr = parseFloat(r.value) / 100, N = parseInt(n.value, 10), gT = parseFloat(g.value) / 100;
      rOut.textContent = r.value + "%"; nOut.textContent = N; gOut.textContent = parseFloat(g.value).toFixed(2).replace(/\.00$/, "") + "%";
      const gr = solve(rr, N, gT);
      const txt = gr == null ? "—" : (Math.abs(gr) >= 1 ? (gr > 0 ? "100%+" : fmtPc(gr)) : fmtPc(gr));
      if (ig) ig.textContent = txt;
      if (igEcho) igEcho.textContent = txt + "/yr";
      if (igN) igN.textContent = N;
      if (igR) igR.textContent = r.value;
    }
    [r, n, g].forEach((el) => el.addEventListener("input", update));
    update();
  })();
</script>
