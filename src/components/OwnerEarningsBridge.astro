---
// "Owner-earnings bridge" — the single most important Buffett adjustment, made legible: how a
// year's reported profit becomes the cash an owner can actually take out. Net income is an
// accountant's number; owner earnings is operating cash less the capital the business must put
// back to keep running. The bridge walks from one to the other, every step from the company's
// own cash-flow statement, and ties out to the same Owner Earnings the scorecard reads. We
// present the reconciliation; the judgment is the reader's. Withheld for financials and for any
// company whose filing doesn't carry the three anchors (net income, operating cash, capex).
import { ownerEarningsBridge, ownerEarningsBridgeSeries, fmtMoney } from "../lib/fundamentals.mjs";
import Term from "./Term.astro";

const { company } = Astro.props;
const b = ownerEarningsBridge(company);
const $ = (v) => fmtMoney(v, company?.currency || "USD");
const signed = (v) => (v < 0 ? "−" : "+") + $(Math.abs(v));
const pc = (n, d) => (n != null && d ? `${Math.round((n / d) * 100)}%` : null);

// The ledger, shown across the last few fiscal years so the trend of each step is legible — whether
// owner earnings is growing, and whether the gap to reported profit is widening or holding. Net
// income closes to operating cash (depreciation and stock comp shown when tagged, everything else in
// the residual, so it ties out), then capex splits the Buffett way: the maintenance the business
// needs just to hold its position, which owner earnings subtracts, and — for a builder spending
// above depreciation while it grows — the discretionary growth capex, carried down to free cash flow.
const series = ownerEarningsBridgeSeries(company, 5);   // oldest → newest
const cols = series.slice().reverse();                  // newest first, so the headline year leads
const anyGrowth = series.some((y) => y.growthCapex > 0);
const anyDep = series.some((y) => y.depreciation != null);
const anySbc = series.some((y) => y.stockBasedComp != null);
const hasGrowth = !!b && b.growthCapex > 0;             // the latest year, for the prose below

// Each row reads one bridge figure across every year column. `kind` drives both the arithmetic sign
// (add/sub get a +/−) and the banded styling (start / subtotal / total / ratio).
const rows = [
  { k: "ni", label: "Reported net income", kind: "start", get: (y) => y.netIncome },
  anyDep ? { k: "dep", label: "Depreciation & amortization", kind: "add", hint: "non-cash charge added back", get: (y) => y.depreciation } : null,
  anySbc ? { k: "sbc", label: "Stock-based compensation", kind: "add", flag: true, hint: "non-cash — but a real cost", get: (y) => y.stockBasedComp } : null,
  { k: "oth", label: "Working capital & other", kind: "add", hint: "timing of cash in and out, other non-cash items", get: (y) => y.other },
  { k: "cfo", label: "Cash from operations", kind: "subtotal", get: (y) => y.cashFromOps },
  { k: "maint", label: anyGrowth ? "Maintenance capital expenditure" : "Capital expenditure", kind: "sub", hint: anyGrowth ? "the spending needed just to hold position and volume" : "cash put back in to keep running and to grow", get: (y) => -y.maintCapex },
  { k: "oe", label: "Owner earnings", kind: "total", get: (y) => y.ownerEarnings },
  anyGrowth ? { k: "growth", label: "Growth capital expenditure", kind: "sub", hint: "discretionary — spent to get bigger, not to stand still", get: (y) => -y.growthCapex } : null,
  anyGrowth ? { k: "fcf", label: "Free cash flow", kind: "subtotal", get: (y) => y.freeCashFlow } : null,
  { k: "oem", label: "Owner-earnings margin", kind: "ratio", hint: "owner earnings ÷ revenue", get: (y) => pc(y.ownerEarnings, y.revenue) },
].filter(Boolean);

// A cell's text: a ratio row is already a string; add/sub carry a sign (and a zero reads as a dash,
// so a non-build year doesn't show "+$0" growth capex); everything else is plain money.
const cell = (r, y) => {
  const v = r.get(y);
  if (r.kind === "ratio") return v ?? "—";
  if (v == null) return "—";
  if (r.kind === "add" || r.kind === "sub") return Math.round(v) === 0 ? "—" : signed(v);
  return $(v);
};

const oeMargin = b ? pc(b.ownerEarnings, b.revenue) : null;
const sbcAdj = b && b.stockBasedComp != null ? b.ownerEarnings - b.stockBasedComp : null;

// The two-bar comparison reads honestly only when both endpoints are positive; with a loss or
// negative owner earnings the ledger below carries the story and the bars are dropped.
const showBars = !!b && b.netIncome > 0 && b.ownerEarnings > 0;
const barMax = showBars ? Math.max(b.netIncome, b.ownerEarnings) : 0;

// When a large share of reported profit didn't arrive as operating cash — the residual that
// closes net income to CFO is a big negative — owner earnings (CFO − capex) understates the
// year's economics: the gap can be a working-capital swing, a heavy tax year, or, the case that
// prompted this, profit a company earns on investments it books through investing rather than
// operations (Nintendo's float of cash and securities). A small note when that gap is large.
const bigGap = !!b && b.netIncome > 0 && b.other < -0.5 * b.netIncome;

// One factual takeaway, no verdict.
let takeaway = null;
if (b) {
  const niTxt = b.netIncome >= 0 ? `${$(b.netIncome)} of profit` : `a ${$(Math.abs(b.netIncome))} loss`;
  if (hasGrowth) {
    takeaway = `That year the business earned ${$(b.ownerEarnings)} of owner earnings — the operating cash left after the ${$(b.maintCapex)} it takes just to hold its position. It chose to put ${$(b.growthCapex)} more into growth, which is why free cash flow was only ${$(b.freeCashFlow)}: the gap is investment, not weakness.`;
  } else {
    takeaway = b.ownerEarnings >= b.netIncome
      ? `That year the business turned ${niTxt} into ${$(b.ownerEarnings)} of owner earnings — more cash than the profit line showed, after the non-cash charges and the capital it put back in.`
      : `That year the business reported ${niTxt} but ${$(b.ownerEarnings)} of owner earnings — ${$(Math.abs(b.ownerEarnings - b.netIncome))} less than the profit line, taken out by capital spending and the timing of cash.`;
  }
}
---

{b ? (
  <section class="oeb">
    <div class="head">
      <h3 class="secTitle"><Term id="owner-earnings">Owner-earnings bridge</Term></h3>
      <span class="hmeta">
        <span class="asof">{series.length > 1 ? `FY${series[0].fy}–FY${series[series.length - 1].fy}` : (b.fy ? `FY${b.fy}` : "latest year")}</span>
        {company.sourceUrl ? <a class="src" href={company.sourceUrl} target="_blank" rel="noopener">cash-flow statement, {company.market === "JP" ? "EDINET" : "SEC EDGAR"} →</a> : null}
      </span>
    </div>
    <p class="intro">
      Net income is the accountant's number; owner earnings is the cash an owner could actually
      take out. The walk from one to the other, every step off the company's own cash-flow
      statement, across the last few years — whether the gap between reported profit and owner cash
      is widening or holding is where a business is read.
    </p>

    {takeaway ? <p class="take">{takeaway}</p> : null}

    {showBars ? (
      <div class="bars">
        <div class="barRow">
          <span class="blab">Reported net income</span>
          <span class="track"><span class="fill ni" style={`width:${(b.netIncome / barMax) * 100}%`}></span></span>
          <span class="bval">{$(b.netIncome)}</span>
        </div>
        <div class="barRow">
          <span class="blab">Owner earnings</span>
          <span class="track"><span class="fill oe" style={`width:${(b.ownerEarnings / barMax) * 100}%`}></span></span>
          <span class="bval">{$(b.ownerEarnings)}{oeMargin ? <i> · {oeMargin} of revenue</i> : null}</span>
        </div>
      </div>
    ) : null}

    <div class="scroll">
      <table class="oebt">
        <thead>
          <tr>
            <th class="corner" scope="col"></th>
            {cols.map((y, i) => <th class={`yr${i === 0 ? " feat" : ""}`} scope="col">FY{y.fy}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr class={`r ${r.kind}`}>
              <th class="lbl" scope="row">
                <span class="lt">{r.label}{r.flag ? <span class="real">real cost</span> : null}</span>
                {r.hint ? <i class="hint">{r.hint}</i> : null}
              </th>
              {cols.map((y, i) => <td class={`amt${i === 0 ? " feat" : ""}`}>{cell(r, y)}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="note">
      Owner earnings is what Buffett called the cash you could pull out without starving the business:
      operating cash less the {hasGrowth ? "maintenance " : ""}capital it must spend to hold its position
      {hasGrowth ? <> — here about {$(b.maintCapex)}, roughly its depreciation, the rate its assets wear out</> : null}.
      {hasGrowth ? (
        <> The other {$(b.growthCapex)} of its capital spending is growth it chose, not upkeep it owed; charged
        only with the maintenance it must do, the business earns well more than this year's free cash flow shows.</>
      ) : null}
      {b.stockBasedComp != null ? (
        <> The cash-flow statement also adds stock comp back as non-cash, but it is a real cost paid in
        shares — counted as the expense it is (less {$(b.stockBasedComp)}), owner earnings is nearer {$(sbcAdj)}.</>
      ) : null}
    </p>

    {bigGap ? (
      <p class="gapnote">
        Mind the gap: much of this year's profit didn't arrive as operating cash — it sits in
        “working capital &amp; other” above. That can be a real inventory or timing swing, or profit
        that doesn't run through operating cash at all: a heavy tax year, equity-method earnings, or
        investment income a company earns on its cash pile and books through investing rather than
        operations. For a year like this, owner earnings understates the cash an owner truly earned;
        read it against the full cash-flow statement.
      </p>
    ) : null}

    <p class="foot">Arithmetic on the company's own cash-flow statement; nothing here is scored. Maintenance capex is estimated as depreciation only where a growing business invests above it (Buffett's proxy, with no property-and-equipment line to do better); free cash flow is the figure the scorecard's free-cash margin reads.</p>
  </section>
) : null}

<style>
  .oeb { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .secTitle { margin: 0; }
  .hmeta { display: inline-flex; align-items: baseline; gap: 12px; flex-wrap: wrap; justify-content: flex-end; }
  .asof { font-size: 11.5px; letter-spacing: 0.03em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 74ch; line-height: 1.6; }
  .take { font-family: var(--serif); font-size: 15.5px; line-height: 1.55; color: var(--ink-soft); margin: 12px 0 0; max-width: 72ch; }

  /* Net income vs owner earnings, side by side, so the gap is visible before the ledger. */
  .bars { margin: 16px 0 0; display: grid; gap: 9px; }
  .barRow { display: grid; grid-template-columns: 160px 1fr auto; align-items: center; gap: 12px; }
  .blab { font-family: var(--sans); font-size: 12px; color: var(--muted); }
  .track { height: 16px; background: var(--surface-2); border: 1px solid var(--rule); position: relative; }
  .fill { display: block; height: 100%; min-width: 2px; }
  .fill.ni { background: var(--viz-muted, var(--rule-strong)); }
  .fill.oe { background: var(--accent); }
  .bval { font-variant-numeric: tabular-nums; font-weight: 700; font-size: 13.5px; color: var(--ink); flex: 0 0 auto; }
  .bval i { font-style: normal; font-weight: 400; color: var(--muted); font-size: 12px; }

  /* The multi-year ledger: each bridge step a row, each fiscal year a column. The newest year leads
     (leftmost, accent-marked) and stays in view; older years scroll off to the right on narrow screens. */
  .scroll { margin: 16px 0 0; overflow-x: auto; }
  .oebt { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  .oebt th, .oebt td { padding: 7px 11px; text-align: right; white-space: nowrap; }
  .oebt thead th { font-family: var(--sans); font-size: 11.5px; font-weight: 700; letter-spacing: 0.03em; color: var(--muted); border-bottom: 1px solid var(--rule-strong); }
  .oebt thead th.feat { color: var(--accent); }
  .oebt .corner { width: 1%; }
  .oebt .lbl { text-align: left; font-weight: 400; vertical-align: baseline; }
  .oebt .lbl .lt { font-size: 13.5px; color: var(--ink-soft); }
  .oebt .hint { display: block; font-style: normal; font-size: 11px; color: var(--ink-dim); margin-top: 1px; white-space: normal; max-width: 34ch; }
  .oebt .amt { font-size: 14px; color: var(--ink); }
  .oebt tbody tr { border-bottom: 1px solid var(--rule); }
  /* the current year, marked rather than filled, so the banded total/subtotal rows stay legible */
  .oebt .feat { background: var(--accent-tint); }
  .oebt td.feat { border-left: 2px solid var(--accent); }
  .oebt th.feat { border-left: 2px solid var(--accent); }

  /* added / subtracted lines: indented label, muted figures */
  .r.add .lbl, .r.sub .lbl { padding-left: 22px; }
  .r.add .amt, .r.sub .amt { color: var(--muted); }
  .real { font-family: var(--sans); font-size: 9.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); border-radius: 2px; padding: 0 5px; margin-left: 8px; vertical-align: 1px; }

  /* subtotal (CFO, free cash flow) and the owner-earnings total are the lines you read */
  .r.subtotal { border-top: 1px solid var(--rule-strong); }
  .r.subtotal .lbl .lt { font-family: var(--sans); font-weight: 700; font-size: 12px; letter-spacing: 0.03em; text-transform: uppercase; color: var(--ink); }
  .r.subtotal .amt { font-weight: 700; }
  .r.total { border-top: 2px solid var(--ink); border-bottom: none; }
  .r.total .lbl .lt { font-weight: 700; font-size: 15px; color: var(--ink); }
  .r.total .amt { font-weight: 800; font-size: 16.5px; color: var(--accent); }
  /* owner-earnings margin is a memo line under the total, not part of the sum */
  .r.ratio .lbl .lt { font-size: 12px; color: var(--muted); }
  .r.ratio .amt { font-size: 12.5px; color: var(--muted); }

  .note { font-family: var(--serif); font-size: 13.5px; line-height: 1.6; color: var(--ink-soft); background: var(--accent-tint); border-left: 2px solid var(--accent); padding: 10px 14px; margin: 14px 0 0; max-width: 80ch; }
  /* The gap caveat is a quieter aside than the main note — a flag, not a headline. */
  .gapnote { font-family: var(--serif); font-style: italic; font-size: 13px; line-height: 1.6; color: var(--muted); border-left: 2px solid var(--rule-strong); padding: 2px 0 2px 12px; margin: 12px 0 0; max-width: 80ch; }
  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 16px; padding-top: 10px; max-width: 74ch; }

  @media (max-width: 560px) {
    .barRow { grid-template-columns: 110px 1fr auto; gap: 8px; }
    .blab { font-size: 11px; }
    .oebt th, .oebt td { padding: 6px 8px; }
    .oebt .amt { font-size: 12.5px; }
    .oebt .lbl .lt { font-size: 12.5px; }
    .oebt .hint { max-width: 22ch; }
  }
</style>
