---
// "Earnings power, through the cycle" — Graham's discipline made visible. What a business
// earns on its average margin, applied to today's revenue, set beside the latest reported
// year, so the reader can see whether they are looking at a peak or a trough. The record's
// own arithmetic; never a forecast, never a verdict.
import { earningsPower } from "../lib/normalize.mjs";
import { fmtMoney } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const ep = earningsPower(company);
const ccy = company.currency || "USD";
const $ = (v) => (v == null ? "—" : fmtMoney(v, ccy));
const pct = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${Math.abs(v * 100).toFixed(dp)}%`);

// The plain read: where this year sits against its own average, stated as a fact. When the
// record has no single through-cycle earning power (owner-earnings margin crosses zero, or the
// median is not positive), we say so plainly instead of normalizing — a turnaround read it on
// the trajectory and the range, not a normalized number that would be negative or mislead.
let read = null;
if (ep && ep.structuralBreak) {
  read = `Revenue has fallen well below its prior peak and stayed there — a one-time windfall reversed, or the business has structurally shrunk, not a cycle that turns. The earlier, far larger years no longer describe what the company is, so a through-cycle margin applied to today's revenue would manufacture an earning power that is not real. Read the range above and the year-by-year record, not a normalized figure.`;
} else if (ep && ep.normUnstable) {
  read = ep.crossesZero
    ? `Owner-earnings margin crosses from loss to profit across this record, so there is no single through-cycle figure to normalize to — this is a turnaround or a structural change, not a business with one steady earning power. Read it on the range above and the year-by-year record, not a normalized number.`
    : `Owner earnings have been negative through most of this record, so there is no positive earning power to normalize to. Read the margin range above and the year-by-year record; the latest year, on its own, does not yet make a through-cycle figure.`;
} else if (ep && ep.cyclePos === "above") {
  read = `This year's margin runs above its through-cycle average, so the latest owner earnings may flatter the business; a buyer paying on the reported figure is paying on a good year.`;
} else if (ep && ep.cyclePos === "below") {
  read = `This year's margin runs below its through-cycle average, so the latest owner earnings may understate the business; the reported figure is being set in a lean year.`;
} else if (ep && ep.cyclePos === "at") {
  read = `This year's margin sits close to its through-cycle average, so the latest owner earnings look representative of normal power, not a peak or a trough.`;
}
const cyclical = ep && ep.swing != null && ep.swing > 1.2;
---

{ep ? (
  <section class="norm">
    <div class="head"><h3>Earnings power, through the cycle</h3><span class="coda">a read of the record above</span></div>
    <p class="lede">
      Graham warned against paying for a peak year or fleeing a trough. Here is what {company.name || company.ticker}
      earns on its <b>through-cycle</b> margin across {ep.span}, applied to the latest annual revenue, set beside the latest reported figure.
    </p>

    <div class="grid">
      <div class="cell">
        <span class="cl">Normalized owner earnings</span>
        <span class="cv hot">{$(ep.normOE)}</span>
        <span class="sub">{ep.normOE != null ? `${pct(ep.normOeMargin, 1)} through-cycle margin on ${$(ep.rev)} revenue` : "no single through-cycle figure here — see below"}</span>
      </div>
      <div class="cell">
        <span class="cl">Latest, reported</span>
        <span class="cv">{$(ep.latestOE)}</span>
        <span class="sub">at a {pct(ep.latestOeMargin, 1)} margin this year</span>
      </div>
      <div class="cell">
        <span class="cl">Owner-earnings margin, the range</span>
        <span class="cv">{ep.oemRange ? `${pct(ep.oemRange[0], 1)} – ${pct(ep.oemRange[1], 1)}` : "—"}</span>
        <span class="sub">{cyclical ? "a wide swing: a cyclical, read it on the average" : "across the record"}</span>
      </div>
    </div>

    {read ? <p class="read">{read}</p> : null}

    <p class="foot">
      Normalized owner earnings apply the median owner-earnings margin of the {ep.years} owner-earnings years on
      record ({ep.span}) to the latest annual revenue, the earnings-power method, with the median used so one partial
      or one-off year cannot skew it.{ep.years < 7 ? " Fewer than seven years is shorter than a full cycle for a cyclical, so weigh it as a starting point, not a settled figure." : ""} It assumes that revenue is a fair base, so for a
      business at a clear revenue peak or trough, or one that has structurally changed, the older years mislead and
      the figure is only a starting point. A yardstick to weigh the reported year against, never a target.
    </p>
  </section>
) : null}

<style>
  /* A coda to the record above, not a peer section: it hugs the table it reads from and wears
     a subordinate heading (smaller than the record's), so the eye treats it as the record's
     conclusion rather than a fresh topic. */
  .norm { margin: 8px 0 24px; }
  .head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule); padding-bottom: 6px; }
  .head h3 { margin: 0; font-family: var(--serif); font-weight: 600; font-size: clamp(17px, 2.6vw, 20px); letter-spacing: -0.01em; color: var(--ink); line-height: 1.2; }
  .coda { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); flex: 0 0 auto; }
  .lede { font-family: var(--serif); font-size: clamp(15px, 2.3vw, 17px); line-height: 1.5; margin: 12px 0 0; max-width: 72ch; }
  .lede b { font-weight: 600; }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px 24px; margin: 16px 0 0; }
  .cell { display: flex; flex-direction: column; padding: 12px 0; border-top: 1px solid var(--rule); }
  .cl { font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .cv { font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums; margin-top: 3px; letter-spacing: -0.01em; }
  .cv.hot { color: var(--accent); }
  .sub { font-size: 12px; color: var(--muted); margin-top: 3px; line-height: 1.4; }

  .read { font-size: 14.5px; line-height: 1.6; color: var(--ink-soft); margin: 14px 0 0; max-width: 74ch; }
  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule); margin-top: 14px; padding-top: 11px; max-width: 74ch; line-height: 1.5; }

  @media (max-width: 620px) { .grid { grid-template-columns: 1fr; gap: 0; } }
</style>
