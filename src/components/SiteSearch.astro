---
// A site-wide search overlay (a command palette), included once in the base layout so it rides on
// every page. Press "/" or ⌘K (Ctrl+K) from anywhere — or the masthead search button — and jump to
// any company by name or ticker without first going home. It loads its index lazily, the one compact
// /company-index.json file, fetched on first open and cached by the browser, so it adds nothing to
// each page's HTML. The matching and ranking mirror the home page exactly: punctuation-insensitive,
// a household name ahead of a tiny look-alike, a US listing ahead of a foreign duplicate.
---

<div id="siteSearch" class="ss" hidden>
  <div class="ssBackdrop" data-ss-close></div>
  <div class="ssDialog" role="dialog" aria-modal="true" aria-label="Search companies">
    <div class="ssField">
      <svg class="ssIcon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="ssInput"
        type="search"
        placeholder="Search every company by name or ticker…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Search every company by name or ticker"
        role="combobox"
        aria-expanded="false"
        aria-controls="ssResults"
        aria-autocomplete="list"
      />
      <button class="ssEsc" type="button" data-ss-close aria-label="Close search">esc</button>
    </div>
    <div class="ssBody">
      <div class="ssCount" id="ssCount" aria-live="polite" hidden></div>
      <ul class="ssResults" id="ssResults" role="listbox" aria-label="Matching companies"></ul>
      <p class="ssMsg" id="ssEmpty" hidden>No company matches that. Try a ticker, or part of a name.</p>
      <p class="ssMsg" id="ssLoading" hidden>Loading the index…</p>
      <p class="ssHint" id="ssHint">
        Search all companies — <b>United States</b>, <b>Japan</b>, and <b>ADRs</b>.
        <span class="ssKeys"><kbd>↑</kbd><kbd>↓</kbd> move · <kbd>↵</kbd> open · <kbd>esc</kbd> close</span>
      </p>
    </div>
  </div>
</div>

<style>
  .ss { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: flex-start; justify-content: center; }
  .ss[hidden] { display: none; }
  .ssBackdrop { position: absolute; inset: 0; background: rgba(10, 11, 14, 0.55); backdrop-filter: blur(2px); }
  :root[data-theme="dark"] .ssBackdrop { background: rgba(0, 0, 0, 0.62); }
  .ssDialog {
    position: relative; width: min(620px, calc(100vw - 28px)); margin-top: clamp(48px, 12vh, 132px);
    background: var(--surface); border: 1px solid var(--rule-strong); border-radius: 12px;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.4); overflow: hidden;
  }

  .ssField { display: flex; align-items: center; gap: 10px; padding: 0 14px; border-bottom: 1px solid var(--rule); }
  .ssIcon { width: 19px; height: 19px; color: var(--faint); flex: 0 0 auto; }
  .ssField:focus-within .ssIcon { color: var(--accent); }
  #ssInput {
    flex: 1 1 auto; min-width: 0; border: 0; background: none; outline: none;
    font-family: var(--sans); font-size: 17px; color: var(--ink); padding: 16px 0; line-height: 1.2;
  }
  #ssInput::placeholder { color: var(--faint); }
  #ssInput::-webkit-search-cancel-button { -webkit-appearance: none; }
  .ssEsc {
    flex: 0 0 auto; font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--muted);
    border: 1px solid var(--rule-strong); border-radius: 4px; padding: 3px 8px; line-height: 1.3;
    background: var(--paper); cursor: pointer;
  }
  .ssEsc:hover { color: var(--accent); border-color: var(--accent); }

  .ssBody { max-height: min(64vh, 520px); overflow-y: auto; }
  .ssCount { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); padding: 10px 16px 4px; font-variant-numeric: tabular-nums; }
  .ssResults { list-style: none; margin: 0; padding: 6px; }

  /* Result rows are built in JavaScript and never carry Astro's scope attribute, so scope the
     container and mark the dynamic descendants :global to let their styles apply. */
  .ssResults :global(.res) { margin: 0; border-radius: 7px; }
  .ssResults :global(.resLink) { display: flex; align-items: baseline; gap: 10px; padding: 10px 12px; min-width: 0; color: var(--ink); }
  .ssResults :global(.resLink:hover) { text-decoration: none; }
  .ssResults :global(.res.is-active) { background: var(--accent-tint); }
  .ssResults :global(.res.is-active .resName) { color: var(--accent); }
  .ssResults :global(.res.is-active .resTicker) { color: var(--accent); }
  .ssResults :global(.resName) { font-size: 15px; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1 1 auto; min-width: 0; }
  .ssResults :global(.resTicker) { font-family: var(--sans); font-weight: 700; font-variant-numeric: tabular-nums; font-size: 11.5px; letter-spacing: 0.03em; color: var(--muted); flex: 0 0 auto; }
  .ssResults :global(.resPlace) { font-size: 10.5px; letter-spacing: 0.02em; color: var(--tag-ink); background: var(--tag-bg); border-radius: 3px; padding: 2px 7px; white-space: nowrap; flex: 0 0 auto; }

  .ssMsg { font-family: var(--serif); font-style: italic; color: var(--muted); margin: 0; padding: 22px 16px; }
  .ssHint { font-size: 12px; color: var(--muted); margin: 0; padding: 12px 16px; border-top: 1px solid var(--rule); display: flex; flex-wrap: wrap; gap: 6px 14px; justify-content: space-between; align-items: center; }
  .ssHint b { color: var(--ink-dim); font-weight: 600; }
  .ssKeys { display: inline-flex; align-items: center; gap: 6px; color: var(--faint); white-space: nowrap; }
  .ssKeys kbd { font-family: var(--sans); font-size: 10.5px; font-weight: 600; border: 1px solid var(--rule-strong); border-radius: 3px; padding: 1px 5px; color: var(--muted); }
  @media (max-width: 520px) { .ssKeys { display: none; } }

  body.ssOpen { overflow: hidden; }
</style>

<script>
  (function () {
    const root = document.getElementById("siteSearch");
    const input = document.getElementById("ssInput");
    const list = document.getElementById("ssResults");
    const countEl = document.getElementById("ssCount");
    const emptyEl = document.getElementById("ssEmpty");
    const loadingEl = document.getElementById("ssLoading");
    const hintEl = document.getElementById("ssHint");
    if (!root || !input || !list) return;

    const MAX = 40;
    const sortKey = (s) => String(s).replace(/^the\s+/i, "").replace(/^[^a-z0-9]+/i, "").trim().toLowerCase();
    const sq = (s) => s.replace(/[^a-z0-9]+/g, "");

    let INDEX = null;     // built lazily on first open
    let loadState = 0;    // 0 = not started, 1 = loading, 2 = ready, 3 = failed
    let shown = [];
    let active = -1;
    let lastFocus = null;

    function build(r) {
      const ticker = String(r[0] || ""), name = String(r[1] || ticker), pool = r[2] || 0, prom = r[3] || 0, place = String(r[4] || "");
      const nl = name.toLowerCase();
      const href = pool === 2 ? "/jp/" + ticker : "/c/" + ticker;
      const hay = nl + " " + ticker.toLowerCase() + " " + place.toLowerCase();
      return { ticker, name, place, href, pool, prom, tl: ticker.toLowerCase(), words: nl.split(/[^a-z0-9]+/).filter(Boolean), nlsq: sq(nl), nksq: sq(sortKey(name)), haysq: sq(hay) };
    }

    async function ensureIndex() {
      if (loadState === 2 || loadState === 1) return;
      loadState = 1;
      showLoading(true);
      try {
        const res = await fetch("/company-index.json", { cache: "force-cache" });
        const data = await res.json();
        INDEX = (data.rows || []).map(build);
        loadState = 2;
      } catch (e) {
        INDEX = [];
        loadState = 3;
      }
      showLoading(false);
      if (root.hidden) return;
      if (input.value.trim()) onInput();
      else if (hintEl) hintEl.hidden = false;   // nothing typed yet — bring the hint back
    }

    function showLoading(on) {
      if (loadingEl) loadingEl.hidden = !on;
      if (on && hintEl) hintEl.hidden = true;
    }

    function rank(term) {
      const t = term.trim().toLowerCase();
      const tq = sq(t);
      if (!tq || !INDEX) return [];
      const out = [];
      for (let i = 0; i < INDEX.length; i++) {
        const it = INDEX[i];
        let s = -1;
        if (it.tl === tq) s = 0;
        else if (it.tl.indexOf(tq) === 0) s = 1;
        else if (it.nlsq.indexOf(tq) === 0 || it.nksq.indexOf(tq) === 0) s = 2;
        else if (it.words.some((w) => w.indexOf(t) === 0)) s = 3;
        else if (it.nlsq.indexOf(tq) >= 0) s = 4;
        else if (it.haysq.indexOf(tq) >= 0) s = 5;
        if (s >= 0) out.push({ it, s });
      }
      out.sort((a, b) =>
        a.s - b.s ||
        a.it.pool - b.it.pool ||
        b.it.prom - a.it.prom ||
        a.it.name.length - b.it.name.length ||
        a.it.nlsq.localeCompare(b.it.nlsq));
      return out;
    }

    function setActive(i) {
      const items = list.children;
      if (active >= 0 && items[active]) { items[active].classList.remove("is-active"); items[active].setAttribute("aria-selected", "false"); }
      active = i;
      if (active >= 0 && items[active]) {
        items[active].classList.add("is-active");
        items[active].setAttribute("aria-selected", "true");
        input.setAttribute("aria-activedescendant", items[active].id);
        items[active].scrollIntoView({ block: "nearest" });
      } else {
        input.removeAttribute("aria-activedescendant");
      }
    }

    function render(term) {
      const matches = rank(term);
      shown = matches.slice(0, MAX).map((m) => m.it);
      list.textContent = "";
      active = -1;
      input.removeAttribute("aria-activedescendant");
      if (hintEl) hintEl.hidden = true;

      if (!matches.length) {
        countEl.hidden = true;
        emptyEl.hidden = loadState !== 2;   // while still loading, don't claim "no match"
        input.setAttribute("aria-expanded", String(loadState === 2));
        return;
      }
      emptyEl.hidden = true;
      countEl.hidden = false;
      countEl.textContent = matches.length > MAX
        ? ("Showing " + MAX + " of " + matches.length.toLocaleString() + " — keep typing to narrow")
        : (matches.length + (matches.length === 1 ? " match" : " matches"));

      shown.forEach((it, i) => {
        const li = document.createElement("li");
        li.className = "res";
        li.id = "ss-res-" + i;
        li.setAttribute("role", "option");
        li.setAttribute("aria-selected", "false");
        const a = document.createElement("a");
        a.className = "resLink";
        a.href = it.href;
        a.tabIndex = -1;
        const n = document.createElement("span"); n.className = "resName"; n.textContent = it.name || it.ticker;
        const t = document.createElement("span"); t.className = "resTicker"; t.textContent = it.ticker;
        a.appendChild(n); a.appendChild(t);
        if (it.place) { const p = document.createElement("span"); p.className = "resPlace"; p.textContent = it.place; a.appendChild(p); }
        li.appendChild(a);
        li.addEventListener("mouseenter", () => setActive(i));
        list.appendChild(li);
      });
      input.setAttribute("aria-expanded", "true");
    }

    function onInput() {
      const term = (input.value || "").trim();
      if (!term) {
        list.textContent = "";
        shown = []; active = -1;
        countEl.hidden = true; emptyEl.hidden = true;
        if (hintEl) hintEl.hidden = loadState === 1;
        input.setAttribute("aria-expanded", "false");
        input.removeAttribute("aria-activedescendant");
        return;
      }
      render(term);
    }

    function go(it) { if (it && it.href) window.location.href = it.href; }

    function open() {
      if (!root.hidden) return;
      lastFocus = document.activeElement;
      root.hidden = false;
      document.body.classList.add("ssOpen");
      ensureIndex();
      // focus after paint so the field is ready
      requestAnimationFrame(() => { input.focus(); input.select(); });
    }
    function close() {
      if (root.hidden) return;
      root.hidden = true;
      document.body.classList.remove("ssOpen");
      input.value = "";
      list.textContent = "";
      shown = []; active = -1;
      countEl.hidden = true; emptyEl.hidden = true;
      if (hintEl) hintEl.hidden = false;
      input.setAttribute("aria-expanded", "false");
      input.removeAttribute("aria-activedescendant");
      if (lastFocus && lastFocus.focus) { try { lastFocus.focus(); } catch (e) {} }
    }

    // Open from the home page's own box when it is the one in view, else open this overlay. This
    // keeps a single, coherent search on the search-first home page and the overlay everywhere else.
    function openSearch() {
      const omni = document.getElementById("omni");
      const sv = document.getElementById("searchView");
      if (omni && sv && !sv.hidden) { omni.focus(); return; }
      open();
    }
    window.__ownerSearch = openSearch;

    input.addEventListener("input", onInput);
    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") { e.preventDefault(); if (shown.length) setActive(Math.min((active < 0 ? -1 : active) + 1, shown.length - 1)); }
      else if (e.key === "ArrowUp") { e.preventDefault(); if (shown.length) setActive(Math.max(active - 1, 0)); }
      else if (e.key === "Enter") { if (shown.length) { e.preventDefault(); go(shown[active >= 0 ? active : 0]); } }
    });

    // Escape and the focus trap live on the dialog, so they work whether the input or the esc button
    // holds focus. The trap cycles between the only two tab stops (the field and the esc button);
    // results are reached with the arrow keys, not Tab.
    root.addEventListener("keydown", (e) => {
      if (e.key === "Escape") { e.preventDefault(); close(); return; }
      if (e.key !== "Tab") return;
      const stops = [input, root.querySelector(".ssEsc")].filter(Boolean);
      if (stops.length < 2) return;
      let i = stops.indexOf(document.activeElement);
      if (i < 0) i = 0;
      let j = i + (e.shiftKey ? -1 : 1);
      if (j < 0) j = stops.length - 1;
      else if (j >= stops.length) j = 0;
      e.preventDefault();
      stops[j].focus();
    });

    list.addEventListener("click", (e) => {
      if (e.target.closest("a")) return;
      const li = e.target.closest(".res");
      if (li) { const i = Array.prototype.indexOf.call(list.children, li); go(shown[i]); }
    });

    root.querySelectorAll("[data-ss-close]").forEach((el) => el.addEventListener("click", close));

    const opener = document.getElementById("siteSearchOpen");
    if (opener) opener.addEventListener("click", (e) => { e.preventDefault(); openSearch(); });

    document.addEventListener("keydown", (e) => {
      // ⌘K / Ctrl+K opens from anywhere.
      if ((e.metaKey || e.ctrlKey) && (e.key === "k" || e.key === "K")) { e.preventDefault(); openSearch(); return; }
      // "/" opens too, but never when a field is focused, and never on the home page (its own box
      // owns "/" there — detected by the presence of #omni).
      if (e.key === "/" && !root.hidden) return;
      if (e.key === "/") {
        const tag = ((document.activeElement || {}).tagName || "").toLowerCase();
        if (tag === "input" || tag === "textarea" || tag === "select") return;
        if (document.getElementById("omni")) return;
        e.preventDefault();
        open();
      }
    });
  })();
</script>
