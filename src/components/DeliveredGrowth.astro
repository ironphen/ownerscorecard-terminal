---
// A record anchor for a reverse-DCF growth dial: the rate the business actually delivered,
// beside a sparkline of the series it is read from, so the reader sets an assumption against
// the record rather than in a vacuum. A yardstick, never a target; withheld when the record
// is too short to read.
import Sparkline from "./Sparkline.astro";

const { cagr = null, series = [], label = "Delivered" } = Astro.props;
const xs = (series || []).filter((v) => v != null);
const pct = (v) => (v == null ? "—" : `${v < 0 ? "−" : ""}${Math.abs(v * 100).toFixed(0)}%`);
const show = cagr != null && xs.length >= 3;
---

{show ? (
  <p class="deliv" title={`What ${label.toLowerCase()} actually did over the last ${xs.length} years on record, the dial's starting point`}>
    <span class="dl">{label}</span>
    <b>{pct(cagr)}/yr</b>
    <Sparkline series={xs} />
    <span class="dn">{xs.length}-yr record</span>
  </p>
) : null}

<style>
  .deliv { display: flex; align-items: center; gap: 9px; margin: 5px 0 2px; font-size: 12.5px; flex-wrap: wrap; }
  .dl { font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--faint); }
  .deliv b { font-variant-numeric: tabular-nums; color: var(--ink-soft); font-weight: 700; }
  .dn { color: var(--faint); font-size: 11.5px; }
</style>
