---
// An act divider for the company page: a Roman numeral, the act's title, and a one-line read
// of what that stretch of the page covers. The page is long because a business has many facets;
// the acts give that length a spine so it reads as a sequence, not a stack.
const { n, title, lede } = Astro.props;
---

<header class="actHead">
  <span class="actNum">{n}</span>
  <div class="actBody">
    <h2 class="actTitle">{title}</h2>
    {lede ? <p class="actLede">{lede}</p> : null}
  </div>
</header>

<style>
  .actHead { display: flex; align-items: baseline; gap: 16px; margin: 40px 0 8px; padding-top: 16px; border-top: 2px solid var(--rule-strong); }
  .actNum { font-family: var(--serif); font-size: clamp(20px, 3vw, 26px); font-weight: 600; color: var(--accent); line-height: 1.1; flex: 0 0 auto; letter-spacing: 0.03em; min-width: 1.4em; }
  .actBody { flex: 1 1 auto; }
  .actTitle { font-family: var(--serif); font-size: clamp(22px, 3.4vw, 28px); font-weight: 600; margin: 0; letter-spacing: -0.01em; color: var(--ink); line-height: 1.12; }
  .actLede { font-family: var(--serif); font-style: italic; font-size: 14px; line-height: 1.55; color: var(--muted); margin: 6px 0 0; max-width: 78ch; }
  @media (max-width: 560px) { .actHead { gap: 11px; margin-top: 32px; } }
</style>
