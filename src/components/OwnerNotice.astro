---
// "What an owner would notice" — the Buffett read, surfaced. Past the year-over-year diff (which
// the panel above carries) lie the handful of things Buffett and Munger actually stop on in a 10-K:
// whether the company sets its price or takes it, where the reported numbers rest on management's
// own judgment, and the grave integrity admissions. The detector in scripts/fetchFilings.mjs reads
// each from the filing's own words; this lays them out, the company's sentence beneath every one,
// and never grades. Present, never pronounce.
import language from "../data/language.json";
import { TONE_COLOR } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const L = language?.companies?.[company.ticker] || null;
const b = L?.buffettRead || null;
const fy = L?.fy || company.fy;

// Build the items in the order an owner reads them: the moat question (pricing) first, then the
// grave integrity admissions, then — as context for all of it — where the numbers rest on judgment.
const items = [];
if (b?.pricing) {
  const p = b.pricing;
  // Pricing power: the single fact Buffett calls most important in judging a business. Shown when
  // the company demonstrated it; when it also names pricing pressure, the tension is shown honestly.
  if (p.power) {
    const contested = !!p.pressure;
    // The strongest form Buffett names: raising price without losing volume. When the filing shows
    // it, say so plainly; when it merely raised price, note that and send the reader to the volume.
    const label = p.powerStrong ? "Raises price without losing customers" : contested ? "Raises price, but not unopposed" : "Sets its price";
    const tone = p.powerStrong ? "good" : contested ? "info" : "good";
    const note = p.powerStrong
      ? "The strongest form of a moat, in Buffett's words: the company raised prices and volume held or grew with them — pricing power a competitor could not punish. The surest sign you are looking at a very good business; the record above shows whether the margin followed."
      : contested
        ? "In its results discussion the company attributes gains to higher pricing — yet the same filing names price competition too. Pricing power that must be defended is still worth more than none; read the two together, and watch the margin in the record above."
        : "Buffett's surest mark of a moat: in its own results discussion the company raised prices and tied the gain to them, not to volume alone. Whether that holds is the question to carry forward — the record above shows whether the margin held with it.";
    items.push({ key: "pricing", label, tone, quote: p.power, note });
  } else if (p.pressure) {
    items.push({
      key: "pricing",
      label: "Takes its price",
      tone: "warn",
      quote: p.pressure,
      note: "The filing describes price competition or price cuts rather than pricing actions of its own — the mark of a business that takes the price the market sets rather than setting it. Watch the operating margin in the record above for what that costs.",
    });
  }
  // Cost pass-through: the margin-durability complement to pricing power.
  if (p.costInflation) {
    items.push({
      key: "costs",
      label: p.passedThrough ? "Passed rising costs through" : "Absorbed rising costs",
      tone: p.passedThrough ? "good" : "warn",
      quote: p.costInflation,
      note: p.passedThrough
        ? "Input costs rose and the company says it recovered them in price — the second half of pricing power, and what keeps a margin durable through inflation."
        : "Input costs rose and the company could not fully pass them on — which is where a margin quietly compresses. Set it against the margin trend in the record above.",
    });
  }
}
// Accounting integrity: the rarest, gravest admissions. When present, they outweigh the rest.
if (b?.integrity?.materialWeakness)
  items.push({
    key: "mw",
    label: "Material weakness in financial controls",
    tone: "bad",
    quote: b.integrity.materialWeakness,
    note: "The company's own controls over its financial reporting were found deficient. Graham's honesty test: the numbers above are only as good as the system that produced them. The most serious thing in this read.",
  });
if (b?.integrity?.restatement)
  items.push({
    key: "restate",
    label: "Restated past financials",
    tone: "bad",
    quote: b.integrity.restatement,
    note: "The company restated numbers it had previously reported. Figures in the record above may have moved since they were first filed; read what was restated, and why, before trusting the trend.",
  });

// Where the numbers rest on judgment — shown last, as context for everything above rather than as a
// flag of its own. Every business has critical estimates; the read is which, and how many.
const judgment = b?.judgment && b.judgment.count >= 1 ? b.judgment : null;

const hasContent = items.length || judgment;
---

{hasContent ? (
  <section class="notice">
    <div class="head">
      <h3 class="secTitle">What an owner would notice{fy ? `, FY${fy}` : ""}</h3>
      {L?.sourceUrl ? <a class="src" href={L.sourceUrl} target="_blank" rel="noopener">read the 10-K →</a> : null}
    </div>
    <p class="intro">
      The handful of things Buffett and Munger actually stop on in a filing: whether the company sets its
      price or takes it, anything it had to admit about the figures themselves, and where those figures
      rest on management's own judgment. Each below is the company's own sentence — we point, you weigh it.
    </p>

    {items.length ? (
      <ul class="items">
        {items.map((it) => (
          <li>
            <span class="lens" style={`color:${TONE_COLOR[it.tone]}`}>{it.label}</span>
            <p class="why">{it.note}</p>
            <blockquote style={`border-color:${TONE_COLOR[it.tone]}`}>“{it.quote}{it.quote.length >= 290 ? "…" : ""}”</blockquote>
          </li>
        ))}
      </ul>
    ) : null}

    {judgment ? (
      <div class="judge">
        <div class="jhead">
          <span class="lens">Where the numbers rest on judgment</span>
          <span class="count">{judgment.count} critical estimate{judgment.count === 1 ? "" : "s"}</span>
        </div>
        <p class="why">
          The figures above lean most on management's own assumptions in the {judgment.count} area{judgment.count === 1 ? "" : "s"} the
          filing itself singles out as critical to its accounting:
        </p>
        <div class="topics">{judgment.topics.map((t) => <span class="topic">{t}</span>)}</div>
        <p class="jnote">
          More estimates is not worse — every business carries them — but each is a number that is partly an
          opinion. When earnings turn on goodwill, reserves or the timing of revenue, that is where to read the
          filing's notes hardest.
        </p>
      </div>
    ) : null}

    <p class="foot">Classic text analysis of the filing's own Business, MD&amp;A and Risk Factors — no model wrote a word, and every quote is the company's. A lens, never a verdict.</p>
  </section>
) : null}

<style>
  .notice { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .secTitle { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 70ch; line-height: 1.6; }

  .items { list-style: none; padding: 0; margin: 12px 0 0; }
  .items li { padding: 14px 0; border-bottom: 1px solid var(--rule); }
  .lens { font-family: var(--sans); font-weight: 700; font-size: 15px; }
  .why { font-size: 13px; color: var(--ink-dim); margin: 5px 0 0; line-height: 1.55; max-width: 74ch; }
  blockquote {
    font-family: var(--serif); font-size: 14.5px; line-height: 1.5; color: var(--ink-soft);
    border-left: 2px solid var(--accent); padding: 3px 0 3px 14px; margin: 9px 0 0; max-width: 74ch;
  }

  .judge { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .jhead { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .jhead .lens { color: var(--ink); }
  .count { font-family: var(--sans); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; }
  .topics { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; }
  .topic { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.02em; color: var(--ink); border: 1px solid var(--rule-strong); padding: 3px 9px; }
  .jnote { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 10px 0 0; line-height: 1.6; max-width: 72ch; }

  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 16px; padding-top: 10px; max-width: 74ch; }
</style>
