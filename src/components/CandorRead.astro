---
// The Candor Read — how management talks to owners, read against the test Buffett actually used: own a
// business with a partner, be away a year, and a straight partner tells you plainly what changed, how it
// performed, and what went wrong — not a sales pitch. So the section answers that test in three parts:
//   1. What management SAYS CHANGED this year — the affirmative account an absent owner needs, taken from
//      the year-over-year read of the MD&A (its own performance sentences, surfaced verbatim).
//   2. The WORDS it reached for — the actual phrases it used, surfaced verbatim: an owner's vocabulary, a
//      promoter's, and the off-GAAP measures that ask you to read earnings its way. No abstract density bar;
//      the words themselves, the way Buffett reads a letter.
//   3. What it OWNED — a first-person admission of a miss, and the gravest disclosures about the numbers
//      themselves (a material weakness, a restatement, the estimates the figures rest on).
// All deterministic, all the company's own words; the detectors live in scripts/fetchFilings.mjs. This
// presents the account and the tells and never grades the character. Present, never pronounce.
import language from "../data/language.json";
import { TONE_COLOR } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const L = language?.companies?.[company.ticker] || null;
const c = L?.mdna?.candor || null;
const fy = L?.fy || company.fy;

// --- Part 1: what management says changed this year ---
// An owner who's been away a year wants the performance account first. Our year-over-year MD&A read
// already surfaces what's new; here we keep only the sentences that report on the business — a direction
// or a cause (MOVE), best of all with a figure (NUM) — and rank those highest. We DEMOTE forward-looking,
// hypothetical risk language (HYPO: "tariffs could adversely affect" is a warning, not a report of the
// year), number-dominated table debris (a flattened EBIT bridge), and accounting-policy lines, so
// "income fell 28% on lower volume" and "gross margin decreased to 71.1% from 75.0%" lead.
const MOVE = /\b(increase|decrease|declin|grew|grow|grown|rose|risen|fell|fall|fallen|higher|lower|improv|impact|driven|drove|due to|offset|reduct|reduced|gain|loss|weaker|stronger|favorab|unfavorab|partially|primarily)\b/i;
const NUM = /\$\s?[\d,]+(\.\d+)?|\b\d+(\.\d+)?\s?(%|percent|basis points|bps)\b/i;
const HYPO = /\b(could|would|may |might|can have|cannot|uncertain|expect|anticipat|intend|potential|adversely|believe|our future|if a |if the|if we|risks?)\b/i;
const tableLike = (s) => { const t = String(s).split(/\s+/); return t.length > 8 && t.filter((x) => /^[\$(]?-?[\d,]+(\.\d+)?\)?$/.test(x)).length / t.length > 0.18; };
// Accounting-policy / definitional sentences ("we include … in Other income", "revenue is recognized
// when …") describe how the books are kept, not how the year went — demote them too.
const POLICY = /\b(is|are) defined as|\b(is|are) recognized|\bwe include\b|\bwe classify\b|\bwe account for\b|in accordance with|under the [a-z ]{0,24} model/i;
const score = (s) => (NUM.test(s) ? 2 : 0) + (MOVE.test(s) ? 1 : 0) - (HYPO.test(s) ? 3 : 0) - (tableLike(s) ? 2 : 0) - (POLICY.test(s) ? 2 : 0);
function tidy(s) {
  s = String(s).replace(/\s+/g, " ").trim().replace(/^\d+\s+/, ""); // collapse space, drop a leading page number
  const m = s.match(/[a-z\)][.](?=\s+[A-Z0-9])/); // cut at the first real sentence end (not "$1.0" or "U.S.")
  if (m && m.index >= 60) s = s.slice(0, m.index + 1);
  const cap = 260;
  if (s.length > cap) { const cut = s.slice(0, cap); const sp = cut.lastIndexOf(" "); s = (sp > 150 ? cut.slice(0, sp) : cut) + "…"; }
  return s;
}
const seenChange = new Set();
const ranked = (L?.mdnaChange?.notable || [])
  .map((s) => ({ t: tidy(s), sc: score(s) })) // score the source; tidy only for display
  .filter((x) => x.sc >= 1 && x.t.length >= 60)
  .sort((a, b) => b.sc - a.sc)
  .filter((x) => { const k = x.t.slice(0, 50).toLowerCase(); if (seenChange.has(k)) return false; seenChange.add(k); return true; });
// Lead with the single strongest performance sentence; add more only if they too clear the bar (sc ≥ 2),
// so a noisy table or a policy line never pads the list beneath a clean lede. A company whose only real
// change reads without a figure (Apple's margin line) still shows its one good sentence.
const told = ranked.length ? [ranked[0].t, ...ranked.slice(1).filter((x) => x.sc >= 2).map((x) => x.t)].slice(0, 3) : [];

// --- Part 2: the words it reached for ---
// The per-1,000-word bars are gone. A density against a hidden norm taught an owner nothing, and for most
// filings the bars sat near-empty (the catalog medians are owner 1.2, promoter 0.2, adjusted 0.3 — a third
// of filings score a flat zero on the latter two). Buffett doesn't count owner-words per 1,000; he catches
// the management in the actual word it chose. So we surface the verbatim phrases each detector matched, and
// gloss frequency in plain English only at the extreme — the catalog's top decile (owner ≥ 2.9, promoter ≥
// 0.8, adjusted ≥ 4.8 per 1,000 words). A filing that reaches for neither a promoter's vocabulary nor an
// off-GAAP measure is plainspoken, itself a finding (18% of filings clear that bar). The phrase arrays
// appear once the scorer that captures them has run; until then a present register degrades to a plain
// "used in the MD&A" line from its density alone — never a bar.
const PCTL = { owner: 2.9, promo: 0.8, adjusted: 4.8 };
const arr = (v) => (Array.isArray(v) ? v : null);
const registers = c
  ? [
      { key: "owner", tone: "good", label: "An owner's vocabulary", words: arr(c.ownerWords), density: c.owner ?? 0, top: (c.owner ?? 0) >= PCTL.owner },
      { key: "promo", tone: "warn", label: "A promoter's vocabulary", words: arr(c.promoWords), density: c.promo ?? 0, top: (c.promo ?? 0) >= PCTL.promo },
      { key: "adjusted", tone: "info", label: "“Look past GAAP”", words: arr(c.adjustedWords), density: c.adjusted ?? 0, top: (c.adjusted ?? 0) >= PCTL.adjusted },
    ].map((r) => ({ ...r, present: r.words ? r.words.length > 0 : r.density > 0 }))
  : [];
const shownRegisters = registers.filter((r) => r.present);
// Plainspoken is a positive tell — a filing that neither sells nor steers you off GAAP. We judge it on the
// two "selling" registers (promoter + adjusted); an owner's vocabulary is a different axis and its absence
// is no virtue.
const promoReg = registers.find((r) => r.key === "promo");
const adjReg = registers.find((r) => r.key === "adjusted");
const plainspoken = !!c && !!promoReg && !!adjReg && !promoReg.present && !adjReg.present;

const admissions = c?.admissions || [];

// --- Part 3: what it had to disclose about the numbers ---
// The gravest, rarest disclosures (a deficient control system, a restatement), shown with the company's
// own sentence. The Scorecard already ties these to the reliability of the numbers; here is the evidence.
const integrity = L?.buffettRead?.integrity || null;
const integrityItems = [];
if (integrity?.materialWeakness)
  integrityItems.push({
    label: "Material weakness in financial controls", quote: integrity.materialWeakness,
    note: "The company's own controls over its financial reporting were found deficient. Graham's honesty test: the figures in the record above are only as good as the system that produced them. The most serious thing in this read.",
  });
if (integrity?.restatement)
  integrityItems.push({
    label: "Restated past financials", quote: integrity.restatement,
    note: "The company restated numbers it had previously reported. Figures in the record may have moved since they were first filed; read what was restated, and why, before trusting the trend.",
  });
// Where the reported numbers rest on management's own assumptions — the areas the filing itself names as
// critical to its accounting. More is not worse; each is a number that is partly an opinion.
const judgment = L?.buffettRead?.judgment && L.buffettRead.judgment.count >= 1 ? L.buffettRead.judgment : null;

const hasContent = !!c || told.length || integrityItems.length || judgment;

// The intro promises only the pillars this filing actually offers. A thin filing — where the year-over-
// year MD&A surfaced no plain performance sentence, common enough — then reads as the language bars it
// has, not as a broken promise of a "what changed" account that was never there.
const pillars = [];
if (told.length) pillars.push("what it says changed");
if (c) pillars.push("the words it reached for");
if (admissions.length || integrityItems.length || judgment) pillars.push("what it was willing to own");
---

{hasContent ? (
  <section class="candor">
    <div class="head">
      <h3 class="secTitle">How management talks to owners{fy ? `, FY${fy}` : ""}</h3>
      {L?.sourceUrl ? <a class="src" href={L.sourceUrl} target="_blank" rel="noopener">read the 10-K →</a> : null}
    </div>

    <p class="intro">
      Buffett's test for a report: imagine you own this business with a partner and you've been away a
      year. A straight partner tells you plainly what changed, how the business performed, and what went
      wrong — the things an owner needs to know, not a sales pitch. Here is this year's filing read against
      that test: {pillars.map((p, i) => (
        <>{i > 0 ? (i === pillars.length - 1 ? (pillars.length > 2 ? ", and " : " and ") : ", ") : ""}<em>{p}</em></>
      ))}. Every line below is the company's own; the character is yours to judge.
    </p>

    {told.length ? (
      <div class="changed">
        <h4 class="aHead">What management says changed this year</h4>
        <p class="aIntro">
          The first thing an absent owner asks: what actually moved, and why. From the year-over-year read
          of the MD&amp;A — the sentences it added this year that report on the business, in its own words.
        </p>
        <ul class="quotes change">{told.map((q) => <li>“{q}”</li>)}</ul>
      </div>
    ) : null}

    {c ? (
      <div class="how">
        <h4 class="aHead">The words it reached for</h4>
        <p class="aIntro">
          The second test is <em>how</em> it tells you. An owner reasons in per-share value, returns and the
          long term; a promoter sells; a filing that keeps steering you off GAAP is asking you to measure
          earnings its way. Here are the actual words this filing reached for — and where it stayed plain.
        </p>
        {shownRegisters.length ? (
          <ul class="regs">
            {shownRegisters.map((r) => (
              <li class="reg">
                <div class="regHead">
                  <span class="rLabel" style={`color:${TONE_COLOR[r.tone]}`}>{r.label}</span>
                  {r.top ? <span class="rFreq">heavier than 9 in 10 filings</span> : null}
                </div>
                {r.words && r.words.length ? (
                  <div class="chips">{r.words.map((w) => <span class="chip" style={`border-color:${TONE_COLOR[r.tone]}`}>“{w}”</span>)}</div>
                ) : (
                  <p class="rDeg">{r.top ? "A recurring feature of this year's MD&A." : "Used in this year's MD&A."}</p>
                )}
              </li>
            ))}
          </ul>
        ) : null}
        {plainspoken ? (
          <p class="plain" style={`border-color:${TONE_COLOR.good}`}>
            <strong>Plainspoken.</strong> No marketing superlatives, and the filing never steered you off GAAP to
            measure earnings its own way — plainer than four in five filings. Graham's preference was exactly this:
            a report that lets the numbers carry the argument.
          </p>
        ) : null}
      </div>
    ) : null}

    {admissions.length ? (
      <div class="admit">
        <h4 class="aHead">What it owned, in its own words</h4>
        <p class="aIntro">The rarest tell in any filing — and the one a part-owner trusts most: management saying plainly, in the first person and past tense, that something did not go as hoped. Worth more than any adjective. Every such sentence, verbatim.</p>
        <ul class="quotes">{admissions.map((q) => <li>“{q}{q.length >= 290 ? "…" : ""}”</li>)}</ul>
      </div>
    ) : null}

    {integrityItems.length ? (
      <div class="integ">
        <h4 class="aHead">What it had to disclose about the numbers</h4>
        <p class="aIntro">The gravest, rarest tells in any filing — the company conceding its own figures may not be reliable. The scorecard above ties each to the numbers it bears on; here is the company's own sentence.</p>
        <ul class="items">
          {integrityItems.map((it) => (
            <li>
              <span class="ilabel" style={`color:${TONE_COLOR.bad}`}>{it.label}</span>
              <p class="why">{it.note}</p>
              <blockquote style={`border-color:${TONE_COLOR.bad}`}>“{it.quote}{it.quote.length >= 290 ? "…" : ""}”</blockquote>
            </li>
          ))}
        </ul>
      </div>
    ) : null}

    {judgment ? (
      <div class="judge">
        <div class="jhead">
          <span class="aHead">Where the numbers rest on judgment</span>
          <span class="count">{judgment.count} critical estimate{judgment.count === 1 ? "" : "s"}</span>
        </div>
        <p class="aIntro">
          The figures above lean most on management's own assumptions in the {judgment.count} area{judgment.count === 1 ? "" : "s"} the
          filing itself singles out as critical to its accounting:
        </p>
        <div class="topics">{judgment.topics.map((t) => <span class="topic">{t}</span>)}</div>
        <p class="jnote">
          More estimates is not worse — every business carries them — but each is a number that is partly an
          opinion. When earnings turn on goodwill, reserves or the timing of revenue, that is where to read the
          filing's notes hardest.
        </p>
      </div>
    ) : null}

    <p class="foot">Classic text analysis of the filing itself, and every quote is the company's own. A lens on what an owner would want told, never a score.</p>
  </section>
) : null}

<style>
  .candor { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .secTitle { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 72ch; line-height: 1.6; }
  .intro em { font-style: normal; font-weight: 600; color: var(--ink-soft); }

  /* Part 1 — what changed this year: the affirmative owner's account, led first. */
  .changed { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .quotes.change li { border-left-color: var(--accent); color: var(--ink-soft); }

  .how { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .regs { list-style: none; padding: 0; margin: 12px 0 0; }
  .reg { padding: 11px 0; border-bottom: 1px solid var(--rule); }
  .regHead { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .rLabel { font-family: var(--sans); font-weight: 700; font-size: 14px; }
  .rFreq { font-family: var(--sans); font-style: italic; font-size: 11px; letter-spacing: 0.02em; color: var(--muted); flex: 0 0 auto; }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; margin: 9px 0 0; }
  .chip { font-family: var(--serif); font-size: 13.5px; color: var(--ink-soft); border: 1px solid var(--rule-strong); border-left-width: 2px; padding: 2px 9px; line-height: 1.5; }
  .rDeg { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 8px 0 0; }
  .plain { font-family: var(--serif); font-size: 13.5px; color: var(--ink-soft); border-left: 2px solid var(--good); padding: 6px 0 6px 14px; margin: 14px 0 0; line-height: 1.6; max-width: 74ch; }
  .plain strong { font-weight: 700; color: var(--ink); font-style: normal; }

  .admit { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .aHead { font-family: var(--sans); font-weight: 700; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); margin: 0; }
  .aIntro { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 6px 0 0; max-width: 72ch; line-height: 1.55; }
  .quotes { list-style: none; padding: 0; margin: 10px 0 0; }
  .quotes li { font-family: var(--serif); font-size: 14.5px; line-height: 1.5; color: var(--ink-soft); border-left: 2px solid var(--good); padding: 3px 0 3px 14px; margin: 9px 0; }

  /* The integrity disclosures: the gravest tells, the company's own sentence beneath each. */
  .integ { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .integ .items { list-style: none; padding: 0; margin: 10px 0 0; }
  .integ .items li { padding: 12px 0; border-bottom: 1px solid var(--rule); }
  .ilabel { font-family: var(--sans); font-weight: 700; font-size: 15px; }
  .integ .why { font-size: 13px; color: var(--ink-dim); margin: 5px 0 0; line-height: 1.55; max-width: 74ch; }
  .integ blockquote { font-family: var(--serif); font-size: 14.5px; line-height: 1.5; color: var(--ink-soft); border-left: 2px solid var(--accent); padding: 3px 0 3px 14px; margin: 9px 0 0; max-width: 74ch; }

  /* Where the numbers rest on judgment: the critical-estimates read. */
  .judge { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .jhead { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .count { font-family: var(--sans); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; }
  .topics { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; }
  .topic { font-family: var(--sans); font-size: 11.5px; letter-spacing: 0.02em; color: var(--ink); border: 1px solid var(--rule-strong); padding: 3px 9px; }
  .jnote { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 10px 0 0; line-height: 1.6; max-width: 72ch; }

  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 16px; padding-top: 10px; max-width: 74ch; }
</style>
