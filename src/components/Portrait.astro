---
import { fmtUSD, roicValue, operatingMargin, ownerEarningsMargin, topLineRevenue, debtReliable } from "../lib/fundamentals.mjs";
import { returnOnEquity, returnOnTangibleEquity, efficiencyRatio, equityToAssets, returnOnAssets } from "../lib/financials.mjs";
import { ffoMargin, ffoPayout, debtToAssets } from "../lib/reits.mjs";
import { combinedRatio, lossRatio } from "../lib/insurers.mjs";
import { netMargin, feeReturnOnEquity } from "../lib/feeFinancials.mjs";
import { medicalLossRatio } from "../lib/managedCare.mjs";
import { financialKind, financialSubtype } from "../lib/archetype.mjs";
import Term from "./Term.astro";

const { company } = Astro.props;
// Trust the captured debt (for ROIC) only when interest does not prove it under-captured.
const debtOk = debtReliable(company.lines || {}) && debtReliable(company.ttm?.lines || {});
const fk = financialKind(company);
// Life insurers sit inside the insurer kind but are read on the spread and book value,
// not the combined ratio, so they get their own vital signs.
const isLife = fk === "insurer" && financialSubtype(company) === "life-insurer";
const isReit = fk === "reit", isBank = fk === "bank", isInsurer = fk === "insurer" && !isLife;
const isFee = fk === "fee", isManagedCare = fk === "managedCare";
// Net investment yield: what the float earns, the life insurer's engine.
const investmentYield = (l) => (l && l.investmentIncome != null && l.lossReserves ? l.investmentIncome / l.lossReserves : null);
const L = company.lines || {};
const rev = topLineRevenue(L, company);
const hist = company.history || [];

const revSeries = hist.map((h) => topLineRevenue(h.lines, company)).filter((v) => v != null);
const prevRev = revSeries.length >= 2 ? revSeries[revSeries.length - 2] : null;
const revGrowth = prevRev ? (rev - prevRev) / prevRev : null;
let cagr = null;
if (revSeries.length >= 4) {
  const span = Math.min(5, revSeries.length - 1);
  const first = revSeries[revSeries.length - 1 - span];
  if (first > 0) cagr = Math.pow(rev / first, 1 / span) - 1;
}

// One vital-signs strip, the universal "is it a good business?" numbers, latest
// year. (No second strip: the business-model specifics live in the record table
// and in what the filing flags below, so they aren't duplicated up here.)
// Vital signs from the freshest twelve months (TTM), each with its 5-year average
// for context, is the business running above or below its own recent norm?
const cur = company.ttm?.lines || L;
const curLabel = company.ttm?.lines ? "TTM" : `FY${company.fy}`;
const grossM = (l) => (l && l.revenue && l.costOfRevenue != null ? 1 - l.costOfRevenue / l.revenue : null);
const hist5 = hist.slice(-5).map((h) => h.lines);
const avgLabel = hist5.length >= 5 ? "5-yr average" : hist5.length >= 2 ? `${hist5.length}-yr average` : null;
const avgShort = avgLabel ? avgLabel.replace("average", "avg") : "";
const avgOf = (fn) => { const xs = hist5.map(fn).filter((v) => v != null); return xs.length ? xs.reduce((a, b) => a + b, 0) / xs.length : null; };
// Vital signs differ by archetype: a bank's "is it a good business" lives in return
// on equity and the efficiency of the operation, not in margins or ROIC.
const vitals = (isReit
  ? [
      { label: "FFO margin", concept: "ffo", value: ffoMargin(cur), avg: avgOf(ffoMargin), dp: 0 },
      { label: "Dividend payout (FFO)", concept: "ffo", value: ffoPayout(cur), avg: avgOf(ffoPayout), dp: 0 },
      { label: "Debt / assets", concept: "net-debt", value: debtToAssets(cur), avg: avgOf(debtToAssets), dp: 0 },
    ]
  : isLife
  ? [
      { label: "Return on equity", concept: "return-on-equity", value: returnOnEquity(cur), avg: avgOf(returnOnEquity), dp: 0 },
      { label: "Investment yield on float", concept: "insurance-float", value: investmentYield(cur), avg: avgOf(investmentYield), dp: 1 },
      { label: "Return on assets", concept: null, value: returnOnAssets(cur), avg: avgOf(returnOnAssets), dp: 1 },
    ]
  : isInsurer
  ? [
      { label: "Combined ratio", concept: "combined-ratio", value: combinedRatio(cur), avg: avgOf(combinedRatio), dp: 0 },
      { label: "Loss ratio", concept: "combined-ratio", value: lossRatio(cur), avg: avgOf(lossRatio), dp: 0 },
      { label: "Return on equity", concept: "return-on-equity", value: returnOnEquity(cur), avg: avgOf(returnOnEquity), dp: 0 },
    ]
  : isBank
  ? [
      { label: "Return on equity", concept: "return-on-equity", value: returnOnEquity(cur), avg: avgOf(returnOnEquity), dp: 0 },
      { label: "Return on tangible equity", concept: "rotce", value: returnOnTangibleEquity(cur), avg: avgOf(returnOnTangibleEquity), dp: 0 },
      { label: "Efficiency ratio", concept: "efficiency-ratio", value: efficiencyRatio(cur), avg: avgOf(efficiencyRatio), dp: 0 },
      { label: "Equity / assets", concept: "tangible-book", value: equityToAssets(cur), avg: avgOf(equityToAssets), dp: 1 },
    ]
  : isManagedCare
  ? [
      { label: "Medical loss ratio", concept: "medical-loss-ratio", value: medicalLossRatio(cur), avg: avgOf(medicalLossRatio), dp: 1 },
      { label: "Operating margin", concept: "operating-margin", value: operatingMargin(cur), avg: avgOf(operatingMargin), dp: 1 },
      { label: "Return on equity", concept: "return-on-equity", value: returnOnEquity(cur), avg: avgOf(returnOnEquity), dp: 0 },
    ]
  : isFee
  ? [
      { label: "Operating margin", concept: "operating-margin", value: operatingMargin(cur), avg: avgOf(operatingMargin), dp: 1 },
      { label: "Net margin", concept: null, value: netMargin(cur), avg: avgOf(netMargin), dp: 1 },
      { label: "Return on equity", concept: "return-on-equity", value: feeReturnOnEquity(cur), avg: avgOf(feeReturnOnEquity), dp: 0 },
    ]
  : [
      { label: "Gross margin", concept: "gross-margin", value: grossM(cur), avg: avgOf(grossM), dp: 0 },
      { label: "Operating margin", concept: "operating-margin", value: operatingMargin(cur), avg: avgOf(operatingMargin), dp: 1 },
      { label: "ROIC", concept: "roic", value: debtOk ? roicValue(cur) : null, avg: debtOk ? avgOf(roicValue) : null, dp: 0 },
      { label: "Owner-earnings margin", concept: "owner-earnings", value: ownerEarningsMargin(cur), avg: avgOf(ownerEarningsMargin), dp: 0 },
    ]
).filter((v) => v.value != null);

const pct = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(dp)}%`);

function spark(values, w = 132, h = 28) {
  const vs = values.filter((v) => v != null);
  if (vs.length < 2) return null;
  const min = Math.min(...vs), max = Math.max(...vs), span = max - min || 1;
  const x = (i) => (w * i) / (values.length - 1);
  const y = (v) => h - 2 - (h - 4) * ((v - min) / span);
  const d = values.map((v, i) => (v == null ? "" : `${i ? "L" : "M"}${x(i).toFixed(1)},${y(v).toFixed(1)}`)).join("");
  return { d, w, h, lastX: x(values.length - 1), lastY: y(values[values.length - 1]) };
}
const sp = spark(revSeries);
---

<section class="portrait">
  <div class="topline">
    <div class="rev">
      <div class="lbl">Revenue · FY{company.fy}</div>
      <div class="big">{fmtUSD(rev)}</div>
      <div class="growth">
        {revGrowth != null ? (
          <span class={revGrowth < 0 ? "neg" : "pos"}>{revGrowth >= 0 ? "+" : ""}{pct(revGrowth, 1)} YoY</span>
        ) : null}
        {cagr != null ? <span class="muted"> · {pct(cagr, 0)} 5-yr CAGR</span> : null}
      </div>
    </div>
    {sp ? (
      <svg class="spark" viewBox={`0 0 ${sp.w} ${sp.h}`} preserveAspectRatio="none" role="img" aria-label="Revenue trend">
        <path d={sp.d} />
        <circle cx={sp.lastX} cy={sp.lastY} r="2.4" />
      </svg>
    ) : null}
  </div>

  {vitals.length ? (
    <div class="vitals">
      <span class="vLbl">Vital signs · {curLabel}{avgLabel ? `, with ${avgLabel}` : ""}</span>
      <div class="vRow">
        {vitals.map((v) => (
          <div class="v">
            <span class="vk">{v.concept ? <Term id={v.concept}>{v.label}</Term> : v.label}</span>
            <span class="vv">{pct(v.value, v.dp)}</span>
            {v.avg != null && avgShort ? <span class="va">{avgShort} {pct(v.avg, v.dp)}</span> : null}
          </div>
        ))}
      </div>
    </div>
  ) : null}

</section>

<style>
  .portrait { margin: 14px 0 18px; }

  .topline { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .lbl { font-size: 11.5px; letter-spacing: 0.07em; text-transform: uppercase; color: var(--muted); }
  .big { font-size: clamp(30px, 6vw, 44px); font-weight: 700; line-height: 1.04; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .growth { margin-top: 2px; font-size: 14px; font-variant-numeric: tabular-nums; }
  .growth .pos { color: var(--good); font-weight: 600; }
  .growth .neg { color: var(--bad); font-weight: 600; }
  .growth .muted { color: var(--muted); }
  .spark { width: 160px; height: 36px; overflow: visible; }
  .spark path { fill: none; stroke: var(--ink); stroke-width: 1.4; vector-effect: non-scaling-stroke; }
  .spark circle { fill: var(--accent); }

  .vitals { margin: 16px 0 0; padding: 12px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .vLbl { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .vRow { display: flex; gap: 30px 40px; flex-wrap: wrap; margin-top: 8px; }
  .v { display: flex; flex-direction: column; }
  .vk { font-size: 12px; color: var(--muted); }
  .vv { font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1.1; margin-top: 2px; }
  .va { font-size: 11.5px; color: var(--muted); font-variant-numeric: tabular-nums; margin-top: 2px; }
</style>
