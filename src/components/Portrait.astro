---
import { classify } from "../lib/archetype.mjs";
import { fmtUSD, roicValue, operatingMargin, ownerEarningsMargin } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const L = company.lines || {};
const rev = L.revenue;
const hist = company.history || [];

const revSeries = hist.map((h) => h.lines.revenue).filter((v) => v != null);
const prevRev = revSeries.length >= 2 ? revSeries[revSeries.length - 2] : null;
const revGrowth = prevRev ? (rev - prevRev) / prevRev : null;
let cagr = null;
if (revSeries.length >= 4) {
  const span = Math.min(5, revSeries.length - 1);
  const first = revSeries[revSeries.length - 1 - span];
  if (first > 0) cagr = Math.pow(rev / first, 1 / span) - 1;
}

// One vital-signs strip — the universal "is it a good business?" numbers, latest
// year. (No second strip: the business-model specifics live in the record table
// and in what the filing flags below, so they aren't duplicated up here.)
const grossMargin = rev && L.costOfRevenue != null ? 1 - L.costOfRevenue / rev : null;
const vitals = [
  { label: "Gross margin", value: grossMargin, dp: 0 },
  { label: "Operating margin", value: operatingMargin(L), dp: 1 },
  { label: "ROIC", value: roicValue(L), dp: 0 },
  { label: "Owner-earnings margin", value: ownerEarningsMargin(L), dp: 0 },
].filter((v) => v.value != null);

const { sector, overlays } = classify(company);
const pct = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(dp)}%`);

function spark(values, w = 132, h = 28) {
  const vs = values.filter((v) => v != null);
  if (vs.length < 2) return null;
  const min = Math.min(...vs), max = Math.max(...vs), span = max - min || 1;
  const x = (i) => (w * i) / (values.length - 1);
  const y = (v) => h - 2 - (h - 4) * ((v - min) / span);
  const d = values.map((v, i) => (v == null ? "" : `${i ? "L" : "M"}${x(i).toFixed(1)},${y(v).toFixed(1)}`)).join("");
  return { d, w, h, lastX: x(values.length - 1), lastY: y(values[values.length - 1]) };
}
const sp = spark(revSeries);
---

<section class="portrait">
  <div class="topline">
    <div class="rev">
      <div class="lbl">Revenue · FY{company.fy}</div>
      <div class="big">{fmtUSD(rev)}</div>
      <div class="growth">
        {revGrowth != null ? (
          <span class={revGrowth < 0 ? "neg" : "pos"}>{revGrowth >= 0 ? "+" : ""}{pct(revGrowth, 1)} YoY</span>
        ) : null}
        {cagr != null ? <span class="muted"> · {pct(cagr, 0)} 5-yr CAGR</span> : null}
      </div>
    </div>
    {sp ? (
      <svg class="spark" viewBox={`0 0 ${sp.w} ${sp.h}`} preserveAspectRatio="none" role="img" aria-label="Revenue trend">
        <path d={sp.d} />
        <circle cx={sp.lastX} cy={sp.lastY} r="2.4" />
      </svg>
    ) : null}
  </div>

  {vitals.length ? (
    <div class="vitals">
      <span class="vLbl">Vital signs · FY{company.fy}</span>
      <div class="vRow">
        {vitals.map((v) => (
          <div class="v"><span class="vk">{v.label}</span><span class="vv">{pct(v.value, v.dp)}</span></div>
        ))}
      </div>
    </div>
  ) : null}

  <p class="reads">
    Read as a <strong>{sector.label}</strong> business — {sector.reason}.
  </p>

  {overlays.length ? (
    <ul class="overlays">
      {overlays.map((o) => (
        <li><span class="chip">{o.label}</span> {o.reason}</li>
      ))}
    </ul>
  ) : null}
</section>

<style>
  .portrait { margin: 14px 0 4px; }

  .topline { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .lbl { font-size: 11.5px; letter-spacing: 0.07em; text-transform: uppercase; color: var(--muted); }
  .big { font-size: clamp(30px, 6vw, 44px); font-weight: 700; line-height: 1.04; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .growth { margin-top: 2px; font-size: 14px; font-variant-numeric: tabular-nums; }
  .growth .pos { color: var(--good); font-weight: 600; }
  .growth .neg { color: var(--bad); font-weight: 600; }
  .growth .muted { color: var(--muted); }
  .spark { width: 160px; height: 36px; overflow: visible; }
  .spark path { fill: none; stroke: var(--ink); stroke-width: 1.4; vector-effect: non-scaling-stroke; }
  .spark circle { fill: var(--accent); }

  .vitals { margin: 16px 0 0; padding: 12px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .vLbl { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .vRow { display: flex; gap: 30px 40px; flex-wrap: wrap; margin-top: 8px; }
  .v { display: flex; flex-direction: column; }
  .vk { font-size: 12px; color: var(--muted); }
  .vv { font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1.1; margin-top: 2px; }

  .reads { font-family: var(--serif); font-size: clamp(17px, 2.4vw, 19px); line-height: 1.45; margin: 16px 0 0; }
  .reads strong { font-weight: 600; }

  .overlays { list-style: none; padding: 0; margin: 10px 0 0; }
  .overlays li { font-size: 13.5px; color: #3a3e46; margin: 6px 0; line-height: 1.45; }
  .chip {
    display: inline-block; font-family: var(--sans); font-size: 11px; font-weight: 600;
    letter-spacing: 0.05em; text-transform: uppercase; color: var(--accent);
    border: 1px solid var(--accent); border-radius: 2px; padding: 1px 6px; margin-right: 6px; white-space: nowrap;
  }
</style>
