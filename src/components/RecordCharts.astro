---
// The record, charted — the operating lines over the whole history, so durability and the
// per-share engine read at a glance. Chart the business, never the price: build-time SVG from
// the same record the table shows (no library, no runtime). Y-anchored at zero so a steady
// line reads steady and a real move reads as a move. Present, never pronounce: the line, the
// current point, and the WORST year on record marked — the trough for a higher-is-better
// measure (ROIC, gross margin), the PEAK for a lower-is-better one (share count); no grade, no color.
//
// This is the set a Graham/Buffett pro keeps after cutting redundancy with the per-share table:
// SHARE COUNT (the per-share / buyback engine — the chart that explains why per-share CAGRs
// outrun the totals), ROIC (the one durability line that weighs profit against capital employed,
// doing the work of the whole margin pile), and GROSS MARGIN (pricing power, upstream of ROIC).
// The relational feature charts — capital allocation, and owner earnings vs. net income — are
// built separately, where the SVG is a stack and a two-line gap rather than a single sparkline.
import { fmtMoney, topLineRevenue, roicValue, grossMargin, gmCorrupt, debtReliable } from "../lib/fundamentals.mjs";
import { financialKind } from "../lib/archetype.mjs";

const { company } = Astro.props;
const hist = company.history || [];
const fk = financialKind(company);
const debtOk = debtReliable(company.lines || {}) && debtReliable(company.ttm?.lines || {});
const $ = (v) => fmtMoney(v, company?.currency || "USD");
const num = (v) => {
  if (v == null) return "—";
  const a = Math.abs(v);
  if (a >= 1e9) return `${(v / 1e9).toFixed(1).replace(/\.0$/, "")}B`;
  if (a >= 1e6) return `${Math.round(v / 1e6)}M`;
  if (a >= 1e3) return `${Math.round(v / 1e3)}K`;
  return String(Math.round(v));
};
const pc = (v) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(0)}%`);
const serOf = (fn) => hist.map((h) => fn(h.lines));
const grossM = (l) => { const g = grossMargin(l); return g == null || gmCorrupt(g, company) ? null : g; };

// Financials run on a balance sheet, not on margins/ROIC, so they get the universally-honest
// lines (revenue) plus share count; non-financials get the durability + per-share engine set.
const metrics = fk
  ? [
      { label: "Share count", series: serOf((l) => l.sharesDiluted), fmt: "count", worse: "high" },
      { label: "Revenue", series: serOf((l) => topLineRevenue(l, company)), fmt: "money", worse: "low" },
    ]
  : [
      { label: "Share count", series: serOf((l) => l.sharesDiluted), fmt: "count", worse: "high" },
      { label: "ROIC", series: debtOk ? serOf(roicValue) : [], fmt: "pct", worse: "low" },
      { label: "Gross margin", series: serOf(grossM), fmt: "pct", worse: "low" },
    ];

const W = 128, H = 40, PAD = 4;
function build(series, worse) {
  const idx = series.map((v, i) => ({ v, i })).filter((p) => p.v != null);
  if (idx.length < 3) return null; // need a shape, not two dots
  const vs = idx.map((p) => p.v);
  const lo = Math.min(0, ...vs), hi = Math.max(0, ...vs), span = hi - lo || 1;
  const n = series.length;
  const x = (i) => (n > 1 ? PAD + (W - 2 * PAD) * (i / (n - 1)) : W / 2);
  const y = (v) => H - PAD - (H - 2 * PAD) * ((v - lo) / span);
  const d = idx.map((p, k) => `${k ? "L" : "M"}${x(p.i).toFixed(1)},${y(p.v).toFixed(1)}`).join("");
  const last = idx[idx.length - 1];
  // The worst year: the trough where higher is better; the peak where lower is better (share count).
  const mark = idx.reduce((a, b) => (worse === "high" ? (b.v > a.v ? b : a) : (b.v < a.v ? b : a)), idx[0]);
  return {
    d,
    lastX: x(last.i), lastY: y(last.v),
    markX: x(mark.i), markY: y(mark.v), markFy: hist[mark.i]?.fy, markLabel: worse === "high" ? "peak" : "low",
    zeroY: lo < 0 && hi > 0 ? y(0) : null,
  };
}

const fmtVal = (v, fmt) => (fmt === "pct" ? pc(v) : fmt === "money" ? $(v) : num(v));
const charts = metrics
  .map((m) => ({ ...m, g: build(m.series, m.worse), last: [...m.series].reverse().find((v) => v != null) }))
  .filter((m) => m.g);

const fy0 = hist.find((h) => h.fy)?.fy;
const fyN = [...hist].reverse().find((h) => h.fy)?.fy;
---

{charts.length ? (
  <section class="rc">
    <div class="head">
      <h3 class="secTitle">The record, charted</h3>
      {fy0 && fyN && fy0 !== fyN ? <span class="span">FY{fy0}–{fyN}</span> : null}
    </div>
    <p class="note">Each measure over its full record — the current point, and the worst year marked.</p>
    <div class="grid">
      {charts.map((c) => (
        <div class="cell">
          <div class="cLbl">{c.label}</div>
          <svg class="chart" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" role="img" aria-label={`${c.label} over the record`}>
            {c.g.zeroY != null ? <line class="zero" x1="0" x2={W} y1={c.g.zeroY} y2={c.g.zeroY} /> : null}
            <path d={c.g.d} />
            <circle class="mark" cx={c.g.markX} cy={c.g.markY} r="2.2" />
            <circle class="last" cx={c.g.lastX} cy={c.g.lastY} r="2.4" />
          </svg>
          <div class="cVal">
            <span class="cNow">{fmtVal(c.last, c.fmt)}</span>
            {c.g.markFy ? <span class="cLow">{c.g.markLabel} FY{c.g.markFy}</span> : null}
          </div>
        </div>
      ))}
    </div>
  </section>
) : null}

<style>
  .rc { margin: 22px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .secTitle { margin: 0; }
  .span { font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); font-variant-numeric: tabular-nums; flex: 0 0 auto; }
  .note { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 8px 0 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 18px 26px; margin: 16px 0 0; }
  .cell { min-width: 0; }
  .cLbl { font-size: 12px; color: var(--muted); }
  .chart { width: 100%; height: 40px; overflow: visible; display: block; margin: 5px 0 4px; }
  .chart path { fill: none; stroke: var(--ink); stroke-width: 1.4; vector-effect: non-scaling-stroke; }
  .chart .last { fill: var(--accent); }
  .chart .mark { fill: var(--paper); stroke: var(--muted); stroke-width: 1; vector-effect: non-scaling-stroke; }
  .chart .zero { stroke: var(--faint); stroke-width: 0.75; stroke-dasharray: 2 2; vector-effect: non-scaling-stroke; }
  .cVal { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; }
  .cNow { font-size: 14px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--ink); }
  .cLow { font-size: 10.5px; color: var(--muted); letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }
</style>
