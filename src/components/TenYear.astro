---
import { classify, financialKind, financialSubtype } from "../lib/archetype.mjs";
import { fmtMoney, currencySymbol, roicValue, liquidAssets, topLineRevenue, debtReliable, oiReliable, effectiveTaxRate, ownerEarningsAbs, freeCashFlowAbs, grossMargin, corruptGrossMarginYears } from "../lib/fundamentals.mjs";
import { returnOnEquity, returnOnTangibleEquity, returnOnAssets, efficiencyRatio, tangibleEquity } from "../lib/financials.mjs";
import { ffo, ffoPerShare, ffoPayout, debtToAssets } from "../lib/reits.mjs";
import { combinedRatio, lossRatio } from "../lib/insurers.mjs";
import { medicalLossRatio } from "../lib/managedCare.mjs";
import Term from "./Term.astro";

const { company } = Astro.props;
const hist = (company.history || []).filter((h) => h?.lines?.revenue != null);
const { sector } = classify(company);

// Whether the captured debt can be trusted is a structural property of the filer (Ford
// reports its real debt only under segment dimensions the data source strips), so we
// decide it once and apply it to the whole record. The signal (a material interest bill
// against little tagged debt) lives in the latest annual, since history and TTM rows
// often omit the interest tag; an under-capture in either marks the whole record unknown.
const debtOk = debtReliable(company.lines || {}) && debtReliable(company.ttm?.lines || {});
// Whether the company carries real debt anywhere in the record. A null debt line is ambiguous —
// genuinely debt-free, or a year the tag was simply missed — so a null year only reads as net cash when
// the company is debt-free throughout; if it shows real debt elsewhere, a null year is a gap, not zero.
const everHadDebt = [...(company.history || []).map((h) => h.lines), company.lines, company.ttm?.lines].some((L) => L && L.totalDebt > 0);
// Whether the operating line is a meaningful read (false for JP holding/trading companies
// that earn through equity-method affiliates); the operating-margin and ROIC rows drop out
// for those, since the record reads on return on equity instead.
const oiOk = oiReliable(company);

// Currency-aware: the same record-table serves the US pool (USD) and the Japanese pool
// (JPY), with the symbol chosen by the company's currency. Ratios and counts are unitless.
const ccy = company.currency || "USD";
const sym = currencySymbol(ccy);
const money = (v) => (v == null ? "—" : fmtMoney(v, ccy));
const marginStr = (n, d, dp = 1) => (n != null && d ? `${(n / d) * 100 < 0 ? "−" : ""}${(Math.abs((n / d) * 100)).toFixed(dp)}%` : "—");
const perShare = (n, sh) => (n != null && sh ? `${sym}${(n / sh).toFixed(2)}` : "—");
// A plain count (shares), so the buyback-or-dilution record reads across the row.
const fmtCount = (v) => {
  if (v == null) return "—";
  const a = Math.abs(v);
  if (a >= 1e9) return `${(v / 1e9).toFixed(2)}B`;
  if (a >= 1e8) return `${Math.round(v / 1e6)}M`;
  if (a >= 1e6) return `${(v / 1e6).toFixed(1)}M`;
  return `${Math.round(v / 1e3)}K`;
};
const xStr = (v, dp = 1) => (v == null ? "—" : `${v.toFixed(dp)}×`);

// Row catalog, each reads one fiscal year's `lines`. `short` is the mobile label;
// `g` groups the row for the banded layout (1 earnings, 2 returns & cash, 3 balance
// sheet & capital), mirroring the order an owner reads a Value Line page.
const ROW = {
  // --- group 1: what it earned ---
  revenue: { label: "Revenue", short: "Revenue", g: 1, get: (L) => money(topLineRevenue(L, company)) },
  grossMargin: { label: "Gross margin", short: "Gross mgn", g: 1, get: (L) => { const v = grossMargin(L); return v == null ? "—" : marginStr(v, 1, 0); } },
  opMargin: { label: "Operating margin", short: "Op. mgn", g: 1, get: (L) => (oiOk ? marginStr(L.operatingIncome, L.revenue) : "—") },
  nii: { label: "Net interest income", short: "Net int.", g: 1, get: (L) => money(L.netInterestIncome) },
  premiums: { label: "Premiums earned", short: "Premiums", g: 1, get: (L) => money(L.premiumsEarned) },
  invInc: { label: "Investment income", short: "Inv. inc.", g: 1, get: (L) => money(L.investmentIncome) },
  provision: { label: "Credit-loss provision", short: "Provision", g: 1, kind: "neutral", get: (L) => money(L.provisionForCreditLosses) },
  netIncome: { label: "Net income", short: "Net inc.", g: 1, get: (L) => money(L.netIncome) },
  netMargin: { label: "Net margin", short: "Net mgn", g: 1, get: (L) => marginStr(L.netIncome, L.revenue) },
  // --- group 4: the per-share array, a Value Line page's heart — every owner figure reduced to one
  // share, so the share-count effect is legible: revenue can climb while revenue/share stalls (dilution)
  // or outruns it (buybacks). Owner earnings and free cash flow per share are the GBM upgrade to Value
  // Line's cruder cash-flow/share; the share count itself leads the band as the divisor behind them all. ---
  eps: { label: "EPS (diluted)", short: "EPS", g: 4, get: (L) => perShare(L.netIncome, L.sharesDiluted) },
  revenuePS: { label: "Revenue / share", short: "Rev/sh", g: 4, get: (L) => perShare(topLineRevenue(L, company), L.sharesDiluted) },
  ownerEarningsPS: { label: "Owner earnings / share", short: "OE/sh", g: 4, get: (L) => perShare(ownerEarningsAbs(L, company), L.sharesDiluted) },
  fcfPS: { label: "Free cash flow / share", short: "FCF/sh", g: 4, get: (L) => perShare(freeCashFlowAbs(L), L.sharesDiluted) },
  // --- group 2: the cash an owner can take, shown as Buffett's bridge so the figure is
  // transparent, operating cash flow, less capex, equals owner earnings. Capex is never
  // hidden: it is half the definition, and in the AI build-out increasingly the half that
  // moves (Capcom's capex nearly halves its owner earnings; Microsoft's capex/revenue has
  // tripled). Then the returns earned on the capital tied up. ---
  cashFromOps: { label: "Operating cash flow", short: "Op. cash", g: 2, get: (L) => money(L.cashFromOps) },
  ownerEarnings: { label: "Owner earnings", short: "Owner earn.", g: 2, get: (L) => { const oe = ownerEarningsAbs(L, company); return oe == null ? "—" : money(oe); } },
  oeMargin: { label: "Owner earnings margin", short: "OE mgn", g: 2, get: (L) => marginStr(ownerEarningsAbs(L, company), L.revenue) },
  // Free cash flow sits beside owner earnings: where they diverge the gap is the growth capex owner
  // earnings excludes, so a build-out cannot hide behind the higher figure.
  freeCashFlow: { label: "Free cash flow", short: "FCF", g: 2, get: (L) => { const f = freeCashFlowAbs(L); return f == null ? "—" : money(f); } },
  fcfMargin: { label: "Free cash flow margin", short: "FCF mgn", g: 2, get: (L) => marginStr(freeCashFlowAbs(L), L.revenue) },
  roic: { label: "ROIC", short: "ROIC", g: 2, get: (L) => { if (!debtOk || !oiOk) return "—"; const r = roicValue(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  roe: { label: "Return on equity", short: "ROE", g: 2, get: (L) => { const r = returnOnEquity(L); return r == null || !(L.stockholdersEquity > 0) ? "—" : `${(r * 100).toFixed(0)}%`; } },
  roa: { label: "Return on assets", short: "ROA", g: 2, get: (L) => { const r = returnOnAssets(L); return r == null ? "—" : `${(r * 100).toFixed(1)}%`; } },
  rotce: { label: "Return on tangible equity", short: "ROTCE", g: 2, get: (L) => { const r = returnOnTangibleEquity(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  efficiency: { label: "Efficiency ratio", short: "Effic.", g: 2, get: (L) => { const r = efficiencyRatio(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  combined: { label: "Combined ratio", short: "Combined", g: 2, get: (L) => { const c = combinedRatio(L); return c == null ? "—" : `≈ ${(c * 100).toFixed(0)}%`; } },
  lossRatio: { label: "Loss ratio", short: "Loss", g: 2, get: (L) => { const r = lossRatio(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  mlr: { label: "Medical loss ratio", short: "MLR", g: 1, get: (L) => { const r = medicalLossRatio(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  ffo: { label: "Funds from operations", short: "FFO", g: 2, get: (L) => money(ffo(L)) },
  ffoPS: { label: "FFO / share", short: "FFO/sh", g: 4, get: (L) => { const f = ffoPerShare(L); return f == null ? "—" : `${sym}${f.toFixed(2)}`; } },
  // Capex sits in group 2, inside the owner-earnings bridge above, because it is a direct
  // subtraction from the cash an owner can take, not a balance-sheet afterthought.
  capex: { label: "Capex", short: "Capex", g: 2, get: (L) => (L.capex != null ? money(Math.abs(L.capex)) : "—") },
  capexToRev: { label: "Capex / revenue", short: "Capex/rev", g: 2, get: (L) => marginStr(L.capex != null ? Math.abs(L.capex) : null, L.revenue) },
  capexToDep: { label: "Capex vs depreciation", short: "Capex/dep", g: 2, get: (L) => (L.capex != null && L.depreciation ? `${(Math.abs(L.capex) / L.depreciation).toFixed(2)}×` : "—") },
  // --- group 3: what it owns and owes, and what owners get ---
  sbcToRev: { label: "Stock comp / revenue", short: "SBC/rev", g: 3, get: (L) => marginStr(L.stockBasedComp, L.revenue) },
  shares: { label: "Shares out (diluted)", short: "Shares", g: 4, get: (L) => fmtCount(L.sharesDiluted) },
  totalDebt: { label: "Total debt", short: "Debt", g: 3, get: (L) => (debtOk ? money(L.totalDebt) : "—") },
  deposits: { label: "Deposits", short: "Deposits", g: 3, get: (L) => money(L.deposits) },
  cash: { label: "Cash & investments", short: "Cash+inv", g: 3, get: (L) => { const v = liquidAssets(L); return v == null ? "—" : money(v); } },
  netDebt: {
    label: "Net debt / (cash)", short: "Net debt", g: 3, kind: "netdebt",
    get: (L) => {
      if (!debtOk) return "—"; // material interest proves the debt is under-captured for this filer
      if (L.totalDebt == null && (everHadDebt || L.cashAndEquivalents == null)) return "—"; // a missing debt year is a gap, not net cash
      return money((L.totalDebt || 0) - (liquidAssets(L) || 0));
    },
  },
  intCov: { label: "Interest coverage", short: "Int. cov.", g: 3, get: (L) => (L.operatingIncome != null && L.interestExpense != null && L.interestExpense > 0 ? xStr(L.operatingIncome / L.interestExpense) : "—") },
  ndEbitda: {
    label: "Net debt / EBITDA", short: "ND/EBITDA", g: 3, kind: "leverage",
    get: (L) => {
      if (!debtOk) return "—";
      if (L.totalDebt == null && everHadDebt) return "—"; // a missing debt year is a gap, not zero
      const ebitda = L.operatingIncome != null && L.depreciation != null ? L.operatingIncome + Math.abs(L.depreciation) : null;
      if (!ebitda || ebitda <= 0) return "—";
      const nd = (L.totalDebt || 0) - (liquidAssets(L) || 0);
      return nd <= 0 ? "net cash" : xStr(nd / ebitda);
    },
  },
  debtAssets: { label: "Debt / assets", short: "Debt/assets", g: 3, get: (L) => { const d = debtToAssets(L); return d == null ? "—" : `${(d * 100).toFixed(0)}%`; } },
  float: { label: "Float (reserves)", short: "Float", g: 3, get: (L) => money(L.lossReserves) },
  dps: { label: "Dividends / share", short: "Div/sh", g: 4, get: (L) => perShare(L.dividendsPaid != null ? Math.abs(L.dividendsPaid) : null, L.sharesDiluted) },
  payoutNI: { label: "Dividend payout", short: "Payout", g: 3, get: (L) => marginStr(L.dividendsPaid != null ? Math.abs(L.dividendsPaid) : null, L.netIncome > 0 ? L.netIncome : null, 0) },
  payout: { label: "Dividend payout (FFO)", short: "Payout", g: 3, get: (L) => { const p = ffoPayout(L); return p == null ? "—" : `${(p * 100).toFixed(0)}%`; } },
  bvps: { label: "Book value / share", short: "BVPS", g: 4, get: (L) => perShare(L.stockholdersEquity, L.sharesDiluted) },
  tbvps: { label: "Tangible book / share", short: "TBVPS", g: 4, get: (L) => perShare(tangibleEquity(L), L.sharesDiluted) },
  // --- fuller income-statement, cash-flow and balance-sheet detail, so the record reads as the
  // whole three-statement snapshot a Value Line page gives, not just the headline lines. Money
  // balances and flows carry no good/bad tone (kind: neutral); a goodwill write-down is the one
  // that does (kind: charge), since it is the admission a past deal was worth less than its price. ---
  sga: { label: "SG&A / revenue", short: "SG&A/rev", g: 1, kind: "neutral", get: (L) => marginStr(L.sgaExpense, L.revenue, 0) },
  rnd: { label: "R&D / revenue", short: "R&D/rev", g: 1, kind: "neutral", get: (L) => marginStr(L.researchDevelopment, L.revenue, 0) },
  opIncome: { label: "Operating income", short: "Op. inc.", g: 1, get: (L) => (oiOk ? money(L.operatingIncome) : "—") },
  taxRate: { label: "Effective tax rate", short: "Tax rate", g: 1, kind: "neutral", get: (L) => { const r = effectiveTaxRate(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  // Depreciation is an add-back, always positive; a negative tag is a sign error, so show its magnitude.
  depreciation: { label: "Depreciation", short: "Deprec.", g: 2, kind: "neutral", get: (L) => (L.depreciation == null ? "—" : money(Math.abs(L.depreciation))) },
  // The rest of what turns profit into operating cash: the change in working capital and the other
  // non-cash items the cash-flow statement reconciles (deferred tax, gains, equity-method profit
  // booked through investing). Operating cash less net income, depreciation and stock comp — the same
  // figure the owner-earnings bridge carries — so a year where cash and profit part ways is legible
  // in the record, not only in the bridge. Big swings here are usually timing — receivables, payables,
  // tax and accrual balances shifting between years — not a change in the business's earning power.
  wcOther: { label: "Working capital & other", short: "WC & other", g: 2, kind: "neutral", get: (L) => (L.cashFromOps != null && L.netIncome != null ? money(L.cashFromOps - L.netIncome - (L.depreciation || 0) - (L.stockBasedComp || 0)) : "—") },
  acquisitions: { label: "Acquisitions", short: "Acquis.", g: 2, kind: "neutral", get: (L) => (L.acquisitionSpend != null ? money(Math.abs(L.acquisitionSpend)) : "—") },
  dividendsPaidAbs: { label: "Dividends paid", short: "Div. paid", g: 2, get: (L) => (L.dividendsPaid != null ? money(Math.abs(L.dividendsPaid)) : "—") },
  buybacksAbs: { label: "Buybacks", short: "Buybacks", g: 2, get: (L) => (L.buybacks != null ? money(Math.abs(L.buybacks)) : "—") },
  receivables: { label: "Receivables", short: "Receiv.", g: 3, kind: "neutral", get: (L) => money(L.receivables) },
  inventoryRow: { label: "Inventory", short: "Invent.", g: 3, kind: "neutral", get: (L) => money(L.inventory) },
  accountsPayable: { label: "Accounts payable", short: "Payables", g: 3, kind: "neutral", get: (L) => money(L.accountsPayable) },
  currentAssets: { label: "Current assets", short: "Cur. assets", g: 3, kind: "neutral", get: (L) => money(L.currentAssets) },
  currentLiabilities: { label: "Current liabilities", short: "Cur. liab.", g: 3, kind: "neutral", get: (L) => money(L.currentLiabilities) },
  goodwillRow: { label: "Goodwill", short: "Goodwill", g: 3, kind: "neutral", get: (L) => money(L.goodwill) },
  totalAssets: { label: "Total assets", short: "Assets", g: 3, kind: "neutral", get: (L) => money(L.totalAssets) },
  equity: { label: "Shareholders’ equity", short: "Equity", g: 3, kind: "neutral", get: (L) => money(L.stockholdersEquity) },
  operatingWC: { label: "Operating working capital", short: "Oper. WC", g: 3, kind: "neutral", get: (L) => ((L.receivables != null || L.inventory != null) ? money((L.receivables || 0) + (L.inventory || 0) - (L.accountsPayable || 0)) : "—") },
  currentRatio: { label: "Current ratio", short: "Curr. ratio", g: 3, kind: "neutral", get: (L) => (L.currentAssets != null && L.currentLiabilities > 0 ? xStr(L.currentAssets / L.currentLiabilities, 1) : "—") },
  goodwillImp: { label: "Goodwill written down", short: "GW imp.", g: 3, kind: "charge", get: (L) => (L.goodwillImpairment ? money(Math.abs(L.goodwillImpairment)) : "—") },
  feeIncome: { label: "Noninterest income", short: "Fee inc.", g: 1, get: (L) => money(L.noninterestIncome) },
  realEstate: { label: "Real estate (gross)", short: "RE gross", g: 3, kind: "neutral", get: (L) => money(L.realEstateGross) },
};

// The full three-statement snapshot for an operating company, in Value Line's spirit: the income
// statement, then the cash it threw off and the returns it earned, then the balance sheet, and finally
// the per-share array — every owner figure reduced to a single share. Generous on purpose — the
// sparse-row prune below drops whatever a business lacks (no inventory for a software maker, no R&D for
// a retailer, no goodwill for one that never acquires).
const FULL = [
  ROW.revenue, ROW.grossMargin, ROW.sga, ROW.rnd, ROW.opIncome, ROW.opMargin, ROW.netIncome, ROW.taxRate,
  ROW.cashFromOps, ROW.depreciation, ROW.wcOther, ROW.capex, ROW.ownerEarnings, ROW.oeMargin, ROW.freeCashFlow, ROW.fcfMargin, ROW.acquisitions, ROW.dividendsPaidAbs, ROW.buybacksAbs, ROW.roic, ROW.roe,
  ROW.cash, ROW.receivables, ROW.inventoryRow, ROW.accountsPayable, ROW.operatingWC, ROW.currentAssets, ROW.currentLiabilities, ROW.currentRatio, ROW.goodwillRow, ROW.totalAssets, ROW.totalDebt, ROW.netDebt, ROW.intCov, ROW.equity, ROW.sbcToRev, ROW.goodwillImp,
  // Per share: the share count leads (the divisor), then top line, earnings, the two cash measures, the
  // dividend and book value — every figure above reduced to one share, so dilution or buybacks show.
  ROW.shares, ROW.revenuePS, ROW.eps, ROW.ownerEarningsPS, ROW.fcfPS, ROW.dps, ROW.bvps,
];
// Operating companies get the full snapshot above; banks, insurers and REITs each read on their
// own measures, so they keep a curated set. Rows the data can't fill drop out below.
const SETS = {
  assetLight: FULL, consumer: FULL, capital: FULL, retail: FULL,
  financial: [ROW.revenue, ROW.nii, ROW.feeIncome, ROW.provision, ROW.netIncome, ROW.taxRate, ROW.roa, ROW.roe, ROW.rotce, ROW.efficiency, ROW.totalAssets, ROW.deposits, ROW.goodwillRow, ROW.equity, ROW.shares, ROW.eps, ROW.dps, ROW.bvps, ROW.tbvps],
  // Insurers read on the combined ratio and float, but they also generate cash, and a group
  // that owns operating businesses under an insurance SIC (a conglomerate, say) is read on its
  // owner economics too. So the owner-earnings bridge and cash sit beside the underwriting
  // measures; the sparse-row prune drops whichever a given filer doesn't support.
  insurer: [ROW.revenue, ROW.premiums, ROW.invInc, ROW.netIncome, ROW.taxRate, ROW.cashFromOps, ROW.ownerEarnings, ROW.combined, ROW.lossRatio, ROW.roe, ROW.float, ROW.totalAssets, ROW.cash, ROW.equity, ROW.shares, ROW.eps, ROW.ownerEarningsPS, ROW.dps, ROW.bvps],
  // Life insurers: the spread-and-book-value story, no combined ratio (see insurers.mjs).
  lifeInsurer: [ROW.revenue, ROW.premiums, ROW.invInc, ROW.netIncome, ROW.taxRate, ROW.cashFromOps, ROW.ownerEarnings, ROW.roe, ROW.float, ROW.totalAssets, ROW.cash, ROW.equity, ROW.shares, ROW.eps, ROW.ownerEarningsPS, ROW.dps, ROW.bvps],
  fee: [ROW.revenue, ROW.opMargin, ROW.netMargin, ROW.netIncome, ROW.taxRate, ROW.ownerEarnings, ROW.roe, ROW.totalAssets, ROW.cash, ROW.equity, ROW.shares, ROW.revenuePS, ROW.eps, ROW.ownerEarningsPS, ROW.dps, ROW.bvps],
  managedCare: [ROW.revenue, ROW.premiums, ROW.mlr, ROW.opMargin, ROW.netIncome, ROW.taxRate, ROW.roe, ROW.totalAssets, ROW.equity, ROW.shares, ROW.revenuePS, ROW.eps, ROW.dps, ROW.bvps],
  reit: [ROW.revenue, ROW.netIncome, ROW.ffo, ROW.payout, ROW.realEstate, ROW.totalAssets, ROW.debtAssets, ROW.totalDebt, ROW.netDebt, ROW.intCov, ROW.equity, ROW.shares, ROW.ffoPS, ROW.dps, ROW.bvps],
  general: FULL,
};

// Columns: each fiscal year, plus a trailing-twelve-months column when present
// (the freshest 12 months, folding in any quarter filed since the last 10-K).
const cols = hist.map((h) => ({ label: String(h.fy), lines: h.lines, ttm: false }));
if (company.ttm?.lines) {
  const asOf = company.ttm.asOf
    ? new Date(company.ttm.asOf + "T00:00:00Z").toLocaleDateString("en-US", { month: "short", year: "numeric", timeZone: "UTC" })
    : null;
  cols.push({ label: "TTM", sub: asOf, lines: company.ttm.lines, ttm: true });
}
const lastI = cols.length - 1;

// Normalize diluted shares to the latest basis so per-share rows stay continuous
// across stock splits. EDGAR only restates ~3 years back, so a year older than
// that can still be pre-split; detect the jump and scale earlier years to match.
{
  const s = cols.map((c) => c.lines?.sharesDiluted ?? null);
  const factor = new Array(s.length).fill(1);
  let f = 1;
  for (let i = s.length - 1; i > 0; i--) {
    factor[i] = f;
    let j = i - 1;
    while (j >= 0 && s[j] == null) j--;
    if (j >= 0 && s[i] != null && s[j] != null && s[j] > 0) {
      const r = s[i] / s[j];
      if (r > 1.4 || r < 0.7) f *= r; // a split (not buybacks) sits between j and i
    }
  }
  factor[0] = f;
  cols.forEach((c, i) => {
    if (c.lines && c.lines.sharesDiluted != null && factor[i] !== 1)
      c.lines = { ...c.lines, sharesDiluted: c.lines.sharesDiluted * factor[i] };
  });
}

// Withhold a mis-tagged cost-of-revenue year: a company whose gross margin swings between a moderate
// year and a near-total one has its cost line captured near zero in the high years — an impossible
// ~100% gross margin (an auto dealer, a utility). Null the cost line for those years so the gross-margin
// row reads "—" rather than printing the corruption; nothing else in the table derives from it. The TTM
// column carries no fiscal year, so it is judged on its own near-total reading when the record swings.
{
  const corruptGM = corruptGrossMarginYears(company);
  if (corruptGM.size) cols.forEach((c) => {
    const corrupt = c.ttm ? (c.lines && grossMargin(c.lines) >= 0.85) : corruptGM.has(Number(c.label));
    if (corrupt && c.lines && c.lines.costOfRevenue != null) c.lines = { ...c.lines, costOfRevenue: null };
  });
}

// The row-set follows the business model. Banks, insurers and REITs each read on
// their own measures, so key off financialKind first (future-proof for any new
// financial), and fall back to the economic-model sector for everything else.
// The Japanese pool carries a curated sector and never passes through the SIC engine, so
// prefer it; the US pool resolves the model from the financial kind, then the shape.
const fk = financialKind(company);
const setKey = company.sector || (fk === "insurer" ? (financialSubtype(company) === "life-insurer" ? "lifeInsurer" : "insurer") : fk === "reit" ? "reit" : fk === "managedCare" ? "managedCare" : fk === "fee" ? "fee" : fk === "bank" ? "financial" : sector.key);
const chosen = SETS[setKey] || SETS.general;

// Link a row's label to its entry on the Concepts page, where the term is defined.
const ROW_CONCEPT = {
  "Gross margin": "gross-margin", "Operating margin": "operating-margin",
  "Owner earnings": "owner-earnings", "Owner earnings margin": "owner-earnings", "ROIC": "roic",
  "Working capital & other": "working-capital", "Operating working capital": "operating-working-capital",
  "Total debt": "net-debt", "Net debt / (cash)": "net-debt", "Net debt / EBITDA": "net-debt",
  "Interest coverage": "interest-coverage",
  "Shares out (diluted)": "dilution", "Stock comp / revenue": "dilution",
  "Revenue / share": "dilution", "Owner earnings / share": "owner-earnings", "Free cash flow / share": "owner-earnings",
  "Net interest income": "net-interest-margin", "Return on equity": "return-on-equity",
  "Return on assets": "return-on-assets",
  "Return on tangible equity": "rotce", "Efficiency ratio": "efficiency-ratio",
  "Tangible book / share": "tangible-book",
  "Funds from operations": "ffo", "FFO / share": "ffo", "Dividend payout (FFO)": "ffo", "Debt / assets": "net-debt",
  "Combined ratio": "combined-ratio", "Loss ratio": "combined-ratio",
  "Investment income": "insurance-float", "Float (reserves)": "insurance-float",
  "Medical loss ratio": "medical-loss-ratio",
};
// Drop a row the data fills in too few years, then mark where each band (earnings → returns →
// balance sheet) begins so the table reads in sections. A lone value beside a row of dashes is
// noise, not a record (a conglomerate filing under an insurance SIC tags premiums in its latest
// year only, say), so require a row populated in a fair share of the columns, at least three of
// a long record, rather than merely non-empty. Every table then reads as a record, and the
// genuinely populated core stands out instead of being lost among sparse specialist rows.
const minFill = cols.length >= 6 ? 3 : 2;
const rows = chosen
  .map((r) => ({ label: r.label, short: r.short || r.label, kind: r.kind || "plain", g: r.g || 1, concept: ROW_CONCEPT[r.label] || null, cells: cols.map((c) => r.get(c.lines)) }))
  .filter((r) => r.cells.filter((c) => c !== "—").length >= minFill);
rows.forEach((r, i) => { r.bandStart = i === 0 || r.g !== rows[i - 1].g; });
// Band headers naming the statement each section reads from, so the record presents as one full
// snapshot: the income statement, then the cash it generated and the returns, then the balance sheet.
const BAND = { 1: "Income statement", 2: "Cash flow & returns", 3: "Balance sheet", 4: "Per share" };

// Abbreviated year for narrow screens: 2017 → ’17, TTM stays.
const yShort = (lbl) => (lbl.length === 4 && /^\d{4}$/.test(lbl) ? "’" + lbl.slice(2) : lbl);

// A parenthesised/minus cell is a loss in most rows (red), but in the net-debt
// row it means net cash, which is a good thing (green).
const cellClass = (kind, c) => {
  if (c === "net cash") return "pos"; // net-debt/EBITDA showing a net-cash balance sheet
  if (kind === "charge") return c === "—" ? "" : "neg"; // a goodwill write-down, red in the year it lands
  const neg = c.startsWith("(") || c.startsWith("−");
  if (kind === "netdebt") return neg ? "pos" : "";
  if (kind === "neutral" || kind === "leverage") return ""; // a provision or leverage figure isn't a loss
  return neg ? "neg" : "";
};
---

{hist.length >= 3 ? (
  <section class="tenyear">
    <div class="head">
      <h3 class="secTitle">The record, {hist[0].fy}–{hist[hist.length - 1].fy}</h3>
      <span class="hint">realized figures from each filing, no estimates</span>
    </div>
    <div class="wrap">
      <table>
        <thead>
          <tr>
            <th class="rowlabel"></th>
            {cols.map((c, i) => (
              <th class={`${i === lastI ? "last" : ""} ${c.ttm ? "ttm" : ""}`}>
                <span class="yf">{c.label}</span><span class="ys">{c.ttm ? c.label : yShort(c.label)}</span>
                {c.sub ? <span class="sub">{c.sub}</span> : null}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <>
              {r.bandStart && BAND[r.g] ? (
                <tr class="band"><th class="rowlabel band" colspan={cols.length + 1}>{BAND[r.g]}</th></tr>
              ) : null}
              <tr>
                <th class="rowlabel"><span class="lf">{r.concept ? <Term id={r.concept}>{r.label}</Term> : r.label}</span><span class="ls">{r.short}</span></th>
                {r.cells.map((c, i) => (
                  <td class={`${i === lastI ? "last" : ""} ${cols[i].ttm ? "ttm" : ""} ${cellClass(r.kind, c)}`}>{c}</td>
                ))}
              </tr>
            </>
          ))}
        </tbody>
      </table>
    </div>
  </section>
) : null}

<style>
  .tenyear { margin: 22px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 5px; }
  .secHead { font-family: var(--serif); font-weight: 600; margin: 0; font-size: clamp(22px, 3.4vw, 27px); letter-spacing: -0.01em; line-height: 1.15; color: var(--ink); }
  .hint { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); }

  .wrap { overflow-x: auto; margin-top: 4px; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; font-variant-numeric: tabular-nums; white-space: nowrap; }
  thead th { font-weight: 600; color: var(--muted); font-size: 12px; text-align: right; padding: 8px 10px 6px; border-bottom: 1px solid var(--rule); }
  tbody th.rowlabel { text-align: left; font-weight: 600; color: var(--ink); padding: 7px 14px 7px 0; position: sticky; left: 0; background: var(--paper); }
  thead th.rowlabel { position: sticky; left: 0; background: var(--paper); }
  td { text-align: right; padding: 7px 10px; border-bottom: 1px solid var(--rule); color: var(--ink); }
  td.last, thead th.last { font-weight: 700; }
  /* A band divider where the table moves from earnings to returns to the balance sheet. */
  tr.gtop td, tr.gtop th.rowlabel { border-top: 2px solid var(--rule-strong); padding-top: 11px; }
  /* Statement band headers (Income statement / Cash flow & returns / Balance sheet). */
  tr.band th.band { font-family: var(--serif); font-style: italic; font-weight: 600; color: var(--muted); text-align: left; font-size: 12px; letter-spacing: 0.01em; padding: 15px 14px 5px 0; border-top: 2px solid var(--rule-strong); border-bottom: 1px solid var(--rule); background: var(--paper); position: static; text-transform: none; }
  tbody tr.band:first-child th.band { border-top: none; padding-top: 2px; }
  th.ttm, td.ttm { background: var(--accent-tint); }
  .sub { display: block; font-weight: 400; font-size: 10px; letter-spacing: 0.02em; color: var(--muted); text-transform: none; }
  td.neg { color: var(--bad); }
  td.pos { color: var(--good, #1a7a3c); }
  tbody tr:hover td, tbody tr:hover th.rowlabel { background: var(--surface-2); }

  /* Short labels are hidden until the screen is narrow, where they buy column room. */
  .ls, .ys { display: none; }
  @media (max-width: 560px) {
    table { font-size: 11.5px; }
    thead th { padding: 7px 7px 5px; font-size: 10.5px; }
    td { padding: 6px 7px; }
    tbody th.rowlabel { padding: 6px 9px 6px 0; font-size: 11.5px; }
    .lf, .yf { display: none; }
    .ls, .ys { display: inline; }
  }
</style>

<script>
  // Freeze the record table's year row. The table scrolls horizontally inside an overflow wrapper, which
  // makes it a scroll container — so a CSS `position: sticky` header would stick to the wrapper, not the
  // page, and wouldn't freeze as the page scrolls. Instead we build a fixed-position copy of the year row
  // that appears, tucked just under the sticky section bar, only while the table itself is on screen, and
  // mirror the table's width and horizontal scroll so the years line up with the data beneath. The real
  // table is untouched; the copy is decorative (aria-hidden, click-through).
  (function () {
    function setup(sec) {
      const wrap = sec.querySelector(".wrap");
      const table = wrap && wrap.querySelector("table");
      const headRow = table && table.querySelector("thead tr");
      if (!wrap || !table || !headRow) return;

      const float = document.createElement("div");
      float.className = "tyFloat";
      float.setAttribute("aria-hidden", "true");
      // Styled inline (not via the component's scoped CSS): the copy is appended to <body>, outside the
      // component subtree, so the scope attribute wouldn't reach it. The cloned cells keep their own
      // bottom border; a soft shadow lifts the frozen row off the data scrolling beneath it.
      Object.assign(float.style, {
        position: "fixed", top: "-9999px", left: "0", overflow: "hidden", zIndex: "30",
        pointerEvents: "none", visibility: "hidden", background: "var(--paper)",
        boxShadow: "0 6px 10px -8px rgba(0, 0, 0, 0.35)",
      });
      const ftable = table.cloneNode(false);                 // keeps the table's scoped-style identity
      ftable.style.margin = "0";
      const fthead = document.createElement("thead");
      const frow = headRow.cloneNode(true);
      fthead.appendChild(frow);
      ftable.appendChild(fthead);
      float.appendChild(ftable);
      document.body.appendChild(float);                      // body: fixed positioning, no transformed ancestor

      const cbar = document.querySelector(".cbar");
      let shown = false;

      function freezeTop() { return cbar ? Math.max(0, cbar.getBoundingClientRect().bottom) : 0; }

      // Lock the copy's columns to the live table's measured widths, so the floating row lines up
      // exactly with the data. A table column shares one width, so the header cell's width is the
      // column's width.
      function syncWidths() {
        ftable.style.width = table.getBoundingClientRect().width + "px";
        ftable.style.tableLayout = "fixed";
        const live = headRow.children, clone = frow.children;
        for (let i = 0; i < live.length && i < clone.length; i++) {
          const w = live[i].getBoundingClientRect().width + "px";
          clone[i].style.width = clone[i].style.minWidth = clone[i].style.maxWidth = w;
        }
      }

      function position() {
        const r = wrap.getBoundingClientRect();
        const top = freezeTop();
        const headH = frow.getBoundingClientRect().height || 36;
        const want = r.top < top - 0.5 && r.bottom > top + headH;   // table crosses the freeze line, still on screen
        if (want) {
          if (!shown) { syncWidths(); shown = true; }
          float.style.top = top + "px";
          float.style.left = r.left + "px";
          float.style.width = wrap.clientWidth + "px";
          float.style.visibility = "visible";
          float.scrollLeft = wrap.scrollLeft;
        } else if (shown || float.style.visibility === "visible") {
          float.style.visibility = "hidden";
          float.style.top = "-9999px";
          shown = false;
        }
      }

      // Horizontal scroll of the table moves the floating row in lockstep; the copy's first cell stays
      // pinned left exactly as the table's row-label column does, since `float` is itself a scroll box.
      wrap.addEventListener("scroll", function () { if (shown) float.scrollLeft = wrap.scrollLeft; }, { passive: true });
      let raf = 0;
      function onScroll() { if (raf) return; raf = requestAnimationFrame(function () { raf = 0; position(); }); }
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", function () { shown = false; float.style.visibility = "hidden"; syncWidths(); position(); }, { passive: true });

      // Settle after layout and any late web-font reflow.
      requestAnimationFrame(function () { syncWidths(); position(); });
      setTimeout(function () { syncWidths(); position(); }, 450);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(function () { syncWidths(); position(); });
    }
    document.querySelectorAll(".tenyear").forEach(setup);
  })();
</script>
