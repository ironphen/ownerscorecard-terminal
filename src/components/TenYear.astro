---
import { classify } from "../lib/archetype.mjs";
import { fmtUSD, roicValue, liquidAssets } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const hist = (company.history || []).filter((h) => h?.lines?.revenue != null);
const { sector } = classify(company);

const money = (v) => (v == null ? "—" : fmtUSD(v));
const marginStr = (n, d, dp = 1) => (n != null && d ? `${(n / d) * 100 < 0 ? "−" : ""}${(Math.abs((n / d) * 100)).toFixed(dp)}%` : "—");
const perShare = (n, sh) => (n != null && sh ? `$${(n / sh).toFixed(2)}` : "—");

// Row catalog — each reads one fiscal year's `lines`.
const ROW = {
  revenue: { label: "Revenue", get: (L) => money(L.revenue) },
  grossMargin: { label: "Gross margin", get: (L) => marginStr(L.revenue != null && L.costOfRevenue != null ? L.revenue - L.costOfRevenue : null, L.revenue, 0) },
  opMargin: { label: "Operating margin", get: (L) => marginStr(L.operatingIncome, L.revenue) },
  netIncome: { label: "Net income", get: (L) => money(L.netIncome) },
  eps: { label: "EPS (diluted)", get: (L) => perShare(L.netIncome, L.sharesDiluted) },
  ownerEarnings: { label: "Owner earnings", get: (L) => (L.cashFromOps != null && L.capex != null ? money(L.cashFromOps - Math.abs(L.capex)) : "—") },
  oeMargin: { label: "Owner earnings margin", get: (L) => marginStr(L.cashFromOps != null && L.capex != null ? L.cashFromOps - Math.abs(L.capex) : null, L.revenue) },
  roic: { label: "ROIC", get: (L) => { const r = roicValue(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  capex: { label: "Capex", get: (L) => (L.capex != null ? money(Math.abs(L.capex)) : "—") },
  capexToRev: { label: "Capex / revenue", get: (L) => marginStr(L.capex != null ? Math.abs(L.capex) : null, L.revenue) },
  capexToDep: { label: "Capex vs depreciation", get: (L) => (L.capex != null && L.depreciation ? `${(Math.abs(L.capex) / L.depreciation).toFixed(2)}×` : "—") },
  totalDebt: { label: "Total debt", get: (L) => money(L.totalDebt) },
  cash: {
    label: "Cash & investments",
    get: (L) => {
      const v = liquidAssets(L);
      return v == null ? "—" : money(v);
    },
  },
  netDebt: {
    label: "Net debt / (cash)",
    kind: "netdebt",
    get: (L) => {
      if (L.totalDebt == null && L.cashAndEquivalents == null) return "—";
      return money((L.totalDebt || 0) - (liquidAssets(L) || 0));
    },
  },
  dps: { label: "Dividends / share", get: (L) => perShare(L.dividendsPaid != null ? Math.abs(L.dividendsPaid) : null, L.sharesDiluted) },
  bvps: { label: "Book value / share", get: (L) => perShare(L.stockholdersEquity, L.sharesDiluted) },
};

const SETS = {
  assetLight: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.cash, ROW.netDebt, ROW.bvps],
  consumer: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.roic, ROW.cash, ROW.netDebt, ROW.dps, ROW.bvps],
  capital: [ROW.revenue, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.roic, ROW.capex, ROW.capexToRev, ROW.capexToDep, ROW.totalDebt, ROW.cash, ROW.netDebt],
  retail: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.cash, ROW.netDebt],
  general: [ROW.revenue, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.totalDebt, ROW.cash, ROW.netDebt],
};

// Columns: each fiscal year, plus a trailing-twelve-months column when present
// (the freshest 12 months, folding in any quarter filed since the last 10-K).
const cols = hist.map((h) => ({ label: String(h.fy), lines: h.lines, ttm: false }));
if (company.ttm?.lines) {
  const asOf = company.ttm.asOf
    ? new Date(company.ttm.asOf + "T00:00:00Z").toLocaleDateString("en-US", { month: "short", year: "numeric", timeZone: "UTC" })
    : null;
  cols.push({ label: "TTM", sub: asOf, lines: company.ttm.lines, ttm: true });
}
const lastI = cols.length - 1;

// Normalize diluted shares to the latest basis so per-share rows stay continuous
// across stock splits. EDGAR only restates ~3 years back, so a year older than
// that can still be pre-split; detect the jump and scale earlier years to match.
{
  const s = cols.map((c) => c.lines?.sharesDiluted ?? null);
  const factor = new Array(s.length).fill(1);
  let f = 1;
  for (let i = s.length - 1; i > 0; i--) {
    factor[i] = f;
    let j = i - 1;
    while (j >= 0 && s[j] == null) j--;
    if (j >= 0 && s[i] != null && s[j] != null && s[j] > 0) {
      const r = s[i] / s[j];
      if (r > 1.4 || r < 0.7) f *= r; // a split (not buybacks) sits between j and i
    }
  }
  factor[0] = f;
  cols.forEach((c, i) => {
    if (c.lines && c.lines.sharesDiluted != null && factor[i] !== 1)
      c.lines = { ...c.lines, sharesDiluted: c.lines.sharesDiluted * factor[i] };
  });
}

const chosen = SETS[sector.key] || SETS.general;
// Drop any row the data can't fill across the whole record.
const rows = chosen
  .map((r) => ({ label: r.label, kind: r.kind || "plain", cells: cols.map((c) => r.get(c.lines)) }))
  .filter((r) => r.cells.some((c) => c !== "—"));

// A parenthesised/minus cell is a loss in most rows (red) — but in the net-debt
// row it means net cash, which is a good thing (green).
const cellClass = (kind, c) => {
  const neg = c.startsWith("(") || c.startsWith("−");
  if (kind === "netdebt") return neg ? "pos" : "";
  return neg ? "neg" : "";
};
---

{hist.length >= 3 ? (
  <section class="tenyear">
    <div class="head">
      <h3 class="secHead">The record — {hist[0].fy}–{hist[hist.length - 1].fy}</h3>
      <span class="hint">realized figures from each filing — no estimates</span>
    </div>
    <div class="wrap">
      <table>
        <thead>
          <tr>
            <th class="rowlabel"></th>
            {cols.map((c, i) => (
              <th class={`${i === lastI ? "last" : ""} ${c.ttm ? "ttm" : ""}`}>
                {c.label}{c.sub ? <span class="sub">{c.sub}</span> : null}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <th class="rowlabel">{r.label}</th>
              {r.cells.map((c, i) => (
                <td class={`${i === lastI ? "last" : ""} ${cols[i].ttm ? "ttm" : ""} ${cellClass(r.kind, c)}`}>{c}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
) : null}

<style>
  .tenyear { margin: 22px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 5px; }
  .secHead { font-family: var(--sans); font-weight: 600; margin: 0; font-size: 11.5px; letter-spacing: 0.09em; text-transform: uppercase; color: var(--ink); }
  .hint { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); }

  .wrap { overflow-x: auto; margin-top: 4px; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; font-variant-numeric: tabular-nums; white-space: nowrap; }
  thead th { font-weight: 600; color: var(--muted); font-size: 12px; text-align: right; padding: 8px 10px 6px; border-bottom: 1px solid var(--rule); }
  tbody th.rowlabel { text-align: left; font-weight: 600; color: var(--ink); padding: 7px 14px 7px 0; position: sticky; left: 0; background: var(--paper); }
  thead th.rowlabel { position: sticky; left: 0; background: var(--paper); }
  td { text-align: right; padding: 7px 10px; border-bottom: 1px solid var(--rule); color: var(--ink); }
  td.last, thead th.last { font-weight: 700; }
  th.ttm, td.ttm { background: var(--accent-tint); }
  .sub { display: block; font-weight: 400; font-size: 10px; letter-spacing: 0.02em; color: var(--muted); text-transform: none; }
  td.neg { color: var(--bad); }
  td.pos { color: var(--good, #1a7a3c); }
  tbody tr:hover td, tbody tr:hover th.rowlabel { background: #faf9f6; }
</style>
