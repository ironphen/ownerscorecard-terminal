---
import { classify, financialKind } from "../lib/archetype.mjs";
import { fmtUSD, roicValue, liquidAssets } from "../lib/fundamentals.mjs";
import { returnOnEquity, returnOnTangibleEquity, efficiencyRatio, tangibleEquity } from "../lib/financials.mjs";
import { ffo, ffoPerShare, ffoPayout, debtToAssets } from "../lib/reits.mjs";
import { combinedRatio, lossRatio } from "../lib/insurers.mjs";
import Term from "./Term.astro";

const { company } = Astro.props;
const hist = (company.history || []).filter((h) => h?.lines?.revenue != null);
const { sector } = classify(company);

const money = (v) => (v == null ? "—" : fmtUSD(v));
const marginStr = (n, d, dp = 1) => (n != null && d ? `${(n / d) * 100 < 0 ? "−" : ""}${(Math.abs((n / d) * 100)).toFixed(dp)}%` : "—");
const perShare = (n, sh) => (n != null && sh ? `$${(n / sh).toFixed(2)}` : "—");

// Row catalog, each reads one fiscal year's `lines`. `short` is the mobile label.
const ROW = {
  revenue: { label: "Revenue", short: "Revenue", get: (L) => money(L.revenue) },
  grossMargin: { label: "Gross margin", short: "Gross mgn", get: (L) => marginStr(L.revenue != null && L.costOfRevenue != null ? L.revenue - L.costOfRevenue : null, L.revenue, 0) },
  opMargin: { label: "Operating margin", short: "Op. mgn", get: (L) => marginStr(L.operatingIncome, L.revenue) },
  netIncome: { label: "Net income", short: "Net inc.", get: (L) => money(L.netIncome) },
  eps: { label: "EPS (diluted)", short: "EPS", get: (L) => perShare(L.netIncome, L.sharesDiluted) },
  ownerEarnings: { label: "Owner earnings", short: "Owner earn.", get: (L) => (L.cashFromOps != null && L.capex != null ? money(L.cashFromOps - Math.abs(L.capex)) : "—") },
  oeMargin: { label: "Owner earnings margin", short: "OE mgn", get: (L) => marginStr(L.cashFromOps != null && L.capex != null ? L.cashFromOps - Math.abs(L.capex) : null, L.revenue) },
  roic: { label: "ROIC", short: "ROIC", get: (L) => { const r = roicValue(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  capex: { label: "Capex", short: "Capex", get: (L) => (L.capex != null ? money(Math.abs(L.capex)) : "—") },
  capexToRev: { label: "Capex / revenue", short: "Capex/rev", get: (L) => marginStr(L.capex != null ? Math.abs(L.capex) : null, L.revenue) },
  capexToDep: { label: "Capex vs depreciation", short: "Capex/dep", get: (L) => (L.capex != null && L.depreciation ? `${(Math.abs(L.capex) / L.depreciation).toFixed(2)}×` : "—") },
  totalDebt: { label: "Total debt", short: "Debt", get: (L) => money(L.totalDebt) },
  cash: {
    label: "Cash & investments",
    short: "Cash+inv",
    get: (L) => {
      const v = liquidAssets(L);
      return v == null ? "—" : money(v);
    },
  },
  netDebt: {
    label: "Net debt / (cash)",
    short: "Net debt",
    kind: "netdebt",
    get: (L) => {
      if (L.totalDebt == null && L.cashAndEquivalents == null) return "—";
      return money((L.totalDebt || 0) - (liquidAssets(L) || 0));
    },
  },
  dps: { label: "Dividends / share", short: "Div/sh", get: (L) => perShare(L.dividendsPaid != null ? Math.abs(L.dividendsPaid) : null, L.sharesDiluted) },
  bvps: { label: "Book value / share", short: "BVPS", get: (L) => perShare(L.stockholdersEquity, L.sharesDiluted) },
  // --- financials (banks): a bank's record is read on these, not on margins/owner earnings ---
  nii: { label: "Net interest income", short: "Net int.", get: (L) => money(L.netInterestIncome) },
  roe: { label: "Return on equity", short: "ROE", get: (L) => { const r = returnOnEquity(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  rotce: { label: "Return on tangible equity", short: "ROTCE", get: (L) => { const r = returnOnTangibleEquity(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  efficiency: { label: "Efficiency ratio", short: "Effic.", get: (L) => { const r = efficiencyRatio(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  deposits: { label: "Deposits", short: "Deposits", get: (L) => money(L.deposits) },
  tbvps: { label: "Tangible book / share", short: "TBVPS", get: (L) => perShare(tangibleEquity(L), L.sharesDiluted) },
  // --- REITs: read on funds from operations, not GAAP earnings ---
  ffo: { label: "Funds from operations", short: "FFO", get: (L) => money(ffo(L)) },
  ffoPS: { label: "FFO / share", short: "FFO/sh", get: (L) => { const f = ffoPerShare(L); return f == null ? "—" : `$${f.toFixed(2)}`; } },
  payout: { label: "Dividend payout (FFO)", short: "Payout", get: (L) => { const p = ffoPayout(L); return p == null ? "—" : `${(p * 100).toFixed(0)}%`; } },
  debtAssets: { label: "Debt / assets", short: "Debt/assets", get: (L) => { const d = debtToAssets(L); return d == null ? "—" : `${(d * 100).toFixed(0)}%`; } },
  // --- insurers: read on underwriting (combined ratio), the float, and book value ---
  premiums: { label: "Premiums earned", short: "Premiums", get: (L) => money(L.premiumsEarned) },
  combined: { label: "Combined ratio", short: "Combined", get: (L) => { const c = combinedRatio(L); return c == null ? "—" : `≈ ${(c * 100).toFixed(0)}%`; } },
  lossRatio: { label: "Loss ratio", short: "Loss", get: (L) => { const r = lossRatio(L); return r == null ? "—" : `${(r * 100).toFixed(0)}%`; } },
  invInc: { label: "Investment income", short: "Inv. inc.", get: (L) => money(L.investmentIncome) },
  float: { label: "Float (reserves)", short: "Float", get: (L) => money(L.lossReserves) },
};

const SETS = {
  assetLight: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.cash, ROW.netDebt, ROW.bvps],
  consumer: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.roic, ROW.cash, ROW.netDebt, ROW.dps, ROW.bvps],
  capital: [ROW.revenue, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.roic, ROW.capex, ROW.capexToRev, ROW.capexToDep, ROW.totalDebt, ROW.cash, ROW.netDebt],
  retail: [ROW.revenue, ROW.grossMargin, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.cash, ROW.netDebt],
  financial: [ROW.revenue, ROW.nii, ROW.netIncome, ROW.eps, ROW.roe, ROW.rotce, ROW.efficiency, ROW.deposits, ROW.bvps, ROW.tbvps, ROW.dps],
  insurer: [ROW.revenue, ROW.premiums, ROW.netIncome, ROW.combined, ROW.lossRatio, ROW.roe, ROW.invInc, ROW.float, ROW.bvps, ROW.dps],
  reit: [ROW.revenue, ROW.netIncome, ROW.ffo, ROW.ffoPS, ROW.payout, ROW.debtAssets, ROW.totalDebt, ROW.dps, ROW.bvps],
  general: [ROW.revenue, ROW.opMargin, ROW.netIncome, ROW.eps, ROW.ownerEarnings, ROW.oeMargin, ROW.roic, ROW.totalDebt, ROW.cash, ROW.netDebt],
};

// Columns: each fiscal year, plus a trailing-twelve-months column when present
// (the freshest 12 months, folding in any quarter filed since the last 10-K).
const cols = hist.map((h) => ({ label: String(h.fy), lines: h.lines, ttm: false }));
if (company.ttm?.lines) {
  const asOf = company.ttm.asOf
    ? new Date(company.ttm.asOf + "T00:00:00Z").toLocaleDateString("en-US", { month: "short", year: "numeric", timeZone: "UTC" })
    : null;
  cols.push({ label: "TTM", sub: asOf, lines: company.ttm.lines, ttm: true });
}
const lastI = cols.length - 1;

// Normalize diluted shares to the latest basis so per-share rows stay continuous
// across stock splits. EDGAR only restates ~3 years back, so a year older than
// that can still be pre-split; detect the jump and scale earlier years to match.
{
  const s = cols.map((c) => c.lines?.sharesDiluted ?? null);
  const factor = new Array(s.length).fill(1);
  let f = 1;
  for (let i = s.length - 1; i > 0; i--) {
    factor[i] = f;
    let j = i - 1;
    while (j >= 0 && s[j] == null) j--;
    if (j >= 0 && s[i] != null && s[j] != null && s[j] > 0) {
      const r = s[i] / s[j];
      if (r > 1.4 || r < 0.7) f *= r; // a split (not buybacks) sits between j and i
    }
  }
  factor[0] = f;
  cols.forEach((c, i) => {
    if (c.lines && c.lines.sharesDiluted != null && factor[i] !== 1)
      c.lines = { ...c.lines, sharesDiluted: c.lines.sharesDiluted * factor[i] };
  });
}

// The row-set follows the business model. Banks, insurers and REITs each read on
// their own measures, so key off financialKind first (future-proof for any new
// financial), and fall back to the economic-model sector for everything else.
const fk = financialKind(company);
const setKey = fk === "insurer" ? "insurer" : fk === "reit" ? "reit" : fk === "bank" ? "financial" : sector.key;
const chosen = SETS[setKey] || SETS.general;

// Link a row's label to its entry on the Concepts page, where the term is defined.
const ROW_CONCEPT = {
  "Gross margin": "gross-margin", "Operating margin": "operating-margin",
  "Owner earnings": "owner-earnings", "Owner earnings margin": "owner-earnings", "ROIC": "roic",
  "Total debt": "net-debt", "Net debt / (cash)": "net-debt",
  "Net interest income": "net-interest-margin", "Return on equity": "return-on-equity",
  "Return on tangible equity": "rotce", "Efficiency ratio": "efficiency-ratio",
  "Tangible book / share": "tangible-book",
  "Funds from operations": "ffo", "FFO / share": "ffo", "Dividend payout (FFO)": "ffo", "Debt / assets": "net-debt",
  "Combined ratio": "combined-ratio", "Loss ratio": "combined-ratio",
  "Investment income": "insurance-float", "Float (reserves)": "insurance-float",
};
// Drop any row the data can't fill across the whole record.
const rows = chosen
  .map((r) => ({ label: r.label, short: r.short || r.label, kind: r.kind || "plain", concept: ROW_CONCEPT[r.label] || null, cells: cols.map((c) => r.get(c.lines)) }))
  .filter((r) => r.cells.some((c) => c !== "—"));

// Abbreviated year for narrow screens: 2017 → ’17, TTM stays.
const yShort = (lbl) => (lbl.length === 4 && /^\d{4}$/.test(lbl) ? "’" + lbl.slice(2) : lbl);

// A parenthesised/minus cell is a loss in most rows (red), but in the net-debt
// row it means net cash, which is a good thing (green).
const cellClass = (kind, c) => {
  const neg = c.startsWith("(") || c.startsWith("−");
  if (kind === "netdebt") return neg ? "pos" : "";
  return neg ? "neg" : "";
};
---

{hist.length >= 3 ? (
  <section class="tenyear">
    <div class="head">
      <h3 class="secHead">The record, {hist[0].fy}–{hist[hist.length - 1].fy}</h3>
      <span class="hint">realized figures from each filing, no estimates</span>
    </div>
    <div class="wrap">
      <table>
        <thead>
          <tr>
            <th class="rowlabel"></th>
            {cols.map((c, i) => (
              <th class={`${i === lastI ? "last" : ""} ${c.ttm ? "ttm" : ""}`}>
                <span class="yf">{c.label}</span><span class="ys">{c.ttm ? c.label : yShort(c.label)}</span>
                {c.sub ? <span class="sub">{c.sub}</span> : null}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <th class="rowlabel"><span class="lf">{r.concept ? <Term id={r.concept}>{r.label}</Term> : r.label}</span><span class="ls">{r.short}</span></th>
              {r.cells.map((c, i) => (
                <td class={`${i === lastI ? "last" : ""} ${cols[i].ttm ? "ttm" : ""} ${cellClass(r.kind, c)}`}>{c}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
) : null}

<style>
  .tenyear { margin: 22px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 5px; }
  .secHead { font-family: var(--serif); font-weight: 600; margin: 0; font-size: clamp(22px, 3.4vw, 27px); letter-spacing: -0.01em; line-height: 1.15; color: var(--ink); }
  .hint { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); }

  .wrap { overflow-x: auto; margin-top: 4px; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; font-variant-numeric: tabular-nums; white-space: nowrap; }
  thead th { font-weight: 600; color: var(--muted); font-size: 12px; text-align: right; padding: 8px 10px 6px; border-bottom: 1px solid var(--rule); }
  tbody th.rowlabel { text-align: left; font-weight: 600; color: var(--ink); padding: 7px 14px 7px 0; position: sticky; left: 0; background: var(--paper); }
  thead th.rowlabel { position: sticky; left: 0; background: var(--paper); }
  td { text-align: right; padding: 7px 10px; border-bottom: 1px solid var(--rule); color: var(--ink); }
  td.last, thead th.last { font-weight: 700; }
  th.ttm, td.ttm { background: var(--accent-tint); }
  .sub { display: block; font-weight: 400; font-size: 10px; letter-spacing: 0.02em; color: var(--muted); text-transform: none; }
  td.neg { color: var(--bad); }
  td.pos { color: var(--good, #1a7a3c); }
  tbody tr:hover td, tbody tr:hover th.rowlabel { background: #faf9f6; }

  /* Short labels are hidden until the screen is narrow, where they buy column room. */
  .ls, .ys { display: none; }
  @media (max-width: 560px) {
    table { font-size: 11.5px; }
    thead th { padding: 7px 7px 5px; font-size: 10.5px; }
    td { padding: 6px 7px; }
    tbody th.rowlabel { padding: 6px 9px 6px 0; font-size: 11.5px; }
    .lf, .yf { display: none; }
    .ls, .ys { display: inline; }
  }
</style>
