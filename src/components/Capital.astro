---
import { capitalHistory } from "../lib/capital.mjs";
import { fmtMoney, currencySymbol } from "../lib/fundamentals.mjs";

const { company } = Astro.props;
const cap = capitalHistory(company);

const ccy = company.currency || "USD";
const sym = currencySymbol(ccy);
const $ = (v) => fmtMoney(v, ccy);
const pct = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${Math.abs(v * 100).toFixed(dp)}%`);
const per = (v) => (v == null ? "—" : `${sym}${v.toFixed(2)}`);

const segs = cap
  ? [
      { label: "Reinvested", amt: cap.capex, pctCfo: cap.pReinvest, color: "var(--viz-1)" },
      { label: "Dividends", amt: cap.div, pctCfo: cap.pDiv, color: "var(--accent)" },
      { label: "Buybacks", amt: cap.bb, pctCfo: cap.pBB, color: "var(--viz-2)" },
      { label: cap.overspent ? "Funded by debt / cash" : "Retained (debt / cash)", amt: Math.max(0, cap.retained), pctCfo: cap.pRetained, color: "var(--viz-muted)", muted: true },
    ].filter((s) => s.amt > 0)
  : [];
const totalUse = segs.reduce((a, s) => a + s.amt, 0) || 1;
segs.forEach((s) => (s.w = (s.amt / totalUse) * 100));

// The report-card facts, each a value and one plain line of context. No grade: the row
// states what happened and stops. Rows the data can't fill drop out.
const facts = cap
  ? [
      {
        key: "returned",
        label: "Returned to owners",
        value: $(cap.returned),
        note: `${cap.oeTotal > 0 ? `${pct(cap.returnedOfOE)} of the owner earnings the business produced over the span, ` : ""}${$(cap.div)} as dividends and ${$(cap.bb)} as buybacks.`,
        show: cap.returned > 0,
      },
      {
        key: "bbprice",
        label: "Average price paid for buybacks",
        value: cap.avgBuybackPrice != null ? per(cap.avgBuybackPrice) : "—",
        note: cap.avgBuybackPrice != null
          ? `Across the years the filing reports a share count, ${(cap.bbSharesPriced / 1e6).toFixed(0)}M shares were bought for ${$(cap.bbSpentPriced)}, about ${per(cap.avgBuybackPrice)} each. Compare that to the price you bring and to the per-share figures above.`
          : cap.bbPriceUnreliable
          ? `Buybacks ran ${$(cap.bb)} over the span, but a stock split in the window left the reported buyback-share counts on a basis the diluted-share count doesn't match, so a comparable average price can't be deduced honestly here.`
          : `Buybacks ran ${$(cap.bb)} over the span, but the filings don't tag the share count needed to deduce the average price paid.`,
        show: cap.bb > 0,
      },
      {
        key: "sharecount",
        label: "Did the share count actually fall?",
        value: cap.shareChange != null ? pct(cap.shareChange, 1) : "—",
        // No good/warn colour: a falling count is not unambiguously good (buying back overvalued
        // stock destroys value) and a rising one can be fine (a growth issuer). The number and the
        // prose carry it; the page grades nothing.
        cls: "",
        note: cap.shareChange == null
          ? "No continuous share count across the span."
          : cap.shareChange <= -0.01
          ? `The diluted count fell from ${(cap.firstShares / 1e6).toFixed(0)}M to ${(cap.lastShares / 1e6).toFixed(0)}M, so the buybacks outran the stock issued to staff: each remaining share owns more of the business.`
          : cap.shareChange >= 0.01
          ? `The diluted count rose from ${(cap.firstShares / 1e6).toFixed(0)}M to ${(cap.lastShares / 1e6).toFixed(0)}M: issuance (stock pay, deals) outran any buybacks, so owners were diluted on net.`
          : `The diluted count barely moved (${(cap.firstShares / 1e6).toFixed(0)}M to ${(cap.lastShares / 1e6).toFixed(0)}M): buybacks roughly offset the stock issued to staff.`,
        show: true,
      },
      {
        key: "dividends",
        label: "Dividend record",
        value: cap.dpsLast != null ? `${per(cap.dpsLast)}/sh` : (cap.divYears > 0 ? "Pays" : cap.divReported ? "None" : "—"),
        note: cap.divYears === 0
          ? (cap.divReported
            ? "Paid no dividend over the span; it returns cash through buybacks or retains it."
            : "No dividend line was reported in the filing data over the span, so we can't say whether it pays one — check the filing itself before assuming it does not.")
          : `Paid in ${cap.divYears} of the years on record${cap.dpsGrowth != null ? `, the per-share dividend ${cap.dpsGrowth >= 0 ? "growing" : "shrinking"} about ${pct(Math.abs(cap.dpsGrowth))} a year` : ""}. ${cap.everCut ? "It was cut at least once along the way." : "It was never cut over the span."}`,
        show: true,
      },
      {
        key: "retained",
        label: "Return on what it retained",
        value: cap.returnOnRetained != null ? pct(cap.returnOnRetained) : "—",
        note: cap.returnOnRetained != null
          ? `Of the earnings it kept rather than paid out (${$(cap.retainedEarnings)} over the span), annual owner earnings (first three years vs last three) grew ${$(cap.incrementalOE)}, so each retained ${sym}1 added about ${(cap.returnOnRetained).toFixed(2)} of yearly owner earnings. Buffett's test, run on owner earnings instead of market value.`
          : "Not read here: owner earnings are negative over the span, or the company returned nearly all its earnings rather than retaining them, so there is too little retained to measure a return on.",
        show: cap.returnOnRetained != null || cap.retainedEarnings > 0,
      },
    ].filter((f) => f.show)
  : [];
---

{cap ? (
  <section class="cap">
    <div class="head">
      <h3 class="secTitle">How the cash was used, {cap.span}</h3>
    </div>

    <p class="lede">
      Over the record, the business generated <b>{$(cap.cfo)}</b> of operating cash, and how management
      split it is, as Buffett insists, the job that matters most. Here it reads as <b>{cap.character}</b>.
    </p>

    <div class="bar" role="img" aria-label="Allocation of operating cash">
      {segs.map((s) => <span class="seg" style={`width:${s.w}%;background:${s.color}`} title={`${s.label} ${$(s.amt)}`}></span>)}
    </div>
    <ul class="legend">
      {segs.map((s) => (
        <li>
          <span class="sw" style={`background:${s.color}`}></span>
          <span class="ll">{s.label}</span>
          <span class="lv">{$(s.amt)} · {pct(s.pctCfo)}</span>
        </li>
      ))}
    </ul>

    <ul class="facts">
      {facts.map((f) => (
        <li>
          <div class="frow">
            <span class="flabel">{f.label}</span>
            <span class={`fvalue ${f.cls || ""}`}>{f.value}</span>
          </div>
          <p class="fnote">{f.note}</p>
        </li>
      ))}
    </ul>

    <p class="foot">
      Buybacks are gross of stock issued to staff; the share-count line above is the net of that, the figure that
      actually decides whether owners gained. The average price paid blends a year of purchases (and any accelerated
      repurchase), so read it as close, not exact. None of this is a grade, only the record of where the cash went and
      on what terms; the return earned on the dollars reinvested is the durability question above.
    </p>
  </section>
) : null}

<style>
  .cap { margin: 24px 0; }
  .head { border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .lede { font-family: var(--serif); font-size: clamp(15px, 2.3vw, 17px); line-height: 1.5; margin: 12px 0 0; max-width: 70ch; }
  .lede b { font-weight: 600; }

  .bar { display: flex; width: 100%; height: 26px; margin: 16px 0 0; border: 1px solid var(--rule-strong); overflow: hidden; }
  .seg { display: block; height: 100%; }

  .legend { list-style: none; padding: 0; margin: 12px 0 0; display: flex; flex-wrap: wrap; gap: 8px 22px; }
  .legend li { display: flex; align-items: baseline; gap: 7px; font-size: 13px; }
  .sw { width: 11px; height: 11px; flex: 0 0 auto; border: 1px solid rgba(128,128,128,0.35); transform: translateY(1px); }
  .ll { color: var(--ink); }
  .lv { color: var(--muted); font-variant-numeric: tabular-nums; }

  .facts { list-style: none; padding: 0; margin: 18px 0 0; }
  .facts li { padding: 13px 0; border-bottom: 1px solid var(--rule); }
  .facts li:first-child { border-top: 1px solid var(--rule); }
  .frow { display: flex; align-items: baseline; justify-content: space-between; gap: 14px; }
  .flabel { font-weight: 600; font-size: 15px; color: var(--ink); }
  .fvalue { font-size: 20px; font-weight: 700; font-variant-numeric: tabular-nums; flex: 0 0 auto; letter-spacing: -0.01em; }
  .fvalue.good { color: var(--good); }
  .fvalue.warn { color: var(--warn); }
  .fnote { font-size: 13.5px; color: var(--ink-dim); margin: 5px 0 0; line-height: 1.55; max-width: 76ch; }

  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 14px; padding-top: 11px; max-width: 74ch; line-height: 1.5; }
</style>
