---
import fundamentals from "../data/fundamentals.json";
import { classify } from "../lib/archetype.mjs";
import { fmtUSD, roicValue } from "../lib/fundamentals.mjs";
import { returnOnEquity, returnOnTangibleEquity, efficiencyRatio, netInterestMargin } from "../lib/financials.mjs";

const { company } = Astro.props;
const all = fundamentals.companies || [];

// Peers: same 3-digit SIC (a tight industry group); broaden to the 2-digit group,
// then to the economic model, if that is too thin. Free, just the data we pull.
function findPeers(co) {
  const sic = String(co.sic || "");
  const inSic = (n) => (sic.slice(0, n) ? all.filter((c) => c.ticker !== co.ticker && String(c.sic || "").slice(0, n) === sic.slice(0, n)) : []);
  let p = inSic(3);
  if (p.length < 2) p = inSic(2);
  if (p.length < 2) {
    const arch = classify(co).sector.key;
    p = all.filter((c) => c.ticker !== co.ticker && classify(c).sector.key === arch);
  }
  const rev = co.lines?.revenue || 0;
  return p.sort((a, b) => Math.abs((a.lines?.revenue || 0) - rev) - Math.abs((b.lines?.revenue || 0) - rev)).slice(0, 7);
}

const group = [company, ...findPeers(company)].sort((a, b) => (b.lines?.revenue || 0) - (a.lines?.revenue || 0));

const pr = (v, dp = 0) => (v == null ? "—" : `${(v * 100).toFixed(dp)}%`);
const isFin = ["financial", "reit"].includes(classify(company).sector.key);

const metricsOf = (c) => {
  const L = c.lines || {};
  return {
    revenue: L.revenue,
    grossMargin: L.revenue && L.costOfRevenue != null ? (L.revenue - L.costOfRevenue) / L.revenue : null,
    opMargin: L.operatingIncome != null && L.revenue ? L.operatingIncome / L.revenue : null,
    roic: roicValue(L),
    oeMargin: L.cashFromOps != null && L.capex != null && L.revenue ? (L.cashFromOps - Math.abs(L.capex)) / L.revenue : null,
    roe: returnOnEquity(L),
    rotce: returnOnTangibleEquity(L),
    efficiency: efficiencyRatio(L),
    nim: netInterestMargin(L),
  };
};

// The comparison columns are archetype-aware: a bank is compared on the bank lens,
// not on margins and ROIC. "Best" respects each column's direction (efficiency low).
const COLS = isFin
  ? [
      { key: "roe", label: "ROE", dp: 0, better: "high" },
      { key: "rotce", label: "ROTCE", dp: 0, better: "high" },
      { key: "efficiency", label: "Efficiency", dp: 0, better: "low" },
      { key: "nim", label: "Net int. margin", dp: 1, better: "high" },
    ]
  : [
      { key: "grossMargin", label: "Gross margin", dp: 0, better: "high" },
      { key: "opMargin", label: "Op. margin", dp: 1, better: "high" },
      { key: "roic", label: "ROIC", dp: 0, better: "high" },
      { key: "oeMargin", label: "Owner earn. margin", dp: 0, better: "high" },
    ];

const rows = group.map((c) => ({ c, m: metricsOf(c) }));
const best = {};
for (const col of COLS) {
  let bt = null, bv = col.better === "low" ? Infinity : -Infinity;
  for (const r of rows) { const v = r.m[col.key]; if (v == null) continue; if (col.better === "low" ? v < bv : v > bv) { bv = v; bt = r.c.ticker; } }
  best[col.key] = bt;
}
---

{group.length >= 2 ? (
  <section class="peers">
    <h3 class="secHead">Peers, {classify(company).industry.label}</h3>
    <p class="pNote">The same industry, side by side on {isFin ? "the bank lens" : "owner economics"}, compare, don't rank by a single number. <span class="bestKey">●</span> marks best in the group.</p>
    <div class="wrap">
      <table>
        <thead>
          <tr>
            <th class="tl">Company</th><th>Revenue</th>
            {COLS.map((col) => <th>{col.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map(({ c, m }) => (
            <tr class={c.ticker === company.ticker ? "me" : ""}>
              <th class="tl"><a href={`/c/${c.ticker}`}>{c.ticker}</a><span class="nm">{c.name}</span></th>
              <td>{m.revenue != null ? fmtUSD(m.revenue) : "—"}</td>
              {COLS.map((col) => <td class={best[col.key] === c.ticker ? "win" : ""}>{pr(m[col.key], col.dp)}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
) : null}

<style>
  .peers { margin: 22px 0; }
  .secHead { font-family: var(--sans); font-weight: 600; margin: 0; font-size: 11.5px; letter-spacing: 0.09em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid var(--rule-strong); padding-bottom: 5px; }
  .pNote { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 9px 0 6px; }
  .bestKey { color: var(--good); font-style: normal; }

  .wrap { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; font-variant-numeric: tabular-nums; white-space: nowrap; }
  thead th { font-weight: 600; color: var(--muted); font-size: 12px; text-align: right; padding: 8px 10px 6px; border-bottom: 1px solid var(--rule); }
  thead th.tl, tbody th.tl { text-align: left; }
  tbody th.tl { font-weight: 600; padding: 9px 12px 9px 0; }
  tbody th.tl a { color: var(--accent); }
  .nm { color: var(--muted); font-weight: 400; font-size: 12px; margin-left: 8px; }
  td { text-align: right; padding: 9px 10px; border-bottom: 1px solid var(--rule); }
  tr.me th.tl a, tr.me td { font-weight: 700; }
  tr.me { background: var(--accent-tint); }
  td.win { color: var(--good); font-weight: 700; }
  td.win::after { content: " ●"; font-size: 9px; vertical-align: middle; }
</style>
