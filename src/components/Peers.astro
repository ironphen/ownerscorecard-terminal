---
import fundamentals from "../data/fundamentals.json";
import { classify } from "../lib/archetype.mjs";
import { fmtMoney, roicValue, topLineRevenue, ownerEarningsMargin, grossMargin, gmCorrupt } from "../lib/fundamentals.mjs";
import { returnOnEquity, returnOnTangibleEquity, efficiencyRatio, netInterestMargin } from "../lib/financials.mjs";
import { ffoMargin, ffoPayout, ffoOnAssets, debtToAssets } from "../lib/reits.mjs";
import { combinedRatio, lossRatio } from "../lib/insurers.mjs";
import { medicalLossRatio } from "../lib/managedCare.mjs";
import { financialKind, financialSubtype } from "../lib/archetype.mjs";
import { selectPeers, peerStat, REIT_SUBSECTOR_LABELS } from "../lib/peers.mjs";
import Term from "./Term.astro";

// The peer set is computed once on the page and passed in, so the universe scan runs a single time per
// page; selectPeers here is the fallback when the component is used on its own.
const { company, peers: peersProp, basis: basisProp, subsector: subsectorProp } = Astro.props;
const all = fundamentals.companies || [];

// Peers are drawn from the same economic engine and ranked by structural likeness — selectPeers lives in
// lib/peers.mjs so the rule is one place and testable. The basis (a real industry group vs the nearest by
// economic model) keeps the heading honest; the subsector, when a REIT, names the property bench.
const { peers, basis, subsector } = peersProp ? { peers: peersProp, basis: basisProp, subsector: subsectorProp } : selectPeers(company, all);
const group = [company, ...peers].sort((a, b) => (b.lines?.revenue || 0) - (a.lines?.revenue || 0));
const cls = classify(company);

const pr = (v, dp = 0) => (v == null ? "—" : `${(v * 100).toFixed(dp)}%`);
const median = (xs) => { if (!xs.length) return null; const s = [...xs].sort((a, b) => a - b); const m = Math.floor(s.length / 2); return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
const fk = financialKind(company);
const isLife = fk === "insurer" && financialSubtype(company) === "life-insurer";
const isReit = fk === "reit", isBank = fk === "bank", isInsurer = fk === "insurer" && !isLife;
const isFee = fk === "fee", isManagedCare = fk === "managedCare";

// Each comparison figure is read through the cycle, not off one year: the median of the metric across the
// company's record, so a peer caught at a peak or a trough doesn't distort the table — Graham's discipline,
// applied to the peer comparison the same way the scorecard and the record apply it. Falls back to the
// latest year only where the record is too short to normalize (under three readings). Revenue stays the
// latest figure: it is the scale anchor for the row, not a rate to average.
const norm = (c, fn) => {
  const hist = (c.history || []).map((h) => fn(h?.lines || {}, c)).filter((v) => v != null && isFinite(v));
  if (hist.length >= 3) return median(hist);
  const latest = fn(c.lines || {}, c);
  return latest != null && isFinite(latest) ? latest : null;
};
const metricsOf = (c) => ({
  revenue: topLineRevenue(c.lines || {}, c),
  grossMargin: norm(c, (L, co) => { const v = grossMargin(L); return gmCorrupt(v, co) ? null : v; }),
  opMargin: norm(c, (L) => (L.operatingIncome != null && L.revenue ? L.operatingIncome / L.revenue : null)),
  roic: norm(c, (L) => roicValue(L)),
  oeMargin: norm(c, (L, co) => ownerEarningsMargin(L, co)),
  netMargin: norm(c, (L) => (L.netIncome != null && L.revenue ? L.netIncome / L.revenue : null)),
  roe: norm(c, (L) => returnOnEquity(L)),
  rotce: norm(c, (L) => returnOnTangibleEquity(L)),
  efficiency: norm(c, (L) => efficiencyRatio(L)),
  nim: norm(c, (L) => netInterestMargin(L)),
  ffoMargin: norm(c, (L) => ffoMargin(L)),
  ffoOnAssets: norm(c, (L) => ffoOnAssets(L)),
  payout: norm(c, (L) => ffoPayout(L)),
  debtToAssets: norm(c, (L) => debtToAssets(L)),
  combined: norm(c, (L) => combinedRatio(L)),
  lossR: norm(c, (L) => lossRatio(L)),
  mlr: norm(c, (L) => medicalLossRatio(L)),
  invYield: norm(c, (L) => (L.investmentIncome != null && L.lossReserves ? L.investmentIncome / L.lossReserves : null)),
  roa: norm(c, (L) => (L.netIncome != null && L.totalAssets ? L.netIncome / L.totalAssets : null)),
});

// The comparison columns are archetype-aware: a bank on the bank lens, a REIT on
// FFO. "Best" respects each column's direction; "neutral" gets no best mark.
const COLS = isReit
  ? [
      { key: "ffoMargin", label: "FFO margin", concept: "ffo", dp: 0, better: "high" },
      { key: "ffoOnAssets", label: "FFO / assets", concept: "ffo", dp: 1, better: "high" },
      { key: "payout", label: "Payout (FFO)", concept: "ffo", dp: 0, better: "neutral" },
      { key: "debtToAssets", label: "Debt / assets", concept: "net-debt", dp: 0, better: "low" },
    ]
  : isLife
  ? [
      { key: "roe", label: "ROE", concept: "return-on-equity", dp: 0, better: "high" },
      { key: "invYield", label: "Yield on float", concept: "insurance-float", dp: 1, better: "high" },
      { key: "roa", label: "Return on assets", concept: "return-on-assets", dp: 1, better: "high" },
    ]
  : isInsurer
  ? [
      { key: "combined", label: "Combined ratio", concept: "combined-ratio", dp: 0, better: "low" },
      { key: "lossR", label: "Loss ratio", concept: "combined-ratio", dp: 0, better: "low" },
      { key: "roe", label: "ROE", concept: "return-on-equity", dp: 0, better: "high" },
    ]
  : isBank
  ? [
      { key: "roe", label: "ROE", concept: "return-on-equity", dp: 0, better: "high" },
      { key: "rotce", label: "ROTCE", concept: "rotce", dp: 0, better: "high" },
      { key: "efficiency", label: "Efficiency", concept: "efficiency-ratio", dp: 0, better: "low" },
      { key: "nim", label: "NII / assets", concept: "net-interest-margin", dp: 1, better: "neutral" },
    ]
  : isManagedCare
  ? [
      { key: "mlr", label: "Medical loss ratio", concept: "medical-loss-ratio", dp: 0, better: "neutral" },
      { key: "opMargin", label: "Op. margin", concept: "operating-margin", dp: 1, better: "high" },
      { key: "roe", label: "ROE", concept: "return-on-equity", dp: 0, better: "high" },
    ]
  : isFee
  ? [
      { key: "opMargin", label: "Op. margin", concept: "operating-margin", dp: 1, better: "high" },
      { key: "netMargin", label: "Net margin", concept: null, dp: 1, better: "high" },
      { key: "roe", label: "ROE", concept: "return-on-equity", dp: 0, better: "high" },
    ]
  : [
      { key: "grossMargin", label: "Gross margin", concept: "gross-margin", dp: 0, better: "high" },
      { key: "opMargin", label: "Op. margin", concept: "operating-margin", dp: 1, better: "high" },
      { key: "roic", label: "ROIC", concept: "roic", dp: 0, better: "high" },
      { key: "oeMargin", label: "Owner earn. margin", concept: "owner-earnings", dp: 0, better: "high" },
    ];

const rows = group.map((c) => ({ c, m: metricsOf(c) }));
// No "best" mark per column. Crowning a winner on a single measure is a verdict — and the same one
// the compare view explicitly forbids ("no highlighted 'better' cell"). The group-median row below is
// the honest context device: it shows where each figure sits in the distribution without ranking.

// The group's distribution per column — the median the company is read against, so a figure is context
// rather than a lone number. peerStat needs three readings (the company plus two peers); a thinner group
// simply shows no median line.
const subjectRow = rows.find((r) => r.c.ticker === company.ticker);
const dist = {};
for (const col of COLS) dist[col.key] = peerStat(rows.map((r) => r.m[col.key]), subjectRow?.m[col.key]);
const anyMed = COLS.some((col) => dist[col.key]);

const lens = isReit ? "the REIT lens" : isLife ? "the spread-and-book-value lens" : isInsurer ? "the underwriting lens" : isBank ? "the bank lens" : isManagedCare ? "the medical-loss-ratio lens" : isFee ? "fee margins" : "owner economics";
// A REIT's heading names its property subsector ("Net-lease REITs"), not the generic "Real estate" SIC
// label — that is the whole point of peering it within its own kind.
const subLabel = subsector ? REIT_SUBSECTOR_LABELS[subsector] || cls.industry.label : null;
const heading = basis === "model" ? "Peers, nearest by economic model" : `Peers, ${subLabel || cls.industry.label}`;
const intro = basis === "model"
  ? `No close industry peers in the catalog yet, so these are the nearest by economic model (${cls.sector.label.toLowerCase()}), compared on ${lens}. Don't rank by a single number.`
  : `The same industry, side by side on ${lens}, compare, don't rank by a single number.`;
---

{group.length >= 2 ? (
  <section class="peers">
    <h3 class="secTitle pHead">{heading}</h3>
    <p class="pNote">{intro} Each figure is a <b>through-cycle median</b>, so a peak or trough year can&rsquo;t distort it; the <b>group median</b> at the foot is the line to read each against.</p>
    <div class="wrap">
      <table>
        <thead>
          <tr>
            <th class="tl">Company</th><th>Revenue</th>
            {COLS.map((col) => <th>{col.concept ? <Term id={col.concept}>{col.label}</Term> : col.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map(({ c, m }) => (
            <tr class={c.ticker === company.ticker ? "me" : ""}>
              <th class="tl"><a href={`/c/${c.ticker}`}>{c.ticker}</a><span class="nm">{c.name}</span></th>
              <td>{m.revenue != null ? fmtMoney(m.revenue, c.currency || "USD") : "—"}</td>
              {COLS.map((col) => <td>{pr(m[col.key], col.dp)}</td>)}
            </tr>
          ))}
        </tbody>
        {anyMed ? (
          <tfoot>
            <tr class="medRow">
              <th class="tl">Group median</th>
              <td>—</td>
              {COLS.map((col) => <td>{dist[col.key] ? pr(dist[col.key].median, col.dp) : "—"}</td>)}
            </tr>
          </tfoot>
        ) : null}
      </table>
    </div>
  </section>
) : null}

<style>
  .peers { margin: 22px 0; }
  .pHead { border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; display: block; }
  .pNote { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); margin: 9px 0 6px; }
  .wrap { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; font-variant-numeric: tabular-nums; white-space: nowrap; }
  thead th { font-weight: 600; color: var(--muted); font-size: 12px; text-align: right; padding: 8px 10px 6px; border-bottom: 1px solid var(--rule); }
  thead th.tl, tbody th.tl { text-align: left; }
  tbody th.tl { font-weight: 600; padding: 9px 12px 9px 0; }
  tbody th.tl a { color: var(--accent); }
  .nm { color: var(--muted); font-weight: 400; font-size: 12px; margin-left: 8px; }
  td { text-align: right; padding: 9px 10px; border-bottom: 1px solid var(--rule); }
  tr.me th.tl a, tr.me td { font-weight: 700; }
  tr.me { background: var(--accent-tint); }

  /* The group-median row: the distribution line the company's figures are read against. Set off with a
     heavier rule and a muted, italic label so it reads as the yardstick, not another peer. */
  tfoot .medRow th.tl, tfoot .medRow td { border-top: 2px solid var(--rule-strong); padding-top: 9px; color: var(--ink-soft); font-weight: 600; }
  tfoot .medRow th.tl { font-style: italic; color: var(--muted); }
  .pNote b { font-style: normal; color: var(--ink); }
</style>
