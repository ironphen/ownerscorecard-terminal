---
// The weld: each thing the company's own 10-K flags as worth worrying about,
// set against the single number from the same filings that bears on it. This is
// where the archetype's numbers and the NLP's reading of the prose finally meet —
// the company's words on the left, the arithmetic that tests them on the right.
import language from "../data/language.json";
import { fmtUSD, ownerEarningsMargin, coverage, cashPosition } from "../lib/fundamentals.mjs";
import { moatReport } from "../lib/durability.mjs";

const { company } = Astro.props;
const L = language?.companies?.[company.ticker] || null;
const flags = L?.ownerFlags || [];

const lines = company.lines || {};
const rev = lines.revenue;
const gm = rev && lines.costOfRevenue != null ? 1 - lines.costOfRevenue / rev : null;
const oem = ownerEarningsMargin(lines);
const report = moatReport(company);
const cov = coverage(company);
const cash = cashPosition(company);
const factBy = (label) => report?.facts.find((f) => f.label === label) || null;

const pct = (v, dp = 0) => (v == null ? "—" : `${v < 0 ? "−" : ""}${(Math.abs(v) * 100).toFixed(dp)}%`);

// Map a flag's lens to the figure that bears on it. null = a judgment, not arithmetic.
function bearing(lens) {
  switch (lens) {
    case "Customer concentration":
      return rev != null ? { label: "Revenue riding on it", value: fmtUSD(rev) } : null;
    case "Pricing power & competition": {
      const m = factBy("Operating margin");
      if (m) return { label: "Operating margin, then → now", value: m.value };
      return gm != null ? { label: "Gross margin", value: pct(gm) } : null;
    }
    case "Supplier & input dependence":
      return gm != null ? { label: "Gross-margin buffer", value: pct(gm) } : null;
    case "Concentrated dependence":
      return oem != null ? { label: "Owner-earnings margin at stake", value: pct(oem) } : rev != null ? { label: "Revenue", value: fmtUSD(rev) } : null;
    case "Debt terms & refinancing":
    case "Going-concern doubt": {
      const parts = [];
      if (cash) parts.push(`${cash.value} ${cash.label.toLowerCase()}`);
      if (cov && cov.ratio != null && cov.ratio >= 0) parts.push(`interest covered ${cov.ratio.toFixed(1)}×`);
      else if (cov && cov.noBurden) parts.push("no real interest burden");
      else if (cov) parts.push("operations don't cover interest");
      return parts.length ? { label: "Balance sheet", value: parts.join(" · ") } : null;
    }
    case "Dilution": {
      const s = factBy("Share count");
      return s ? { label: "Share count", value: s.value } : null;
    }
    case "Cyclicality & demand": {
      const w = factBy("Worst year");
      return w ? { label: "Worst year on record", value: w.value } : null;
    }
    default:
      return null; // litigation, regulation — read, don't compute
  }
}

const items = flags.map((f) => ({ ...f, fig: bearing(f.lens) }));
---

{items.length ? (
  <section class="oread">
    <div class="head">
      <h2>What the filing flags{L.fy ? ` — FY${L.fy}` : ""}</h2>
      {L.sourceUrl ? <a class="src" href={L.sourceUrl} target="_blank" rel="noopener">read the 10-K →</a> : null}
    </div>
    <p class="intro">
      A 10-K names what an owner should worry about — in the company's own words. Here are
      the ones Graham and Buffett would stop on, each set against the figure from the same
      filings that bears on it. We point; the judgment is yours.
    </p>

    <ul class="items">
      {items.map((it) => (
        <li>
          <div class="lensRow">
            <span class="lens">{it.lens}</span>
            <span class="sec">{it.section}</span>
          </div>
          <p class="why">{it.why}</p>
          <blockquote>“{it.quote}{it.quote.length >= 300 ? "…" : ""}”</blockquote>
          {it.fig ? (
            <div class="weld">
              <span class="arrow">The numbers ↓</span>
              <span class="fl">{it.fig.label}</span>
              <span class="fv">{it.fig.value}</span>
            </div>
          ) : (
            <div class="weld judgment">A judgment, not a number — weigh it against the filing yourself.</div>
          )}
        </li>
      ))}
    </ul>
  </section>
) : null}

<style>
  .oread { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .head h2 { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .intro { font-family: var(--serif); font-style: italic; font-size: 13.5px; color: var(--muted); margin: 9px 0 0; max-width: 66ch; }

  .items { list-style: none; padding: 0; margin: 12px 0 0; }
  .items li { padding: 14px 0; border-bottom: 1px solid var(--rule); }
  .lensRow { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .lens { font-family: var(--sans); font-weight: 700; font-size: 15px; color: var(--ink); }
  .sec { font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); flex: 0 0 auto; }
  .why { font-size: 13px; color: #3a3e46; margin: 4px 0 0; line-height: 1.5; }
  blockquote {
    font-family: var(--serif); font-size: 14.5px; line-height: 1.5; color: #2c2f36;
    border-left: 2px solid var(--accent); padding: 3px 0 3px 14px; margin: 8px 0 0;
  }

  .weld { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin: 10px 0 0; padding: 7px 12px; background: var(--accent-tint); }
  .arrow { font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); font-weight: 600; flex: 0 0 auto; }
  .weld .fl { font-size: 13px; color: var(--muted); }
  .weld .fv { font-size: 15px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--ink); margin-left: auto; }
  .weld.judgment { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--muted); display: block; }
</style>
