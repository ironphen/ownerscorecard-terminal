---
// What an owner would ask — the owner-initiated interrogation. NOT "what the filing warns about"
// (risk-factor boilerplate a company is required to print, which Buffett and Munger distrust): the
// selection is driven by a NUMBER firing or a rare, specific admission the filing can't retract —
// never by the filing's own risk language. Each line is a question an owner puts to the business,
// welded to a figure OSC computes or to a verbatim sentence, with a pointer to verify. Present,
// never pronounce.
//
// Deliberately NARROW to avoid duplicating the page. Durability, solvency, dilution, capital
// allocation, goodwill-on-equity, pricing power, and the owner/promoter candor tally already live
// in the Scorecard, Inversion, Acquisitions, Capital and the record charts. This section carries
// ONLY the owner questions nothing else surfaces: who the revenue depends on, whether management
// plainly owned its misses, and which reported numbers rest on management's own judgment.
import language from "../data/language.json";
import { fmtMoney, topLineRevenue } from "../lib/fundamentals.mjs";
import { cleanOwnerFlags, customerConcentration } from "../lib/business.mjs";

const { company } = Astro.props;
const L = language?.companies?.[company.ticker] || null;
const $ = (v) => fmtMoney(v, company?.currency || "USD");
const src = L?.sourceUrl || null;
const cur = company.ttm?.lines || company.lines || {};
const curLabel = company.ttm?.lines ? "TTM" : company.fy ? `FY${company.fy}` : "latest";
const rev = topLineRevenue(cur, company) ?? topLineRevenue(company.lines, company);

const items = [];

// 1. Concentration — how much of the top line rides on one buyer. The one genuinely owner-grade weld
// kept from the old section: parsed conservatively from the company's own disclosure (the parser
// rejects geographic / receivable / backlog bases), so it fires only where a dominant buyer is real.
const concFlag = cleanOwnerFlags(L?.ownerFlags).find((f) => f.lens === "Customer concentration");
if (concFlag && rev != null) {
  const cc = customerConcentration(concFlag.quote);
  if (cc) {
    items.push({
      q: "How much of the revenue rides on one buyer?",
      fig: `≈${$(rev * cc.pct)} · ${(cc.pct * 100).toFixed(0)}% of revenue on the largest customer${cc.multi ? "s" : ""} (${curLabel})`,
      quote: concFlag.quote,
    });
  }
}

// 2. Candor — did management plainly own a miss, in the first person? A rare tell (~2% of filings), so
// its presence is itself the signal. Buffett's owner-report standard; the sentence the filing can't
// take back.
const admissions = L?.mdna?.candor?.admissions || [];
if (admissions.length) {
  items.push({
    q: "Does management own its misses?",
    fig: `${admissions.length} plain admission${admissions.length === 1 ? "" : "s"} in this year's filing`,
    quote: admissions[0],
  });
}

// 3. Critical estimates — which reported numbers rest on management's own judgment. Led by the NAMED
// topics (specific to this filing, so differential — an insurer's reserves are not a software firm's
// revenue timing), with GOODWILL excluded because Acquisitions already carries the goodwill read.
// Points at the note; it welds nothing itself — the size is read in the record.
const judgment = L?.buffettRead?.judgment;
const critTopics = judgment && judgment.count >= 1
  ? (judgment.topics || []).filter((t) => !/goodwill/i.test(t))
  : [];
if (critTopics.length) {
  items.push({
    q: "Which reported numbers are a judgment call?",
    fig: `Management names ${critTopics.slice(0, 4).join(", ")} as critical estimates`,
    note: "each is partly an opinion — read the note before trusting the figure",
  });
}
---

{items.length ? (
  <section class="ask">
    <div class="head">
      <h3 class="secTitle">What an owner would ask{L?.fy ? `, FY${L.fy}` : ""}</h3>
      {src ? <a class="src" href={src} target="_blank" rel="noopener">read the 10-K →</a> : null}
    </div>
    <ul class="qs">
      {items.map((it) => (
        <li>
          <div class="q">{it.q}</div>
          <div class="fig">{it.fig}</div>
          {it.quote ? (
            <blockquote>“{it.quote}{it.quote.length >= 300 ? "…" : ""}”{src ? <a class="verify" href={src} target="_blank" rel="noopener">verify →</a> : null}</blockquote>
          ) : null}
          {it.note ? (
            <p class="note">{it.note}{src ? <a class="verify" href={src} target="_blank" rel="noopener">verify →</a> : null}</p>
          ) : null}
        </li>
      ))}
    </ul>
    <p class="foot">The questions the record and the charts don't answer on their own — the figure and the place to look, never a verdict.</p>
  </section>
) : null}

<style>
  .ask { margin: 24px 0; }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid var(--rule-strong); padding-bottom: 6px; }
  .secTitle { margin: 0; }
  .src { font-size: 12px; color: var(--accent); flex: 0 0 auto; }
  .qs { list-style: none; padding: 0; margin: 12px 0 0; }
  .qs li { padding: 13px 0; border-bottom: 1px solid var(--rule); }
  .q { font-family: var(--sans); font-weight: 700; font-size: 15.5px; color: var(--ink); line-height: 1.35; }
  .fig { font-size: 15px; font-variant-numeric: tabular-nums; color: var(--ink-soft); margin: 4px 0 0; }
  blockquote { font-family: var(--serif); font-size: 14px; line-height: 1.5; color: var(--ink-soft); border-left: 2px solid var(--accent); padding: 3px 0 3px 14px; margin: 8px 0 0; max-width: 78ch; }
  .note { font-size: 13px; color: var(--ink-dim); margin: 6px 0 0; line-height: 1.5; max-width: 78ch; }
  .verify { font-family: var(--sans); font-size: 11px; letter-spacing: 0.03em; color: var(--accent); margin-left: 8px; white-space: nowrap; }
  .foot { font-family: var(--serif); font-style: italic; font-size: 12.5px; color: var(--muted); border-top: 1px solid var(--rule-strong); margin-top: 14px; padding-top: 10px; max-width: 78ch; }
</style>
