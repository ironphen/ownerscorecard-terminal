---
const { title = "Owner Scorecard" } = Astro.props;
const today = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap"
    />

    <style is:global>
      :root {
        --serif: "Fraunces", Georgia, "Times New Roman", serif;
        --sans: "Inter", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;

        --paper: #fcfcfa;
        --ink: #18191d;
        --muted: #5b616c;
        --faint: #8b909a;
        --rule: #e4e3dd;
        --rule-strong: #16181d;

        --accent: #1b3b6f;       /* ink blue — links, brand marks */
        --accent-tint: #eef2f8;
        --good: #1a7a3c;
        --bad: #8b1a1a;
        --warn: #9a6a00;
        --info: #1b3b6f;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

      body {
        font-family: var(--sans);
        font-size: 17px;
        line-height: 1.6;
        color: var(--ink);
        background: var(--paper);
        max-width: 880px;
        margin: 0 auto;
        padding: 0 20px 64px;
        font-feature-settings: "kern" 1;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-wrap: balance;
      }
      h1 { font-size: clamp(30px, 5vw, 42px); }
      h2 { font-size: clamp(22px, 3.4vw, 27px); }
      h3 { font-size: 20px; }

      p { margin: 0 0 14px; }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 2px; }

      ::selection { background: var(--accent-tint); }

      .tnum { font-variant-numeric: tabular-nums; }

      /* ---- masthead ---- */
      .masthead { margin: 26px 0 22px; }
      .mastRule { border: 0; border-top: 1px solid var(--rule-strong); margin: 0; }
      .mastRuleThin { border: 0; border-top: 1px solid var(--rule); margin: 0; }

      .mastBar {
        display: flex; align-items: baseline; justify-content: space-between;
        gap: 16px; flex-wrap: wrap; padding: 14px 0 12px;
      }
      .brand {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(28px, 6vw, 38px);
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1;
      }
      .brand:hover { text-decoration: none; }
      .dateline {
        font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--muted); font-weight: 500;
      }

      .nav {
        display: flex; gap: 22px; flex-wrap: wrap;
        padding: 9px 0;
        font-size: 14px; letter-spacing: 0.02em;
      }
      .nav a {
        color: var(--ink); font-weight: 500; text-transform: uppercase;
        font-size: 12.5px; letter-spacing: 0.07em;
      }
      .nav a:hover { color: var(--accent); text-decoration: none; }

      main { margin-top: 22px; }

      /* ---- footer ---- */
      footer { border-top: 1px solid var(--rule-strong); margin-top: 48px; padding-top: 16px; }
      footer .colophon {
        font-family: var(--serif); font-size: 14px; color: var(--muted); margin: 0 0 10px;
      }
      footer small { display: block; color: var(--faint); font-size: 12px; line-height: 1.5; }

      @media (max-width: 520px) {
        body { font-size: 16px; padding: 0 14px 48px; }
        .nav { gap: 16px; }
      }
    </style>
  </head>

  <body>
    <header class="masthead">
      <hr class="mastRule" />
      <div class="mastBar">
        <a class="brand" href="/">Owner Scorecard</a>
        <div class="dateline">An independent research publication · {today}</div>
      </div>
      <hr class="mastRuleThin" />
      <nav class="nav">
        <a href="/">Catalog</a>
        <a href="/wire">Wire</a>
        <a href="/method">Method</a>
        <a href="/articles">Articles</a>
      </nav>
      <hr class="mastRule" />
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p class="colophon">Owner Scorecard</p>
      <small>
        Owner Scorecard is an independent publisher of financial research and is not registered as an investment adviser or broker-dealer.
        This material is for informational and educational purposes only and does not constitute investment, tax, or legal advice, or a recommendation to buy or sell any security.
        Figures are drawn from public SEC filings and believed reliable, but accuracy and completeness are not guaranteed.
        Any positions or results mentioned are the author's own and may change at any time without notice.
        Past performance is not indicative of future results; do your own research and consult a qualified professional before investing.
      </small>
    </footer>
  </body>
</html>
