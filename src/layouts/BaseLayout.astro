---
const { title = "Owner Scorecard" } = Astro.props;
const today = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      /* Set the theme before first paint to avoid a flash. Dark is the default;
         a reader's saved choice (light) is honored. */
      (function () {
        try {
          var t = localStorage.getItem("oss-theme");
          document.documentElement.dataset.theme = t === "light" ? "light" : "dark";
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" id="themeColorMeta" content="#15161a" />
    <title>{title}</title>

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap"
    />

    <style is:global>
      :root {
        --serif: "Fraunces", Georgia, "Times New Roman", serif;
        --sans: "Inter", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;

        /* Light theme (the toggle's alternate; dark is the default below). */
        --paper: #fcfcfa;
        --surface: #ffffff;       /* cards, inputs, sticky backgrounds */
        --surface-2: #f6f5f1;     /* row hover, subtle fills */
        --ink: #18191d;
        --ink-soft: #2c2f36;      /* body text */
        --ink-dim: #3a3e46;       /* secondary body text */
        --muted: #5b616c;
        --faint: #8b909a;
        --rule: #e4e3dd;
        --rule-soft: #eeede7;
        --rule-strong: #16181d;

        --accent: #1b3b6f;        /* ink blue — links, brand marks */
        --accent-tint: #eef2f8;
        --accent-ink: #ffffff;    /* text on a solid accent fill */
        --solid: #18191d;         /* a selected chip's fill */
        --solid-ink: #ffffff;     /* text on the solid fill */
        --good: #1a7a3c;
        --bad: #8b1a1a;
        --warn: #9a6a00;
        --info: #1b3b6f;
        --tag-bg: #f0efe9;
        --tag-ink: #565961;
        --warn-bg: #fff7e6;
        --warn-border: #e0c98a;
        --warn-ink: #7a5b00;
        --shadow: rgba(20, 22, 28, 0.06);
        /* Categorical data-viz fills (allocation bars, segment mix). */
        --viz-1: #2c3038; --viz-2: #2e7d6b; --viz-3: #a86b52; --viz-4: #9c8f6e;
        --viz-5: #5f7355; --viz-6: #5a6b7a; --viz-muted: #cfcec8;
      }

      /* Dark theme — the default. Warm near-black, off-white ink: an editorial,
         terminal-grade reading surface, not pure black on pure white inverted. */
      :root[data-theme="dark"] {
        --paper: #15161a;
        --surface: #1c1e23;
        --surface-2: #24262c;
        --ink: #ecebe4;
        --ink-soft: #cfcec6;
        --ink-dim: #a9a8a0;
        --muted: #8c8b84;
        --faint: #67665f;
        --rule: #2c2e34;
        --rule-soft: #232429;
        --rule-strong: #474851;

        --accent: #8aabe0;
        --accent-tint: #1b2431;
        --accent-ink: #0f1218;
        --solid: #ecebe4;
        --solid-ink: #15161a;
        --good: #57c47e;
        --bad: #e67f77;
        --warn: #dcb052;
        --info: #8aabe0;
        --tag-bg: #292b31;
        --tag-ink: #b6b5ad;
        --warn-bg: #28220f;
        --warn-border: #564a2b;
        --warn-ink: #dcb052;
        --shadow: rgba(0, 0, 0, 0.35);
        --viz-1: #c9ced7; --viz-2: #5cc1a1; --viz-3: #d29c80; --viz-4: #c4b68e;
        --viz-5: #95b285; --viz-6: #8ca5bf; --viz-muted: #494b51;
      }

      :root { color-scheme: light; }
      :root[data-theme="dark"] { color-scheme: dark; }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

      body {
        font-family: var(--sans);
        font-size: 17px;
        line-height: 1.6;
        color: var(--ink);
        background: var(--paper);
        max-width: 880px;
        margin: 0 auto;
        padding: 0 20px 64px;
        font-feature-settings: "kern" 1;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-wrap: balance;
      }
      h1 { font-size: clamp(30px, 5vw, 42px); }
      h2 { font-size: clamp(22px, 3.4vw, 27px); }
      h3 { font-size: 20px; }

      p { margin: 0 0 14px; }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 2px; }

      /* A visible, theme-aware focus ring for keyboard navigation. */
      :where(a, button, input, select, [tabindex]):focus-visible {
        outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 2px;
      }

      ::selection { background: var(--accent-tint); color: var(--ink); }

      .tnum { font-variant-numeric: tabular-nums; }

      /* ---- masthead ---- */
      .masthead { margin: 26px 0 22px; }
      .mastRule { border: 0; border-top: 1px solid var(--rule-strong); margin: 0; }
      .mastRuleThin { border: 0; border-top: 1px solid var(--rule); margin: 0; }

      .mastBar {
        display: flex; align-items: baseline; justify-content: space-between;
        gap: 16px; flex-wrap: wrap; padding: 14px 0 12px;
      }
      .brand {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(28px, 6vw, 38px);
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1;
      }
      .brand:hover { text-decoration: none; }
      .dateline {
        font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--muted); font-weight: 500;
      }

      .nav {
        display: flex; gap: 22px; flex-wrap: wrap;
        padding: 9px 0;
        font-size: 14px; letter-spacing: 0.02em;
      }
      .nav a {
        color: var(--ink); font-weight: 500; text-transform: uppercase;
        font-size: 12.5px; letter-spacing: 0.07em;
      }
      .nav a:hover { color: var(--accent); text-decoration: none; }
      .themeToggle {
        margin-left: auto; background: none; border: 1px solid var(--rule-strong);
        color: var(--ink); width: 32px; height: 26px; border-radius: 3px; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center; font-size: 13px;
        line-height: 1; padding: 0; align-self: center;
      }
      .themeToggle:hover { border-color: var(--accent); color: var(--accent); }
      .ttSun { display: none; } .ttMoon { display: inline; }
      :root[data-theme="dark"] .ttSun { display: inline; }
      :root[data-theme="dark"] .ttMoon { display: none; }

      main { margin-top: 22px; }

      /* ---- footer ---- */
      footer { border-top: 1px solid var(--rule-strong); margin-top: 48px; padding-top: 16px; }
      footer .colophon {
        font-family: var(--serif); font-size: 14px; color: var(--muted); margin: 0 0 10px;
      }
      footer small { display: block; color: var(--faint); font-size: 12px; line-height: 1.5; }

      @media (max-width: 520px) {
        body { font-size: 16px; padding: 0 14px 48px; }
        .nav { gap: 16px; }
      }
    </style>
  </head>

  <body>
    <header class="masthead">
      <hr class="mastRule" />
      <div class="mastBar">
        <a class="brand" href="/">Owner Scorecard</a>
        <div class="dateline">An independent research publication · {today}</div>
      </div>
      <hr class="mastRuleThin" />
      <nav class="nav">
        <a href="/">Catalog</a>
        <a href="/wire">Wire</a>
        <a href="/method">Method</a>
        <a href="/concepts">Concepts</a>
        <a href="/articles">Articles</a>
        <button id="themeToggle" class="themeToggle" type="button" aria-label="Switch between light and dark theme" title="Switch theme">
          <span class="ttSun" aria-hidden="true">☀</span><span class="ttMoon" aria-hidden="true">☾</span>
        </button>
      </nav>
      <hr class="mastRule" />
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p class="colophon">Owner Scorecard</p>
      <small>
        Owner Scorecard is an independent publisher of financial research and is not registered as an investment adviser or broker-dealer.
        This material is for informational and educational purposes only and does not constitute investment, tax, or legal advice, or a recommendation to buy or sell any security.
        Figures are drawn from public SEC filings and believed reliable, but accuracy and completeness are not guaranteed.
        Any positions or results mentioned are the author's own and may change at any time without notice.
        Past performance is not indicative of future results; do your own research and consult a qualified professional before investing.
      </small>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById("themeToggle");
        var meta = document.getElementById("themeColorMeta");
        function syncMeta() {
          if (!meta) return;
          var dark = document.documentElement.dataset.theme !== "light";
          meta.setAttribute("content", dark ? "#15161a" : "#fcfcfa");
        }
        syncMeta();
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem("oss-theme", next); } catch (e) {}
          syncMeta();
        });
      })();
    </script>
  </body>
</html>
