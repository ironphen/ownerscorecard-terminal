---
const { title = "Owner Scorecard" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      body { font-family: Garamond, Georgia, serif; max-width: 900px; margin: 24px auto; padding: 0 16px; }
      header { margin-bottom: 18px; }
      .brand { font-size: 34px; font-weight: 700; letter-spacing: 0.2px; margin: 0; }
      .brand a { text-decoration: none; color: inherit; }
      .quote { margin: 6px 0 10px; color: #444; font-style: italic; }
      nav { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 8px; }
      nav a { color: inherit; }
      nav a:hover { text-decoration: underline; }
      main { margin-top: 10px; }

      footer { border-top: 1px solid #ddd; margin-top: 26px; padding-top: 14px; color: #333; }
      footer .about { margin: 0 0 10px; }

      .promo { margin: 18px 0; text-align: center; }
      .rule { border-top: 1px solid #ddd; margin: 10px 0; }
      .promoTitle { font-weight: 700; letter-spacing: 0.6px; }
      .promoTitle a { text-decoration: none; color: inherit; }
      .promoUrl { font-size: 12px; color: #444; }
      .promoUrl a { color: inherit; text-decoration: none; }
      .promoUrl a:hover, .promoTitle a:hover { text-decoration: underline; }

      footer small { display: block; color: #555; line-height: 1.35; }
    </style>
  </head>

  <body>
    <header>
      <h1 class="brand"><a href="/">Owner Scorecard</a></h1>
      <div class="quote">“Start with the A’s.” — Warren Buffet</div>

      <nav>
        <a href="/">Directory</a>
        <a href="https://newsletter.ownerscorecard.com" target="_blank" rel="noopener">Newsletter</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p class="about">An enormously efficient way to garner information about various businesses &amp; their competitors.</p>

      <div class="promo">
        <div class="rule"></div>
        <div class="promoInner">
          <div class="promoTitle">
            <a href="https://dynastynexus.com" target="_blank" rel="noopener">DYNASTY NEXUS</a>
          </div>
          <div class="promoUrl">
            <a href="https://dynastynexus.com" target="_blank" rel="noopener">dynastynexus.com</a>
          </div>
        </div>
        <div class="rule"></div>
      </div>

      <small>
        R.G. Research is an independent publisher of financial research and is not registered as an investment adviser or broker-dealer.
        This report is for informational and educational purposes only and does not constitute investment, tax, or legal advice, or a recommendation to buy or sell any security.
        The information herein is based on sources believed to be reliable, but R.G. Research does not guarantee its accuracy or completeness and assumes no liability for any errors or omissions.
        Past performance is not indicative of future results; you should conduct your own research and consult a qualified financial professional before making any investment decisions.
      </small>
    </footer>
  </body>
</html>
